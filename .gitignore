# .NET build output
bin/
obj/
*.user
*.suo
.vs/

# NuGet
*.nupkg
packages/
nuget.config

# Rider / VS
.idea/
*.DotSettings.user

# OS
Thumbs.db
.DS_Store

# Developer session / knowledge files (contain local paths, internal IPs)
.agent.md
PENTEST.agent.md
PROJECT_LOG.md

# Publish output (large binary artifacts — run dotnet publish locally)
publish/

# Secrets / local config
appsettings.local.json
*.env
*.key
*.pem
*.pfx

# Tools/ is tracked — BenchmarkRunner included for community use
# Exclude only build artifacts within Tools/
Tools/**/bin/
Tools/**/obj/

# Training Pit — dataset JSONL files (large, contain model outputs, not versioned)
# Only examples/ and evals/ are committed; datasets/ is local-only
training_pit/datasets/*.jsonl
training_pit/datasets/staging/

# Training outputs (LoRA adapters, GGUFs — large binary artifacts)
training_pit/outputs/

# Swarm dataset staging (auto-generated plan captures from DatasetCapture.cs)
# Files require human review before moving to training_pit/datasets/
.orc/swarm/dataset-staging/
.orc/swarm/dataset-staging-test/
