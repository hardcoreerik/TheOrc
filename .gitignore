# Python cache
__pycache__/
*.py[cod]

# .NET build output
bin/
obj/
*.user
*.suo
.vs/

# NuGet
*.nupkg
packages/
nuget.config

# Rider / VS
.idea/
*.DotSettings.user

# OS
Thumbs.db
.DS_Store

# Developer session / knowledge files (contain local paths, internal IPs)
.agent.md
PENTEST.agent.md
PROJECT_LOG.md

# Internal dev scratch / session notes — not user-facing
dev-notes/
GOBLIN_MIND_TODO.md
GOBLIN_MIND_UPDATES.md
RESEARCH_TOOL_TODO.md
THE_ORC_HANDOFF.md
ROADMAP_MAC_PORT.md

# Root-level ROADMAP.md superseded by docs/ROADMAP.md
ROADMAP.md

# Portable release zips — upload to GitHub Releases, not committed to repo
TheOrc-*.zip
TheOrc-*.exe

# Runtime-generated swarm benchmark data
swarm-metrics.json

# Swarm benchmark workspace (live run outputs — not versioned)
OrchestratorIDE.SwarmBenchmarks/

# Meeting notes and personal documents
*.docx
*.doc

# Publish output (large binary artifacts — run dotnet publish locally)
publish/

# Secrets / local config
appsettings.local.json
*.env
*.key
*.pem
*.pfx

# Tools/ is tracked — BenchmarkRunner included for community use
# Exclude only build artifacts within Tools/
Tools/**/bin/
Tools/**/obj/

# Training Pit — dataset JSONL files (large, contain model outputs, not versioned)
# Only examples/ and evals/ are committed; datasets/ is local-only
training_pit/datasets/*.jsonl
training_pit/datasets/*.jsonl.bak
training_pit/datasets/staging/

# Training outputs (LoRA adapters, GGUFs — large binary artifacts)
training_pit/outputs/

# Training Pit harvest batch files (auto-generated per-run capture batches)
training_pit/batch_*.csv
training_pit/batch_*.psv
training_pit/batch_*.tsv
training_pit/review_sweep.tsv
training_pit/flag_review.txt

# GGUF model files — binary artifacts, host on HuggingFace or Ollama registry
*.gguf

# Swarm dataset staging (auto-generated plan captures from DatasetCapture.cs)
# Files require human review before moving to training_pit/datasets/
.orc/swarm/dataset-staging/
.orc/swarm/dataset-staging-test/

# All TheOrc local runtime state (runs, staging, manual captures) — local-only by design
.orc/

# Test result artifacts
test-results/

# .grok/ is internal dev scratch (specs, prompts, launch scripts, spike code) —
# not user-facing, kept local-only by default. PROJECT_TRUTH.md is the one
# exception: explicit decision 2026-06-20 to keep it public.
.grok/*
!.grok/PROJECT_TRUTH.md

# Root-level dev-planning notes — internal, not user-facing (2026-06-20)
/Avalonia_Migration.md
/CodeGraph_v1.md
/ContentAwareDatasets_v1.md
/TrainingFlags_Guide.md
/MARKER_NOTE.md

# Scratch review/diff artifacts (codex-review.ps1, dataset verification runs, etc.)
.grok/*_run.log
.grok/*run*.log
training_pit/datasets/*_run.log
training_pit/datasets/*.log
Tools/*.log
/*.diff
/temp_*.diff
/*_diffs.diff
/staged_*.diff
/combined_review_diff.txt

# Scratch files from ad-hoc file-diffing/inventory work during a session —
# not a deliverable, never meant to be committed (found accumulating 2026-06-20)
/staged_*.txt
*.staged.tmp

# Spike harness re-run output (regenerable; canonical finding lives in RUNTIME_PHASE0_SPEC.md)
.grok/spike-assets/**/*.log

# Marketplace — local publishing staging (Gumroad listings, model cards, release
# packages). Business/product copy + pricing, kept local-only by default; not part
# of the source tree (decision 2026-06-23). Was previously only ignoring *.zip.
marketplace/
