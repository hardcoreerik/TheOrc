<Window x:Class="OrchestratorIDE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:panels="clr-namespace:OrchestratorIDE.UI.Panels"
        xmlns:controls="clr-namespace:OrchestratorIDE.UI.Controls"
        mc:Ignorable="d"
        Title="Orchestrator IDE" Height="800" Width="1300"
        Background="{StaticResource Br.Bg.App}"
        WindowState="Normal"
        KeyDown="Window_KeyDown">

    <!--
    ═══════════════════════════════════════════════════════════════════
    ROOT LAYOUT
    ┌─────────────────────────────────────────────────────────────────┐
    │  Title bar (custom)                                             │
    ├─────────────────────────────────────────────────────────────────┤
    │  Menu bar  File | Edit | View | Agent                           │
    ├────┬────────────────────────┬────────────────────────────────── │
    │ AB │  Sidebar               │  Agent Panel  │  Code Editor      │
    │    │  (file explorer /      │  (chat)       │  (AvalonEdit)     │
    │    │   settings …)          ├───────────────┴───────────────────│
    │    │                        │  Activity log                     │
    ├────┴────────────────────────┴──────────────────────────────────┤
    │  Status bar                                                     │
    └─────────────────────────────────────────────────────────────────┘
    AB = Activity Bar (narrow icon strip, left edge)
    ═══════════════════════════════════════════════════════════════════
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>   <!-- Title bar -->
            <RowDefinition Height="22"/>   <!-- Menu bar   -->
            <RowDefinition Height="*"/>    <!-- Workbench  -->
            <RowDefinition Height="24"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Title bar ──────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#323233" BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <TextBlock Text="⬡" Foreground="{StaticResource Br.Accent.Blue}"
                           Margin="10,0,6,0" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock Text="Orchestrator IDE" VerticalAlignment="Center"
                           FontSize="12" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,0,10,0">
                    <TextBlock x:Name="TbModelBadge" Text="gemma4:e4b · minimal"
                               Foreground="{StaticResource Br.Text.Muted}"
                               VerticalAlignment="Center" FontSize="11" Margin="0,0,16,0"/>
                    <TextBlock x:Name="TbContextPct" Text="0%"
                               Foreground="{StaticResource Br.Text.Muted}"
                               VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Menu bar ───────────────────────────────────────────── -->
        <Menu Grid.Row="1"
              Background="#2D2D2D" Foreground="#CCCCCC"
              BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,0,1"
              FontSize="12">

            <Menu.Resources>
                <!-- Dark style for top-level and popup items -->
                <Style TargetType="MenuItem">
                    <Setter Property="Background"   Value="#2D2D2D"/>
                    <Setter Property="Foreground"   Value="#CCCCCC"/>
                    <Setter Property="BorderBrush"  Value="#3C3C3C"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#094771"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#666"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
                <Style TargetType="Separator">
                    <Setter Property="Background" Value="#3C3C3C"/>
                    <Setter Property="Margin"     Value="4,2"/>
                </Style>
            </Menu.Resources>

            <!-- ── File ─────────────────────────────────────────── -->
            <MenuItem Header="_File">
                <MenuItem Header="Open Folder…"    InputGestureText="Ctrl+O"   Click="Menu_OpenFolder"/>
                <MenuItem Header="Open in Explorer"                             Click="Menu_OpenExplorer"/>
                <Separator/>
                <MenuItem Header="New Session"      InputGestureText="Ctrl+N"   Click="Menu_NewSession"/>
                <Separator/>
                <MenuItem Header="Exit"             InputGestureText="Alt+F4"   Click="Menu_Exit"/>
            </MenuItem>

            <!-- ── Edit ─────────────────────────────────────────── -->
            <MenuItem Header="_Edit">
                <MenuItem Header="Command Palette…" InputGestureText="Ctrl+K"   Click="Menu_CommandPalette"/>
                <Separator/>
                <MenuItem Header="Settings"                                      Click="Menu_Settings"/>
            </MenuItem>

            <!-- ── View ─────────────────────────────────────────── -->
            <MenuItem Header="_View">
                <MenuItem Header="File Explorer"    InputGestureText="Ctrl+Shift+E"  Click="Menu_ShowExplorer"/>
                <MenuItem Header="Code Editor"      InputGestureText="Ctrl+Shift+C"  Click="Menu_ToggleEditor"/>
                <MenuItem Header="Edit Rules File"  InputGestureText="Ctrl+Shift+R"  Click="Menu_EditRules"/>
                <Separator/>
                <MenuItem x:Name="MiWordWrap" Header="Word Wrap" IsCheckable="True"  Click="Menu_WordWrap"/>
                <Separator/>
                <MenuItem Header="Increase Font Size"   InputGestureText="Ctrl+="   Click="Menu_FontBigger"/>
                <MenuItem Header="Decrease Font Size"   InputGestureText="Ctrl+-"   Click="Menu_FontSmaller"/>
                <MenuItem Header="Reset Font Size"      InputGestureText="Ctrl+0"   Click="Menu_FontReset"/>
            </MenuItem>

            <!-- ── Agent ────────────────────────────────────────── -->
            <MenuItem Header="_Agent">
                <MenuItem Header="Plan Mode"                                    Click="Menu_ModePlan"/>
                <MenuItem Header="Execute Mode"                                 Click="Menu_ModeExecute"/>
                <Separator/>
                <MenuItem Header="Change Model…"                                Click="Menu_ChangeModel"/>
                <Separator/>
                <MenuItem Header="New Session"                                  Click="Menu_NewSession"/>
            </MenuItem>
        </Menu>

        <!-- ── Workbench ──────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44"/>   <!-- Activity bar -->
                <ColumnDefinition Width="220" MinWidth="140"/>  <!-- Sidebar -->
                <ColumnDefinition Width="4"/>    <!-- Splitter -->
                <ColumnDefinition Width="*"/>    <!-- Main -->
            </Grid.ColumnDefinitions>

            <!-- Activity Bar -->
            <Border Grid.Column="0" Background="#333333">
                <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                    <Button x:Name="BtnExplorer" Content="📁" ToolTip="File Explorer (Ctrl+Shift+E)"
                            Style="{StaticResource ActivityBtnStyle}"
                            Click="BtnExplorer_Click"/>
                    <Button x:Name="BtnAgent" Content="⚡" ToolTip="Code Agent (Ctrl+Shift+A)"
                            Style="{StaticResource ActivityBtnStyle}"
                            Click="BtnAgent_Click"/>
                    <Button x:Name="BtnCheckpoints" Content="⬡" ToolTip="Checkpoints"
                            Style="{StaticResource ActivityBtnStyle}"
                            Click="BtnCheckpoints_Click"/>
                    <Button x:Name="BtnTools" Content="🔧" ToolTip="Tool Editor — write + hot-load custom tools (Phase 7)"
                            Style="{StaticResource ActivityBtnStyle}"
                            Click="BtnTools_Click"/>
                    <Button x:Name="BtnSettings" Content="⚙" ToolTip="Settings"
                            Style="{StaticResource ActivityBtnStyle}"
                            Click="BtnSettings_Click"/>
                </StackPanel>
            </Border>

            <!-- Sidebar -->
            <Border Grid.Column="1" Background="{StaticResource Br.Bg.Sidebar}"
                    BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,1,0">
                <!-- Sidebar content swapped by activity bar buttons -->
                <ContentPresenter x:Name="SidebarContent"/>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="2" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource Br.Border}" Cursor="SizeWE"/>

            <!-- Main area: vertical split — [Agent+Editor] top / Activity log bottom -->
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>              <!-- Top: Agent + Editor -->
                    <RowDefinition Height="4"/>               <!-- H-splitter -->
                    <RowDefinition Height="*" MinHeight="60"/><!-- Activity log -->
                </Grid.RowDefinitions>

                <!-- Top: horizontal split — Agent panel | Editor pane -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="300"/>           <!-- Agent -->
                        <ColumnDefinition x:Name="ColEditorSplitter" Width="0"/> <!-- V-splitter -->
                        <ColumnDefinition x:Name="ColEditor" Width="0"/>         <!-- Editor (hidden until file opened) -->
                    </Grid.ColumnDefinitions>

                    <!-- Agent panel (chat bubbles + diff + input) -->
                    <ContentPresenter x:Name="MainContent" Grid.Column="0"/>

                    <!-- Vertical splitter between agent and editor -->
                    <GridSplitter x:Name="SplitterEditor"
                                  Grid.Column="1"
                                  Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource Br.Border}"
                                  Cursor="SizeWE"
                                  Visibility="Collapsed"/>

                    <!-- Code editor pane -->
                    <ContentPresenter x:Name="EditorContent"
                                      Grid.Column="2"
                                      Visibility="Collapsed"/>
                </Grid>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              Background="{StaticResource Br.Border}" Cursor="SizeNS"/>

                <!-- Activity log (streaming tool events) -->
                <Border Grid.Row="2" Background="{StaticResource Br.Bg.Panel}"
                        BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ACTIVITY"
                                   Foreground="{StaticResource Br.Text.Muted}"
                                   FontSize="10" FontWeight="Bold" Padding="8,4"
                                   Background="#2D2D2D"/>
                        <ScrollViewer x:Name="ActivityScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="ActivityLog" Padding="6,2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                       Foreground="{StaticResource Br.Accent.Blue}"
                                                       FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                       Foreground="{StaticResource Br.Text.Muted}"
                                                       FontSize="11" Margin="4,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Detail}"
                                                       FontSize="11" TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Status bar ─────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="{StaticResource Br.Bg.StatusBar}">
            <DockPanel>
                <TextBlock x:Name="SbWorkspace" DockPanel.Dock="Left"
                           Text="📁 No workspace" Foreground="{StaticResource Br.Text.White}"
                           Margin="8,0" VerticalAlignment="Center" FontSize="11"/>
                <TextBlock x:Name="SbBranch" DockPanel.Dock="Left"
                           Text="" Foreground="#B0D0FF"
                           Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11"/>
                <TextBlock x:Name="SbModel" DockPanel.Dock="Right"
                           Foreground="{StaticResource Br.Text.White}"
                           Margin="8,0" VerticalAlignment="Center" FontSize="11"
                           Cursor="Hand" MouseDown="SbModel_Click"
                           ToolTip="Click to change model"/>
                <TextBlock x:Name="SbStatus" Text="Ready"
                           Foreground="{StaticResource Br.Text.White}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
            </DockPanel>
        </Border>

        <!-- Model picker popup — anchors above the status bar model badge -->
        <Popup x:Name="ModelPickerPopup"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Slide">
            <controls:ModelPickerPopup x:Name="ModelPickerContent"/>
        </Popup>

        <!-- Command palette overlay — centered, Ctrl+K -->
        <Popup x:Name="CmdPalettePopup"
               Placement="Center"
               PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <controls:CommandPalette x:Name="CmdPaletteContent"/>
        </Popup>

    </Grid>

</Window>
