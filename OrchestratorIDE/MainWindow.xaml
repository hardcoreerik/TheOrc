<Window x:Class="OrchestratorIDE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:panels="clr-namespace:OrchestratorIDE.UI.Panels"
        xmlns:controls="clr-namespace:OrchestratorIDE.UI.Controls"
        mc:Ignorable="d"
        Title="Orchestrator IDE" Height="800" Width="1300"
        Background="{StaticResource Br.Bg.App}"
        WindowState="Normal"
        KeyDown="Window_KeyDown"
        AutomationProperties.AutomationId="MainWindow"
        AutomationProperties.Name="Orchestrator IDE">

    <!--
    ═══════════════════════════════════════════════════════════════════
    ROOT LAYOUT
    ┌─────────────────────────────────────────────────────────────────┐
    │  Title bar (custom)                                             │
    ├─────────────────────────────────────────────────────────────────┤
    │  Menu bar  File | Edit | View | Agent                           │
    ├────┬────────────────────────┬────────────────────────────────── │
    │ AB │  Sidebar               │  Agent Panel  │  Code Editor      │
    │    │  (file explorer /      │  (chat)       │  (AvalonEdit)     │
    │    │   settings …)          ├───────────────┴───────────────────│
    │    │                        │  Activity log                     │
    ├────┴────────────────────────┴──────────────────────────────────┤
    │  Status bar                                                     │
    └─────────────────────────────────────────────────────────────────┘
    AB = Activity Bar (narrow icon strip, left edge)
    ═══════════════════════════════════════════════════════════════════
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>   <!-- Title bar -->
            <RowDefinition Height="26"/>   <!-- Menu bar   -->
            <RowDefinition Height="*"/>    <!-- Workbench  -->
            <RowDefinition Height="30"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Title bar ──────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0E0E0E" BorderBrush="#2A3A2A"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">

                <!-- NVIDIA-green left brand stripe -->
                <Border DockPanel.Dock="Left" Width="4"
                        Background="{StaticResource Br.Accent.Green}"/>

                <!-- TheOrc wordmark -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="10,0,0,0">
                    <!-- Hex logo glyph -->
                    <TextBlock Text="⬡" Foreground="{StaticResource Br.Accent.Green}"
                               FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <!-- Brand name -->
                    <TextBlock Text="TheOrc"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                               FontFamily="Consolas, 'Cascadia Code', monospace"/>
                    <!-- Divider + subtitle -->
                    <TextBlock Text=" · " Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="Orchestrator IDE"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: mode toggle + model badge + context % -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,12,0">

                    <!-- ── Mode toggle pill ────────────────────────────── -->
                    <Border Background="#161616" CornerRadius="4"
                            BorderBrush="#2A3A2A" BorderThickness="1"
                            Margin="0,0,12,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <!-- Single agent button -->
                            <Button x:Name="BtnModeSingle"
                                    Content="⚡ Single"
                                    ToolTip="Single Agent mode — focused coding session"
                                    Padding="10,4"
                                    FontSize="11" FontFamily="Segoe UI"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnModeSingle_Click"
                                    AutomationProperties.AutomationId="Mode.Single">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="3,0,0,3"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Divider -->
                            <Rectangle Width="1" Fill="#2A3A2A"/>
                            <!-- Swarm button -->
                            <Button x:Name="BtnModeSwarm"
                                    Content="🐝 Swarm"
                                    ToolTip="Swarm multi-agent mode"
                                    Padding="10,4"
                                    FontSize="11" FontFamily="Segoe UI"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnModeSwarm_Click"
                                    AutomationProperties.AutomationId="Mode.Swarm">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="0,0,0,0"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Divider -->
                            <Rectangle Width="1" Fill="#2A3A2A"/>
                            <!-- Chat button -->
                            <Button x:Name="BtnModeChat"
                                    Content="💬 Chat"
                                    ToolTip="Just Chat — research with web search"
                                    Padding="10,4"
                                    FontSize="11" FontFamily="Segoe UI"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnModeChat_Click"
                                    AutomationProperties.AutomationId="Mode.Chat">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="0,0,0,0"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Divider -->
                            <Rectangle Width="1" Fill="#2A3A2A"/>
                            <!-- Training Pit button -->
                            <Button x:Name="BtnModePit"
                                    ToolTip="Training Pit — dataset farming, review queue, night harvest"
                                    Padding="10,4"
                                    FontSize="11" FontFamily="Segoe UI"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnModePit_Click"
                                    AutomationProperties.AutomationId="Mode.Pit">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="0,3,3,0"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⛏ Pit"/>
                                    <Ellipse x:Name="PitLiveDot" Width="7" Height="7" Fill="#76B900"
                                             VerticalAlignment="Center" Margin="5,0,0,0"
                                             Visibility="Collapsed"
                                             ToolTip="The pit is collecting plans right now"/>
                                    <TextBlock x:Name="PitQueueBadge" Text="" Margin="4,0,0,0"
                                               ToolTip="Plans waiting for your review"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Active model chip -->
                    <Border Background="#1A2A0A" CornerRadius="3" Padding="7,2"
                            Margin="0,0,10,0">
                        <TextBlock x:Name="TbModelBadge" Text="no model"
                                   Foreground="{StaticResource Br.Accent.Green}"
                                   FontSize="10" VerticalAlignment="Center"
                                   MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <!-- Context % -->
                    <TextBlock x:Name="TbContextPct" Text="0%"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── Menu bar ───────────────────────────────────────────── -->
        <Menu Grid.Row="1"
              Background="#141814" Foreground="#D4D4D4"
              BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,0,1"
              FontSize="12"
              ItemContainerStyle="{StaticResource MenuBarItemStyle}">

            <!-- ── File ─────────────────────────────────────────── -->
            <MenuItem Header="_File">
                <MenuItem Header="Open Folder…"    InputGestureText="Ctrl+O"   Click="Menu_OpenFolder"/>
                <MenuItem x:Name="MiOpenRecent" Header="Open Recent" IsEnabled="False"/>
                <MenuItem Header="Open in Explorer"                             Click="Menu_OpenExplorer"/>
                <Separator/>
                <MenuItem Header="New Session"      InputGestureText="Ctrl+N"   Click="Menu_NewSession"/>
                <Separator/>
                <MenuItem Header="Exit"             InputGestureText="Alt+F4"   Click="Menu_Exit"/>
            </MenuItem>

            <!-- ── Edit ─────────────────────────────────────────── -->
            <MenuItem Header="_Edit">
                <MenuItem Header="Command Palette…" InputGestureText="Ctrl+K"   Click="Menu_CommandPalette"/>
                <Separator/>
                <MenuItem Header="Settings"                                      Click="Menu_Settings"/>
            </MenuItem>

            <!-- ── View ─────────────────────────────────────────── -->
            <MenuItem Header="_View">
                <MenuItem Header="File Explorer"    InputGestureText="Ctrl+Shift+E"  Click="Menu_ShowExplorer"/>
                <MenuItem Header="Code Editor"      InputGestureText="Ctrl+Shift+C"  Click="Menu_ToggleEditor"/>
                <MenuItem Header="Edit Rules File"  InputGestureText="Ctrl+Shift+R"  Click="Menu_EditRules"/>
                <Separator/>
                <MenuItem x:Name="MiWordWrap" Header="Word Wrap" IsCheckable="True"  Click="Menu_WordWrap"/>
                <Separator/>
                <MenuItem Header="Increase Font Size"   InputGestureText="Ctrl+="   Click="Menu_FontBigger"/>
                <MenuItem Header="Decrease Font Size"   InputGestureText="Ctrl+-"   Click="Menu_FontSmaller"/>
                <MenuItem Header="Reset Font Size"      InputGestureText="Ctrl+0"   Click="Menu_FontReset"/>
            </MenuItem>

            <!-- ── Agent ────────────────────────────────────────── -->
            <MenuItem Header="_Agent">
                <MenuItem Header="Plan Mode"                                    Click="Menu_ModePlan"/>
                <MenuItem Header="Execute Mode"                                 Click="Menu_ModeExecute"/>
                <Separator/>
                <MenuItem Header="Change Model…"                                Click="Menu_ChangeModel"/>
                <Separator/>
                <MenuItem Header="New Session"                                  Click="Menu_NewSession"/>
            </MenuItem>

            <!-- ── Models ─────────────────────────────────────────── -->
            <MenuItem Header="_Models"
                      AutomationProperties.AutomationId="Menu.Models">
                <MenuItem Header="Choose Model…"
                          InputGestureText="Ctrl+Shift+M"
                          Click="Menu_ModelChoose"/>
                <MenuItem Header="Download Models…"
                          Click="Menu_ModelDownload"/>
                <Separator/>
                <MenuItem Header="Warm Up">
                    <MenuItem Header="Worker · Coder"      Tag="worker"     Click="Menu_WarmUp"/>
                    <MenuItem Header="Boss · Orchestrator" Tag="boss"       Click="Menu_WarmUp"/>
                    <MenuItem Header="Researcher"          Tag="researcher" Click="Menu_WarmUp"/>
                    <Separator/>
                    <MenuItem Header="Edit Warm-Up Scripts…" Click="Menu_WarmUpEdit"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Run Tool Call Tests…"
                          Click="Menu_RunToolProbe"/>
                <MenuItem Header="Run Model Capability Test…"
                          AutomationProperties.AutomationId="Menu.ModelCapabilityTest"
                          Click="Menu_RunModelCapabilityTest"/>
                <Separator/>
                <MenuItem Header="Model Wiki / Lab…"
                          AutomationProperties.AutomationId="Menu.ModelWiki"
                          Click="Menu_ModelWiki"/>
                <Separator/>
                <MenuItem Header="Manage Library…"   Click="Menu_ModelLibrary"/>
            </MenuItem>

            <!-- ── Debug ─────────────────────────────────────────── -->
            <MenuItem Header="_Debug">
                <MenuItem Header="Start / Stop Recording"
                          InputGestureText="F12"
                          Click="Menu_ToggleRecording"/>
                <MenuItem Header="Open Recordings Folder…"
                          Click="Menu_OpenRecordings"/>
            </MenuItem>

            <!-- ── Help ──────────────────────────────────────────── -->
            <MenuItem Header="_Help"
                      AutomationProperties.AutomationId="Menu.Help">
                <MenuItem Header="Documentation"
                          AutomationProperties.AutomationId="Help.Documentation"
                          Click="Menu_HelpDocumentation"/>
                <MenuItem Header="Troubleshooting"
                          AutomationProperties.AutomationId="Help.Troubleshooting"
                          Click="Menu_HelpTroubleshooting"/>
                <MenuItem Header="Model Guide"
                          AutomationProperties.AutomationId="Help.ModelGuide"
                          Click="Menu_HelpModelGuide"/>
                <MenuItem Header="Training Pit Guide"
                          AutomationProperties.AutomationId="Help.TrainingPitGuide"
                          Click="Menu_HelpTrainingPitGuide"/>
                <Separator/>
                <MenuItem Header="Check for Updates…"   Click="Menu_CheckUpdates"/>
                <Separator/>
                <MenuItem Header="View Release Notes"   Click="Menu_ReleaseNotes"/>
                <MenuItem Header="GitHub Repository"    Click="Menu_GitHub"/>
            </MenuItem>
        </Menu>

        <!-- ── Workbench ──────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44"/>   <!-- Activity bar -->
                <ColumnDefinition Width="220" MinWidth="200"/>  <!-- Sidebar -->
                <ColumnDefinition Width="4"/>    <!-- Splitter -->
                <ColumnDefinition Width="*"/>    <!-- Main -->
            </Grid.ColumnDefinitions>

            <!-- Activity Bar -->
            <Border Grid.Column="0" Background="#101410">
                <DockPanel>
                    <!-- NVIDIA-green left accent stripe -->
                    <Border DockPanel.Dock="Left" Width="2"
                            Background="{StaticResource Br.Accent.Green}" Opacity="0.6"/>

                    <StackPanel VerticalAlignment="Top" Margin="0,6,0,0">
                        <!-- Orc brand glyph — top of bar -->
                        <Border Margin="0,0,0,6" Padding="0,4">
                            <TextBlock Text="⬡"
                                       Foreground="{StaticResource Br.Accent.Green}"
                                       FontSize="18" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Separator Background="{StaticResource Br.Border}" Margin="6,0,6,6" Height="1"/>

                        <Button x:Name="BtnExplorer" Content="📁" ToolTip="File Explorer (Ctrl+Shift+E)"
                                Style="{StaticResource ActivityBtnStyle}"
                                AutomationProperties.AutomationId="ActivityBar.Explorer"
                                Click="BtnExplorer_Click"/>
                        <Button x:Name="BtnAgent" Content="⚡" ToolTip="Code Agent (Ctrl+Shift+A)"
                                Style="{StaticResource ActivityBtnStyle}"
                                AutomationProperties.AutomationId="ActivityBar.Agent"
                                Click="BtnAgent_Click"/>
                        <Button x:Name="BtnCheckpoints" Content="⬡" ToolTip="Checkpoints"
                                Style="{StaticResource ActivityBtnStyle}"
                                AutomationProperties.AutomationId="ActivityBar.Checkpoints"
                                Click="BtnCheckpoints_Click"/>
                        <Button x:Name="BtnTools" Content="🔧" ToolTip="Tool Editor — write + hot-load custom tools (Phase 7)"
                                Style="{StaticResource ActivityBtnStyle}"
                                AutomationProperties.AutomationId="ActivityBar.Tools"
                                Click="BtnTools_Click"/>
                        <Button x:Name="BtnSettings" Content="⚙" ToolTip="Settings"
                                Style="{StaticResource ActivityBtnStyle}"
                                AutomationProperties.AutomationId="ActivityBar.Settings"
                                Click="BtnSettings_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Sidebar -->
            <Border Grid.Column="1" Background="{StaticResource Br.Bg.Sidebar}"
                    BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,1,0">
                <!-- Sidebar content swapped by activity bar buttons -->
                <ContentPresenter x:Name="SidebarContent"/>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="2" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource Br.Border}" Cursor="SizeWE"/>

            <!-- Main area: vertical split — [Agent+Editor] top / Activity log bottom -->
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>              <!-- Top: Agent + Editor -->
                    <RowDefinition Height="4"/>               <!-- H-splitter -->
                    <RowDefinition Height="*" MinHeight="60"/><!-- Activity log -->
                </Grid.RowDefinitions>

                <!-- Top: horizontal split — Agent panel | Editor pane -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="300"/>           <!-- Agent -->
                        <ColumnDefinition x:Name="ColEditorSplitter" Width="0"/> <!-- V-splitter -->
                        <ColumnDefinition x:Name="ColEditor" Width="0"/>         <!-- Editor (hidden until file opened) -->
                    </Grid.ColumnDefinitions>

                    <!-- Agent panel (chat bubbles + diff + input) -->
                    <ContentPresenter x:Name="MainContent" Grid.Column="0"/>

                    <!-- Vertical splitter between agent and editor -->
                    <GridSplitter x:Name="SplitterEditor"
                                  Grid.Column="1"
                                  Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource Br.Border}"
                                  Cursor="SizeWE"
                                  Visibility="Collapsed"/>

                    <!-- Code editor pane -->
                    <ContentPresenter x:Name="EditorContent"
                                      Grid.Column="2"
                                      Visibility="Collapsed"/>
                </Grid>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              Background="{StaticResource Br.Border}" Cursor="SizeNS"/>

                <!-- Activity log (streaming tool events) -->
                <Border Grid.Row="2" Background="{StaticResource Br.Bg.Panel}"
                        BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <!-- Header: title + verbosity selector -->
                        <DockPanel DockPanel.Dock="Top" Background="#141814" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="ACTIVITY"
                                       Foreground="{StaticResource Br.Text.Muted}"
                                       FontSize="10" FontWeight="Bold" Padding="8,4"/>
                            <!-- Verbosity buttons (right-aligned) -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,1,4,1">
                                <Button x:Name="VerbBtn1" Content="1" Tag="1"
                                        Width="20" Height="18" FontSize="9" Padding="0"
                                        Background="Transparent" Foreground="#999999"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Silent — hide all events"
                                        Click="VerbBtn_Click"/>
                                <Button x:Name="VerbBtn2" Content="2" Tag="2"
                                        Width="20" Height="18" FontSize="9" Padding="0"
                                        Background="Transparent" Foreground="#999999"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Default — key events only"
                                        Click="VerbBtn_Click"/>
                                <Button x:Name="VerbBtn3" Content="3" Tag="3"
                                        Width="20" Height="18" FontSize="9" Padding="0"
                                        Background="Transparent" Foreground="#999999"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Medium — + rules content, full tool args"
                                        Click="VerbBtn_Click"/>
                                <Button x:Name="VerbBtn4" Content="4" Tag="4"
                                        Width="20" Height="18" FontSize="9" Padding="0"
                                        Background="Transparent" Foreground="#999999"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="High — + step responses, full tool results"
                                        Click="VerbBtn_Click"/>
                                <Button x:Name="VerbBtn5" Content="5" Tag="5"
                                        Width="20" Height="18" FontSize="9" Padding="0"
                                        Background="Transparent" Foreground="#999999"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Everything — raw content, timing, full debug"
                                        Click="VerbBtn_Click"/>
                            </StackPanel>
                        </DockPanel>
                        <ScrollViewer x:Name="ActivityScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="ActivityLog" Padding="6,2"
                                          MouseLeftButtonDown="ActivityLog_MouseLeftButtonDown">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy detail"    Click="ActivityCopyDetail_Click"/>
                                                    <MenuItem Header="Copy full line" Click="ActivityCopyFull_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Save output to…">
                                                        <MenuItem Header="Markdown (.md)"  Tag="md"  Click="ActivitySaveOutput_Click"/>
                                                        <MenuItem Header="Log file (.log)" Tag="log" Click="ActivitySaveOutput_Click"/>
                                                        <MenuItem Header="Text file (.txt)" Tag="txt" Click="ActivitySaveOutput_Click"/>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="Clear log"      Click="ActivityClearLog_Click"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                       FontSize="11" VerticalAlignment="Top">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Br.Accent.Blue}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#CCA700"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                                <Setter Property="Foreground" Value="#F44747"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Rules">
                                                                <Setter Property="Foreground" Value="#9CDCFE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Git">
                                                                <Setter Property="Foreground" Value="#C586C0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Tool">
                                                                <Setter Property="Foreground" Value="#76B900"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="ToolResult">
                                                                <Setter Property="Foreground" Value="#5A9A00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Debug">
                                                                <Setter Property="Foreground" Value="#606060"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                       Foreground="{StaticResource Br.Text.Muted}"
                                                       FontSize="11" Margin="4,0"
                                                       VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Detail}"
                                                       FontSize="11" TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <!-- BasedOn inherits #D4D4D4 foreground from the global TextBlock style.
                                                         Without this, WPF falls back to its default Black. -->
                                                    <Style TargetType="TextBlock"
                                                           BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasFilePath}" Value="True">
                                                                <Setter Property="Cursor"  Value="Hand"/>
                                                                <Setter Property="ToolTip" Value="Click to open in editor"/>
                                                                <Setter Property="Foreground" Value="#9CDCFE"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Status bar ─────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="{StaticResource Br.Bg.StatusBar}">
            <DockPanel>
                <TextBlock x:Name="SbWorkspace" DockPanel.Dock="Left"
                           Text="📁 No workspace" Foreground="#A8CC80"
                           Margin="8,0" VerticalAlignment="Center" FontSize="13"
                           AutomationProperties.AutomationId="StatusBar.Workspace"/>
                <TextBlock x:Name="SbBranch" DockPanel.Dock="Left"
                           Text="" Foreground="#76B900"
                           Margin="0,0,8,0" VerticalAlignment="Center" FontSize="13"
                           AutomationProperties.AutomationId="StatusBar.Branch"/>
                <!-- Model status widget (populated by ModelStatusService) -->
                <Border x:Name="SbModelStatus"
                        DockPanel.Dock="Right"
                        Background="#111111" CornerRadius="3"
                        Padding="6,1" Margin="0,2,8,2"
                        Cursor="Hand" MouseDown="SbModelStatus_Click"
                        ToolTip="Model status — click to open Downloader"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtSbModelStatus"
                               Foreground="{StaticResource Br.Accent.Green}"
                               FontFamily="Consolas" FontSize="12"/>
                </Border>

                <TextBlock x:Name="SbModel" DockPanel.Dock="Right"
                           Foreground="#76B900"
                           Margin="8,0" VerticalAlignment="Center" FontSize="13"
                           Cursor="Hand" MouseDown="SbModel_Click"
                           ToolTip="Click to change model"
                           AutomationProperties.AutomationId="StatusBar.Model"/>

                <!-- ── Trust level selector ────────────────────────────── -->
                <Border DockPanel.Dock="Right"
                        Background="#111111"
                        BorderBrush="#2A2A2A" BorderThickness="1"
                        CornerRadius="3" Margin="0,2,8,2" Padding="1">
                    <StackPanel Orientation="Horizontal">

                        <Button x:Name="BtnTrustPlan"
                                Content="📋 Plan"
                                Tag="Plan"
                                Click="BtnTrust_Click"
                                ToolTip="Plan mode — agent reads and reasons only. No files written, no shell commands run."
                                AutomationProperties.AutomationId="Trust.Plan">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TrustPillStyle}"/>
                            </Button.Style>
                        </Button>

                        <Rectangle Width="1" Fill="#2A2A2A" Margin="1,3"/>

                        <Button x:Name="BtnTrustGuarded"
                                Content="🛡 Guarded"
                                Tag="Guarded"
                                Click="BtnTrust_Click"
                                ToolTip="Guarded — every file write and shell command requires your explicit approval."
                                AutomationProperties.AutomationId="Trust.Guarded">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TrustPillStyle}"/>
                            </Button.Style>
                        </Button>

                        <Rectangle Width="1" Fill="#2A2A2A" Margin="1,3"/>

                        <Button x:Name="BtnTrustStandard"
                                Content="✅ Standard"
                                Tag="Standard"
                                Click="BtnTrust_Click"
                                ToolTip="Standard — file writes are auto-approved; shell commands still require approval."
                                AutomationProperties.AutomationId="Trust.Standard">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TrustPillStyle}"/>
                            </Button.Style>
                        </Button>

                        <Rectangle Width="1" Fill="#2A2A2A" Margin="1,3"/>

                        <Button x:Name="BtnTrustFullAuto"
                                Content="⚡ Full Auto"
                                Tag="FullAuto"
                                Click="BtnTrust_Click"
                                ToolTip="Full Auto — all tools run without prompts. Use with care."
                                AutomationProperties.AutomationId="Trust.FullAuto">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TrustPillStyle}"/>
                            </Button.Style>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- ── Pending approval chips (hidden until diff/shell is waiting) ── -->
                <Border x:Name="BdrApprovalChip"
                        DockPanel.Dock="Right"
                        Visibility="Collapsed"
                        Background="#1A2A00"
                        BorderBrush="#76B900" BorderThickness="1"
                        CornerRadius="3" Margin="0,2,6,2" Padding="4,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock x:Name="TbApprovalChipLabel"
                                   Text="⏳ Approval needed"
                                   Foreground="#CCA700"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="4,0,8,0"/>

                        <!-- Apply button -->
                        <Button x:Name="BtnStatusApprove"
                                Click="BtnStatusApprove_Click"
                                ToolTip="Approve this action"
                                Cursor="Hand"
                                Margin="0,0,4,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="#1F3D00" BorderBrush="#2A5A00"
                                            BorderThickness="1" CornerRadius="3" Padding="7,3">
                                        <TextBlock Text="✓  Apply"
                                                   Foreground="#76B900"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A5A00"/>
                                            <Setter TargetName="Bd" Property="BorderBrush"  Value="#76B900"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Reject button -->
                        <Button x:Name="BtnStatusReject"
                                Click="BtnStatusReject_Click"
                                ToolTip="Reject this action"
                                Cursor="Hand"
                                Margin="0,0,2,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="#2A0A0A" BorderBrush="#4A1A1A"
                                            BorderThickness="1" CornerRadius="3" Padding="7,3">
                                        <TextBlock Text="✗  Reject"
                                                   Foreground="#F44747"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3A1414"/>
                                            <Setter TargetName="Bd" Property="BorderBrush"  Value="#F44747"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- Screenshot button -->
                <Border DockPanel.Dock="Right"
                        Background="#111111"
                        BorderBrush="#2A2A2A" BorderThickness="1"
                        CornerRadius="3"
                        Padding="8,2,8,2"
                        Margin="4,2,4,2"
                        Cursor="Hand"
                        MouseDown="BdrScreenshot_Click"
                        ToolTip="Take a screenshot of this window (saved to %APPDATA%\OrchestratorIDE\Screenshots)"
                        AutomationProperties.AutomationId="StatusBar.Screenshot">
                    <TextBlock Text="📷"
                               FontSize="15"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Recording indicator — visible only while screen recording is active -->
                <Border x:Name="BdrRecording"
                        DockPanel.Dock="Right"
                        Background="#5A0000"
                        CornerRadius="3"
                        Padding="6,0,6,0"
                        Margin="4,2,4,2"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        MouseDown="BdrRecording_Click"
                        ToolTip="Recording — click to stop (or press F12)">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#FF3333"
                                 VerticalAlignment="Center" Margin="0,0,5,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.2" Duration="0:0:0.8"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock x:Name="TbRecordingTime"
                                   Text="REC 00:00"
                                   Foreground="#FF9999"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Update badge — collapsed until a newer release is detected -->
                <Border x:Name="BdrUpdateBadge"
                        DockPanel.Dock="Right"
                        Background="#1A6B35"
                        CornerRadius="3"
                        Padding="6,0,6,0"
                        Margin="4,2,0,2"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        MouseDown="BdrUpdateBadge_Click"
                        ToolTip="Click to view release notes">
                    <TextBlock x:Name="TbUpdateBadge"
                               Text="↑ Update available"
                               Foreground="#AAFFAA"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="SbStatus" Text="Ready"
                           Foreground="{StaticResource Br.Text.White}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"
                           AutomationProperties.AutomationId="StatusBar.Status"/>
            </DockPanel>
        </Border>

        <!-- Model picker popup — anchors above the status bar model badge -->
        <Popup x:Name="ModelPickerPopup"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Slide">
            <controls:ModelPickerPopup x:Name="ModelPickerContent"/>
        </Popup>

        <!-- Command palette overlay — centered, Ctrl+K -->
        <Popup x:Name="CmdPalettePopup"
               Placement="Center"
               PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <controls:CommandPalette x:Name="CmdPaletteContent"/>
        </Popup>

    </Grid>

</Window>
