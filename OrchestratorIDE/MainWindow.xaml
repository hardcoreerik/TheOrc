<Window x:Class="OrchestratorIDE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:panels="clr-namespace:OrchestratorIDE.UI.Panels"
        xmlns:controls="clr-namespace:OrchestratorIDE.UI.Controls"
        mc:Ignorable="d"
        Title="Orchestrator IDE" Height="700" Width="1200"
        Background="{StaticResource Br.Bg.App}"
        WindowState="Normal"
        KeyDown="Window_KeyDown">

    <!--
    ═══════════════════════════════════════════════════════════════════
    ROOT LAYOUT
    ┌─────────────────────────────────────────────────────────────────┐
    │  Title bar (custom)                                             │
    ├────┬────────────────────────┬────────────────────────────────── │
    │ AB │  Sidebar               │  Main area                       │
    │    │  (file explorer /      │  (chat panel + activity log)     │
    │    │   agent panel list)    │                                   │
    ├────┴────────────────────────┴──────────────────────────────────┤
    │  Status bar                                                     │
    └─────────────────────────────────────────────────────────────────┘
    AB = Activity Bar (narrow icon strip, left edge)
    ═══════════════════════════════════════════════════════════════════
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>   <!-- Title bar -->
            <RowDefinition Height="*"/>    <!-- Workbench -->
            <RowDefinition Height="24"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Title bar ──────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#323233" BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <TextBlock Text="⬡" Foreground="{StaticResource Br.Accent.Blue}"
                           Margin="10,0,6,0" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock Text="Orchestrator IDE" VerticalAlignment="Center"
                           FontSize="12" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,0,10,0">
                    <TextBlock x:Name="TbModelBadge" Text="gemma4:e4b · minimal"
                               Foreground="{StaticResource Br.Text.Muted}"
                               VerticalAlignment="Center" FontSize="11" Margin="0,0,16,0"/>
                    <TextBlock x:Name="TbContextPct" Text="0%"
                               Foreground="{StaticResource Br.Text.Muted}"
                               VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Workbench ──────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44"/>   <!-- Activity bar -->
                <ColumnDefinition Width="220" MinWidth="140"/>  <!-- Sidebar -->
                <ColumnDefinition Width="4"/>    <!-- Splitter -->
                <ColumnDefinition Width="*"/>    <!-- Main -->
            </Grid.ColumnDefinitions>

            <!-- Activity Bar -->
            <Border Grid.Column="0" Background="#333333">
                <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                    <Button x:Name="BtnExplorer" Content="📁" ToolTip="File Explorer (Ctrl+Shift+E)"
                            Style="{StaticResource ActivityBtnStyle}"
                            Click="BtnExplorer_Click"/>
                    <Button x:Name="BtnAgent" Content="⚡" ToolTip="Code Agent (Ctrl+Shift+A)"
                            Style="{StaticResource ActivityBtnStyle}"
                            Click="BtnAgent_Click"/>
                    <Button x:Name="BtnCheckpoints" Content="⬡" ToolTip="Checkpoints"
                            Style="{StaticResource ActivityBtnStyle}"
                            Click="BtnCheckpoints_Click"/>
                    <Button x:Name="BtnSettings" Content="⚙" ToolTip="Settings"
                            Style="{StaticResource ActivityBtnStyle}"
                            Click="BtnSettings_Click"/>
                </StackPanel>
            </Border>

            <!-- Sidebar -->
            <Border Grid.Column="1" Background="{StaticResource Br.Bg.Sidebar}"
                    BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,1,0">
                <!-- Sidebar content swapped by activity bar buttons -->
                <ContentPresenter x:Name="SidebarContent"/>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="2" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource Br.Border}" Cursor="SizeWE"/>

            <!-- Main area: split — agent panel top, activity log bottom -->
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>   <!-- Agent panel (chat + input) -->
                    <RowDefinition Height="4"/>    <!-- Splitter -->
                    <RowDefinition Height="*" MinHeight="60"/>  <!-- Activity log -->
                </Grid.RowDefinitions>

                <!-- Agent panel (chat bubbles + diff + input) -->
                <ContentPresenter x:Name="MainContent" Grid.Row="0"/>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              Background="{StaticResource Br.Border}" Cursor="SizeNS"/>

                <!-- Activity log (streaming tool events) -->
                <Border Grid.Row="2" Background="{StaticResource Br.Bg.Panel}"
                        BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ACTIVITY"
                                   Foreground="{StaticResource Br.Text.Muted}"
                                   FontSize="10" FontWeight="Bold" Padding="8,4"
                                   Background="#2D2D2D"/>
                        <ScrollViewer x:Name="ActivityScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="ActivityLog" Padding="6,2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                       Foreground="{StaticResource Br.Accent.Blue}"
                                                       FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                       Foreground="{StaticResource Br.Text.Muted}"
                                                       FontSize="11" Margin="4,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Detail}"
                                                       FontSize="11" TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Status bar ─────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource Br.Bg.StatusBar}">
            <DockPanel>
                <TextBlock x:Name="SbWorkspace" DockPanel.Dock="Left"
                           Text="📁 No workspace" Foreground="{StaticResource Br.Text.White}"
                           Margin="8,0" VerticalAlignment="Center" FontSize="11"/>
                <TextBlock x:Name="SbBranch" DockPanel.Dock="Left"
                           Text="" Foreground="#B0D0FF"
                           Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11"/>
                <TextBlock x:Name="SbModel" DockPanel.Dock="Right"
                           Foreground="{StaticResource Br.Text.White}"
                           Margin="8,0" VerticalAlignment="Center" FontSize="11"
                           Cursor="Hand" MouseDown="SbModel_Click"
                           ToolTip="Click to change model"/>
                <TextBlock x:Name="SbStatus" Text="Ready"
                           Foreground="{StaticResource Br.Text.White}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
            </DockPanel>
        </Border>

        <!-- Model picker popup — anchors above the status bar model badge -->
        <Popup x:Name="ModelPickerPopup"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Slide">
            <controls:ModelPickerPopup x:Name="ModelPickerContent"/>
        </Popup>

        <!-- Command palette overlay — centered, Ctrl+K -->
        <Popup x:Name="CmdPalettePopup"
               Placement="Center"
               PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <controls:CommandPalette x:Name="CmdPaletteContent"/>
        </Popup>

    </Grid>

</Window>
