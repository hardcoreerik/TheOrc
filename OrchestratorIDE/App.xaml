<Application x:Class="OrchestratorIDE.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OrchestratorIDE">
    <Application.Resources>

        <!-- ══════════════════════════════════════════════════════════
             TheOrc — NVIDIA/Orc colour palette
             Primary accent : #76B900  (NVIDIA green)
             Hero dark      : #161616  (near-black canvas)
             Orc tint       : subtle green cast on chrome surfaces
             ══════════════════════════════════════════════════════════ -->

        <!-- Backgrounds -->
        <SolidColorBrush x:Key="Br.Bg.App"       Color="#161616"/>
        <SolidColorBrush x:Key="Br.Bg.Panel"     Color="#1C1C1C"/>
        <SolidColorBrush x:Key="Br.Bg.Sidebar"   Color="#1A201A"/>
        <SolidColorBrush x:Key="Br.Bg.StatusBar" Color="#1A3300"/>
        <SolidColorBrush x:Key="Br.Bg.Input"     Color="#252525"/>
        <SolidColorBrush x:Key="Br.Bg.Hover"     Color="#1C2A1C"/>
        <SolidColorBrush x:Key="Br.Bg.Active"    Color="#1F3D00"/>

        <!-- Chrome -->
        <SolidColorBrush x:Key="Br.Border"       Color="#2E3A2E"/>

        <!-- Text -->
        <SolidColorBrush x:Key="Br.Text.Primary" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="Br.Text.Default" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="Br.Text.Muted"   Color="#7A8A6A"/>
        <SolidColorBrush x:Key="Br.Text.White"   Color="#FFFFFF"/>

        <!-- Accents -->
        <SolidColorBrush x:Key="Br.Accent.Green" Color="#76B900"/>   <!-- NVIDIA green — primary -->
        <SolidColorBrush x:Key="Br.Accent.Neon"  Color="#9DFF00"/>   <!-- electric highlight -->
        <SolidColorBrush x:Key="Br.Accent.Blue"  Color="#569CD6"/>   <!-- kept for diff/data -->

        <!-- State -->
        <SolidColorBrush x:Key="Br.Warning"      Color="#CCA700"/>
        <SolidColorBrush x:Key="Br.Error"        Color="#F44747"/>

        <!-- ── Global font ───────────────────────────────────────────── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Br.Text.Primary}"/>
            <Setter Property="FontFamily" Value="Consolas, 'Cascadia Code', monospace"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="{StaticResource Br.Bg.Input}"/>
            <Setter Property="Foreground"  Value="{StaticResource Br.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Br.Border}"/>
            <Setter Property="FontFamily"  Value="Consolas, 'Cascadia Code', monospace"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="CaretBrush" Value="{StaticResource Br.Text.Primary}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background"  Value="{StaticResource Br.Bg.Input}"/>
            <Setter Property="Foreground"  Value="{StaticResource Br.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Br.Border}"/>
            <Setter Property="Padding"     Value="8,4"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>

        <!-- File tree item style -->
        <Style x:Key="FileTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource Br.Text.Primary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="2,1"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Br.Bg.Hover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Br.Bg.Active}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Settings panel styles ────────────────────────────────────── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource Br.Text.Muted}"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="8,8,8,2"/>
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Br.Text.Primary}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>

        <Style x:Key="SettingHint" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource Br.Text.Muted}"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SettingInput" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource Br.Bg.Input}"/>
            <Setter Property="Foreground"      Value="{StaticResource Br.Text.Primary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Br.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,5"/>
            <Setter Property="FontFamily"      Value="Consolas, 'Cascadia Code', monospace"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <Style x:Key="SettingRow" TargetType="StackPanel">
            <Setter Property="Margin" Value="8,4,8,4"/>
        </Style>

        <Style x:Key="SettingRowBorder" TargetType="Border">
            <Setter Property="Margin"  Value="8,4,8,4"/>
            <Setter Property="Padding" Value="0,6"/>
        </Style>

        <!-- Toggle switch -->
        <Style x:Key="ToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width"             Value="40"/>
            <Setter Property="Height"            Value="20"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" CornerRadius="10" Width="40" Height="20"
                                Background="{StaticResource Br.Bg.Input}">
                            <Ellipse x:Name="Thumb" Width="14" Height="14"
                                     Fill="{StaticResource Br.Text.Muted}"
                                     HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"
                                        Value="#2A5200"/>
                                <Setter TargetName="Thumb" Property="Fill"
                                        Value="{StaticResource Br.Accent.Green}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment"
                                        Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin"
                                        Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ContextMenu ────────────────────────────────────────────────────
             Dark popup with drop-shadow. Grid.IsSharedSizeScope aligns icon,
             label, gesture, and arrow columns across all sibling items.
        ─────────────────────────────────────────────────────────────────── -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background"            Value="#1C1C1C"/>
            <Setter Property="BorderBrush"           Value="#383838"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="Padding"               Value="0,3"/>
            <Setter Property="SnapsToDevicePixels"   Value="True"/>
            <Setter Property="Grid.IsSharedSizeScope" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                MinWidth="180"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.60"
                                                  BlurRadius="16" ShadowDepth="5"
                                                  Direction="270"/>
                            </Border.Effect>
                            <ScrollViewer CanContentScroll="True"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter SnapsToDevicePixels="True"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Separator ─────────────────────────────────────────────────────
             Thin dark-grey rule with vertical breathing room.
        ─────────────────────────────────────────────────────────────────── -->
        <Style TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Rectangle Height="1" Fill="#333333" Margin="8,3,8,3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── MenuItem ──────────────────────────────────────────────────────
             Handles all four WPF roles:
               TopLevelHeader / TopLevelItem  — horizontal menu-bar entries
               SubmenuHeader / SubmenuItem    — context-menu / popup entries
             Layout: [28px icon] [label *] [shortcut auto] [16px arrow]
             Hover:  #1F3D00 bg, #76B900 text (NVIDIA-green brand).
        ─────────────────────────────────────────────────────────────────── -->
        <Style TargetType="MenuItem">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Foreground"     Value="#D4D4D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"     Value="Segoe UI"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid SnapsToDevicePixels="True">

                            <!-- Hover / active fill -->
                            <Border x:Name="HoverBg"
                                    Background="Transparent"
                                    Margin="4,1"/>

                            <!-- Four-column content row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- Icon: hidden for TopLevel roles -->
                                    <ColumnDefinition x:Name="ColIcon"
                                                      Width="28"
                                                      SharedSizeGroup="MenuIcon"/>
                                    <!-- Label -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- Keyboard shortcut -->
                                    <ColumnDefinition Width="Auto"
                                                      SharedSizeGroup="MenuGesture"/>
                                    <!-- Submenu arrow -->
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon (or check mark) -->
                                <ContentPresenter x:Name="Icon"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="6,4"/>

                                <!-- Header label -->
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"
                                                  Margin="2,6,0,6"/>

                                <!-- Keyboard gesture (right-justified, muted) -->
                                <TextBlock x:Name="GestureText"
                                           Grid.Column="2"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="#606060"
                                           VerticalAlignment="Center"
                                           Margin="24,0,8,0"
                                           FontSize="11"
                                           FontFamily="Segoe UI"/>

                                <!-- › arrow for submenus -->
                                <TextBlock x:Name="Arrow"
                                           Grid.Column="3"
                                           Text="›"
                                           FontSize="15"
                                           Foreground="#606060"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,0,3,0"
                                           Visibility="Collapsed"/>
                            </Grid>

                            <!-- Submenu popup — used for both TopLevel (Below) and Submenu (Right) -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="None"
                                   Grid.IsSharedSizeScope="True">
                                <Border Background="#1C1C1C"
                                        BorderBrush="#383838"
                                        BorderThickness="1"
                                        Padding="0,3"
                                        MinWidth="180"
                                        SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.60"
                                                          BlurRadius="16" ShadowDepth="5"
                                                          Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter SnapsToDevicePixels="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>

                            <!-- ── Hover ────────────────────────────────── -->
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="HoverBg"   Property="Background" Value="#1F3D00"/>
                                <Setter Property="Foreground"  Value="#76B900"/>
                                <Setter TargetName="GestureText" Property="Foreground" Value="#4A7A00"/>
                                <Setter TargetName="Arrow"     Property="Foreground" Value="#76B900"/>
                            </Trigger>

                            <!-- Submenu open (keep highlight while popup is visible) -->
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="HoverBg"  Property="Background" Value="#1F3D00"/>
                                <Setter Property="Foreground" Value="#76B900"/>
                            </Trigger>

                            <!-- ── Disabled ─────────────────────────────── -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"              Value="#4A4A4A"/>
                                <Setter TargetName="GestureText" Property="Foreground" Value="#3C3C3C"/>
                                <Setter TargetName="Icon"        Property="Opacity"    Value="0.35"/>
                            </Trigger>

                            <!-- ── Submenu items (context menu / flyout) ── -->
                            <!-- Show arrow when this item has children -->
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow"       Property="Visibility" Value="Visible"/>
                                <Setter TargetName="PART_Popup"  Property="Placement"  Value="Right"/>
                                <Setter TargetName="PART_Popup"  Property="HorizontalOffset" Value="-4"/>
                            </Trigger>

                            <!-- ── TopLevel items (menu bar) ────────────── -->
                            <!-- Compact presentation: no icon, no gesture, no arrow -->
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="Icon"        Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Arrow"       Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="ColIcon"     Property="Width"      Value="0"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="Icon"        Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Arrow"       Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="ColIcon"     Property="Width"      Value="0"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Menu bar item style ────────────────────────────────────────────
             Applied via Menu.ItemContainerStyle so it only affects the
             horizontal top-bar entries, not context-menu popup items.
             Popup items inside the dropdown still use the global MenuItem style.
        ─────────────────────────────────────────────────────────────────── -->
        <Style x:Key="MenuBarItemStyle" TargetType="MenuItem">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Foreground"     Value="#D4D4D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"     Value="Segoe UI"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="Padding"        Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <!-- Grid is the single required root for a ControlTemplate.
                             Border provides the hit-test/hover area; Popup floats below. -->
                        <Grid>
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"/>
                            </Border>

                            <!-- Dropdown popup — items inside use the global MenuItem style -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="None"
                                   Grid.IsSharedSizeScope="True">
                                <Border Background="#1C1C1C"
                                        BorderBrush="#383838"
                                        BorderThickness="1"
                                        Padding="0,3"
                                        MinWidth="200"
                                        SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.60"
                                                          BlurRadius="16" ShadowDepth="5"
                                                          Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter SnapsToDevicePixels="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1F3D00"/>
                                <Setter Property="Foreground" Value="#76B900"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1F3D00"/>
                                <Setter Property="Foreground" Value="#76B900"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Trust level pill button (status bar selector) -->
        <Style x:Key="TrustPillStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Model Wiki styles ─────────────────────────────────────────────────
             FilterChipStyle  — toggled pill buttons in the wiki left pane
             WikiSectionHeader — muted uppercase section label
             WikiSectionBody   — dark-bordered content area
        ─────────────────────────────────────────────────────────────────── -->
        <Style x:Key="FilterChipStyle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="#111A11"/>
            <Setter Property="Foreground"      Value="{StaticResource Br.Text.Muted}"/>
            <Setter Property="BorderBrush"     Value="#2A3A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Margin"          Value="0,0,4,4"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#1A3A0A"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="{StaticResource Br.Accent.Green}"/>
                                <Setter Property="Foreground" Value="{StaticResource Br.Accent.Green}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#182818"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WikiSectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource Br.Text.Muted}"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,12,0,4"/>
        </Style>

        <Style x:Key="WikiSectionBody" TargetType="Border">
            <Setter Property="Background"      Value="#0A120A"/>
            <Setter Property="BorderBrush"     Value="#1E2E1E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Margin"          Value="0,0,0,4"/>
        </Style>

        <!-- Activity bar icon buttons -->
        <Style x:Key="ActivityBtnStyle" TargetType="Button">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource Br.Text.Muted}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize"    Value="16"/>
            <Setter Property="Width"       Value="44"/>
            <Setter Property="Height"      Value="44"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Br.Bg.Hover}"/>
                                <Setter Property="Foreground" Value="{StaticResource Br.Accent.Green}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
