<Window x:Class="OrchestratorIDE.Tests.ToolCallTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TheOrc — Tool Call Tests · Goblin Mind"
        Width="1120" Height="660"
        MinWidth="800" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1A">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- model selector + controls -->
            <RowDefinition Height="*"/>      <!-- results table -->
            <RowDefinition Height="120"/>    <!-- log -->
            <RowDefinition Height="Auto"/>   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⬡  Tool Call Probe"
                           Foreground="#76B900" FontFamily="Consolas"
                           FontSize="15" FontWeight="Bold"/>
                <Border Background="#1A2A0A" BorderBrush="#2A5A00" BorderThickness="1"
                        CornerRadius="3" Padding="6,1" Margin="10,2,0,0" VerticalAlignment="Center">
                    <TextBlock Text="GOBLIN MIND"
                               Foreground="#4EC94E" FontFamily="Consolas"
                               FontSize="9" FontWeight="Bold"/>
                </Border>
            </StackPanel>
            <TextBlock Text="Phase 1: Format Fingerprint · Phase 2: Category Map · Dispatch probe"
                       Foreground="#666666" FontFamily="Consolas" FontSize="10"
                       Margin="0,3,0,0"/>
        </StackPanel>

        <!-- ── Controls ────────────────────────────────────────────────────── -->
        <DockPanel Grid.Row="1" Margin="0,0,0,10">
            <!-- Run buttons -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="BtnRunAll" Content="▶  Test All Models"
                        Padding="12,5" Margin="0,0,8,0"
                        FontSize="11" FontWeight="SemiBold"
                        Background="#1F3D00" Foreground="#76B900"
                        BorderBrush="#2A5A00" BorderThickness="1"
                        Cursor="Hand" Click="BtnRunAll_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A5A00"/>
                                    <Setter Property="BorderBrush" Value="#76B900"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#1A1A1A"/>
                                    <Setter Property="BorderBrush" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnRunSelected" Content="▶  Test Selected"
                        Padding="12,5" Margin="0,0,8,0"
                        FontSize="11" FontWeight="SemiBold"
                        Background="#1A2A1A" Foreground="#76B900"
                        BorderBrush="#2A4A1A" BorderThickness="1"
                        Cursor="Hand" Click="BtnRunSelected_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#253525"/>
                                    <Setter Property="BorderBrush" Value="#76B900"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#1A1A1A"/>
                                    <Setter Property="BorderBrush" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnRunGoblinMind" Content="🧠  Full Profile"
                        Padding="12,5" Margin="0,0,8,0"
                        FontSize="11" FontWeight="SemiBold"
                        Background="#0A1A2A" Foreground="#4A9FD9"
                        BorderBrush="#1A3A5A" BorderThickness="1"
                        Cursor="Hand" Click="BtnRunGoblinMind_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#152535"/>
                                    <Setter Property="BorderBrush" Value="#4A9FD9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#1A1A1A"/>
                                    <Setter Property="BorderBrush" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnStop" Content="✗  Stop"
                        Padding="12,5"
                        FontSize="11" FontWeight="SemiBold"
                        Background="#2A0A0A" Foreground="#F44747"
                        BorderBrush="#4A1A1A" BorderThickness="1"
                        Cursor="Hand" IsEnabled="False" Click="BtnStop_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A1A1A"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#1A1A1A"/>
                                    <Setter Property="BorderBrush" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Status chip -->
            <Border Background="#141414" BorderBrush="#2A2A2A" BorderThickness="1"
                    CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                <TextBlock x:Name="TbStatus" Text="Ready"
                           Foreground="#666666" FontFamily="Consolas"
                           FontSize="11"/>
            </Border>
        </DockPanel>

        <!-- ── Results tabs: Probes | Evolution ─────────────────────────────── -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0"
                    Padding="0" SelectionChanged="Tabs_SelectionChanged"
                    x:Name="ResultTabs"
                    AutomationProperties.AutomationId="ToolProbe.Tabs">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="#888888"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize"   Value="11"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Background="#141414" BorderBrush="#2A2A2A"
                                        BorderThickness="1,1,1,0" CornerRadius="4,4,0,0"
                                        Padding="14,6" Margin="0,0,4,0">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#111111"/>
                                        <Setter Property="Foreground" Value="#76B900"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="⬡ PROBES"
                     AutomationProperties.AutomationId="ToolProbe.Tab.Probes">
        <Border Background="#111111" BorderBrush="#2A2A2A"
                BorderThickness="1" CornerRadius="0,4,4,4">
            <DataGrid x:Name="DgResults"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      Background="#111111"
                      Foreground="#CCCCCC"
                      RowBackground="#111111"
                      AlternatingRowBackground="#161616"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#1E1E1E"
                      BorderThickness="0"
                      FontFamily="Consolas" FontSize="11"
                      ColumnHeaderHeight="28"
                      RowHeight="26">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"   Value="#0A0A0A"/>
                        <Setter Property="Foreground"   Value="#76B900"/>
                        <Setter Property="FontSize"     Value="10"/>
                        <Setter Property="FontWeight"   Value="Bold"/>
                        <Setter Property="Padding"      Value="8,4"/>
                        <Setter Property="BorderBrush"  Value="#2A2A2A"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="8,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Model name -->
                    <DataGridTextColumn Header="MODEL" Binding="{Binding ShortName}"
                                        Width="200" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#D4D4D4"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Mode column: Native / Text -->
                    <DataGridTextColumn Header="MODE" Binding="{Binding ModeDisplay}"
                                        Width="80" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding ModeColor}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 5 test columns -->
                    <DataGridTextColumn Header="BASIC"    Binding="{Binding T1}" Width="60"  IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding T1Color}"/>
                                <Setter Property="FontSize"   Value="14"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="INTS"     Binding="{Binding T2}" Width="60"  IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding T2Color}"/>
                                <Setter Property="FontSize"   Value="14"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="CONTENT"  Binding="{Binding T3}" Width="70"  IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding T3Color}"/>
                                <Setter Property="FontSize"   Value="14"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="SELECT"   Binding="{Binding T4}" Width="65"  IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding T4Color}"/>
                                <Setter Property="FontSize"   Value="14"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="STRUCT"   Binding="{Binding T5}" Width="65"  IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding T5Color}"/>
                                <Setter Property="FontSize"   Value="14"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Score -->
                    <DataGridTextColumn Header="PASSES"  Binding="{Binding PassScore}" Width="65"  IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="Foreground" Value="{Binding ScoreColor}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Recommendation -->
                    <DataGridTextColumn Header="DISPATCH" Binding="{Binding RecMode}" Width="75" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding RecColor}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- GOBLIN MIND Phase 1: Preferred format -->
                    <DataGridTextColumn Header="FORMAT" Binding="{Binding FormatDisplay}" Width="80" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding FormatColor}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="10"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- GOBLIN MIND Phase 2: Category score -->
                    <DataGridTextColumn Header="CATS" Binding="{Binding CatsDisplay}" Width="*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding CatsColor}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
            </TabItem>

            <!-- ── GOBLIN MIND Phase 5: Evolutionary schema fitness ─────────── -->
            <TabItem Header="🧬 EVOLUTION"
                     AutomationProperties.AutomationId="ToolProbe.Tab.Evolution">
                <Border Background="#111111" BorderBrush="#2A2A2A"
                        BorderThickness="1" CornerRadius="0,4,4,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Evolution toolbar -->
                        <DockPanel Grid.Row="0" Margin="10,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button x:Name="BtnEvoRefresh" Content="↻ Refresh"
                                        AutomationProperties.AutomationId="ToolProbe.Evolution.Refresh"
                                        Padding="10,4" Margin="0,0,8,0" Cursor="Hand"
                                        Background="#1A2A1A" Foreground="#76B900"
                                        BorderBrush="#2A4A1A" BorderThickness="1"
                                        FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                        Click="BtnEvoRefresh_Click"/>
                                <Button x:Name="BtnPromote" Content="⬆ Promote Winners"
                                        AutomationProperties.AutomationId="ToolProbe.Evolution.Promote"
                                        Padding="10,4" Cursor="Hand"
                                        Background="#1F3D00" Foreground="#76B900"
                                        BorderBrush="#2A5A00" BorderThickness="1"
                                        FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                        ToolTip="Save every winning schema variant into SchemaLibrary so AgentLoop uses it automatically"
                                        Click="BtnPromote_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="TbEvoSummary"
                                       Text="Schema variants discovered by 'tool-probe evolve' — run it from the CLI to populate this map."
                                       Foreground="#666666" FontFamily="Consolas" FontSize="10"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </DockPanel>

                        <!-- Fitness records grid -->
                        <DataGrid x:Name="DgEvolution" Grid.Row="1"
                                  AutomationProperties.AutomationId="ToolProbe.Evolution.Grid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" IsReadOnly="True"
                                  Background="#111111" Foreground="#CCCCCC"
                                  RowBackground="#111111" AlternatingRowBackground="#161616"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#1E1E1E"
                                  BorderThickness="0"
                                  FontFamily="Consolas" FontSize="11"
                                  ColumnHeaderHeight="28" RowHeight="26">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"   Value="#0A0A0A"/>
                                    <Setter Property="Foreground"   Value="#76B900"/>
                                    <Setter Property="FontSize"     Value="10"/>
                                    <Setter Property="FontWeight"   Value="Bold"/>
                                    <Setter Property="Padding"      Value="8,4"/>
                                    <Setter Property="BorderBrush"  Value="#2A2A2A"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding"         Value="8,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="MODEL"     Binding="{Binding ModelId}"      Width="200"/>
                                <DataGridTextColumn Header="TOOL"      Binding="{Binding ToolName}"     Width="160"/>
                                <DataGridTextColumn Header="VARIANTS"  Binding="{Binding TestedDisplay}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="WIN RATE"  Binding="{Binding WinRateDisplay}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{Binding WinRateColor}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="BEST MUTATION" Binding="{Binding BestMutation}" Width="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4EC9B0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="UPDATED"   Binding="{Binding UpdatedDisplay}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ── Live log ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#0D0D0D" BorderBrush="#2A2A2A"
                BorderThickness="1" CornerRadius="4" Margin="0,8,0,0">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto" Padding="8,6">
                <TextBox x:Name="TbLog"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#888888" FontFamily="Consolas" FontSize="10"
                         IsReadOnly="True" TextWrapping="NoWrap"
                         VerticalAlignment="Top"/>
            </ScrollViewer>
        </Border>

        <!-- ── Progress + footer ────────────────────────────────────────────── -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar x:Name="PbProgress" Grid.Row="0"
                         Background="#222" Foreground="#76B900"
                         IsIndeterminate="False" Value="0"/>

            <DockPanel Grid.Row="1" Margin="0,8,0,0">
                <TextBlock x:Name="TbProfilePath"
                           DockPanel.Dock="Left"
                           Foreground="#444" FontFamily="Consolas" FontSize="9"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                           MaxWidth="500"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="BtnCopy" Content="Copy Log" Width="80"
                            Background="#2D2D2D" Foreground="#CCCCCC"
                            BorderBrush="#474747" FontFamily="Consolas" FontSize="10"
                            Padding="0,5" Margin="0,0,8,0" Click="BtnCopy_Click"/>
                    <Button x:Name="BtnClose" Content="Close" Width="70"
                            Background="#094771" Foreground="#FFFFFF"
                            BorderBrush="#094771" FontFamily="Consolas" FontSize="10"
                            Padding="0,5" Click="BtnClose_Click"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
