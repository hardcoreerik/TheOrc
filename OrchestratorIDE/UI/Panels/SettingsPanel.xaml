<UserControl x:Class="OrchestratorIDE.UI.Panels.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Br.Bg.Sidebar}">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,0,1"
                Padding="8,5">
            <TextBlock Text="SETTINGS" Foreground="{StaticResource Br.Text.Muted}"
                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <!-- Save button pinned to bottom -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0"
                Padding="8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnTestConn" Grid.Column="0" Content="⚡ Test Connection"
                        Margin="0,0,4,0" Click="BtnTestConn_Click"
                        Background="{StaticResource Br.Bg.Input}"
                        Foreground="{StaticResource Br.Text.Primary}"
                        FontSize="11" Padding="0,6"/>
                <Button x:Name="BtnSave" Grid.Column="1" Content="✓  Save"
                        Margin="4,0,0,0" Click="BtnSave_Click"
                        Background="{StaticResource Br.Bg.Active}"
                        Foreground="{StaticResource Br.Text.White}"
                        FontSize="11" Padding="0,6"/>
            </Grid>
        </Border>

        <!-- Status message -->
        <Border DockPanel.Dock="Bottom" Padding="8,4">
            <TextBlock x:Name="TbStatus" Text="" FontSize="11"
                       TextWrapping="Wrap" Foreground="{StaticResource Br.Accent.Green}"/>
        </Border>

        <!-- Scrollable settings body -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,4,0,12">

                <!-- ── OLLAMA ─────────────────────────────────────────── -->
                <TextBlock Text="OLLAMA" Style="{StaticResource SectionHeader}"/>

                <StackPanel Style="{StaticResource SettingRow}">
                    <TextBlock Text="Host URL" Style="{StaticResource SettingLabel}"/>
                    <TextBlock Text="Where your Ollama instance is running"
                               Style="{StaticResource SettingHint}"/>
                    <TextBox x:Name="TbOllamaHost"
                             Style="{StaticResource SettingInput}"
                             Text="http://localhost:11434"/>
                </StackPanel>

                <!-- ── AGENT ─────────────────────────────────────────── -->
                <TextBlock Text="AGENT" Style="{StaticResource SectionHeader}" Margin="0,12,0,0"/>

                <StackPanel Style="{StaticResource SettingRow}">
                    <TextBlock Text="Default Model" Style="{StaticResource SettingLabel}"/>
                    <TextBlock Text="Auto-selected on startup if installed"
                               Style="{StaticResource SettingHint}"/>
                    <TextBox x:Name="TbDefaultModel"
                             Style="{StaticResource SettingInput}"
                             Text="qwen2.5-coder:14b"/>
                </StackPanel>

                <StackPanel Style="{StaticResource SettingRow}">
                    <TextBlock Text="Max Steps Override" Style="{StaticResource SettingLabel}"/>
                    <TextBlock Text="0 = use model profile default"
                               Style="{StaticResource SettingHint}"/>
                    <TextBox x:Name="TbMaxSteps"
                             Style="{StaticResource SettingInput}"
                             Text="0"/>
                </StackPanel>

                <Border Style="{StaticResource SettingRowBorder}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Auto-verify after write"
                                       Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Run tests automatically after every file write"
                                       Style="{StaticResource SettingHint}"/>
                        </StackPanel>
                        <ToggleButton x:Name="TglAutoVerify"
                                      DockPanel.Dock="Right"
                                      Style="{StaticResource ToggleStyle}"
                                      IsChecked="True"/>
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource SettingRowBorder}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Git checkpoint before Execute"
                                       Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Auto-commits workspace before every agent run"
                                       Style="{StaticResource SettingHint}"/>
                        </StackPanel>
                        <ToggleButton x:Name="TglAutoCheckpoint"
                                      DockPanel.Dock="Right"
                                      Style="{StaticResource ToggleStyle}"
                                      IsChecked="True"/>
                    </DockPanel>
                </Border>

                <!-- ── UPDATES ──────────────────────────────────────── -->
                <TextBlock Text="UPDATES" Style="{StaticResource SectionHeader}" Margin="0,12,0,0"/>

                <Border Style="{StaticResource SettingRowBorder}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Check for updates on startup"
                                       Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Silent check against GitHub Releases once per day"
                                       Style="{StaticResource SettingHint}"/>
                        </StackPanel>
                        <ToggleButton x:Name="TglCheckUpdates"
                                      DockPanel.Dock="Right"
                                      Style="{StaticResource ToggleStyle}"
                                      IsChecked="True"/>
                    </DockPanel>
                </Border>

                <StackPanel Style="{StaticResource SettingRow}" Orientation="Horizontal">
                    <Button x:Name="BtnCheckNow" Content="⬆ Check Now"
                            Click="BtnCheckNow_Click"
                            Background="{StaticResource Br.Bg.Input}"
                            Foreground="{StaticResource Br.Text.Primary}"
                            FontSize="11" Padding="8,6" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TbVersionInfo" Text=""
                               Style="{StaticResource SettingHint}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ── AGENT FILE ────────────────────────────────────── -->
                <TextBlock Text="AGENT FILE" Style="{StaticResource SectionHeader}" Margin="0,12,0,0"/>

                <StackPanel Style="{StaticResource SettingRow}">
                    <TextBlock Text="Personalise your .agent.md" Style="{StaticResource SettingLabel}"/>
                    <TextBlock Style="{StaticResource SettingHint}"
                               TextWrapping="Wrap"
                               Text="Regenerates the agent knowledge file in your workspace with your hardware, model, and any personal context you want the agent to always know."/>
                    <Button x:Name="BtnRegenerateAgentFile"
                            Content="🗡  Regenerate Agent File"
                            Click="BtnRegenerateAgentFile_Click"
                            Background="{StaticResource Br.Bg.Input}"
                            Foreground="{StaticResource Br.Text.Primary}"
                            FontSize="11" Padding="8,6"
                            HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- ── WORKSPACE ─────────────────────────────────────── -->
                <TextBlock Text="WORKSPACE" Style="{StaticResource SectionHeader}" Margin="0,12,0,0"/>

                <StackPanel Style="{StaticResource SettingRow}">
                    <TextBlock Text="Default Folder" Style="{StaticResource SettingLabel}"/>
                    <TextBlock Text="Loaded on startup (leave blank to start empty)"
                               Style="{StaticResource SettingHint}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TbDefaultWorkspace"
                                 Grid.Column="0"
                                 Style="{StaticResource SettingInput}"/>
                        <Button Grid.Column="1" Content="…" Margin="4,0,0,0"
                                Background="{StaticResource Br.Bg.Input}"
                                Foreground="{StaticResource Br.Text.Primary}"
                                FontSize="12" Click="BtnBrowseWorkspace_Click"/>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
