<UserControl x:Class="OrchestratorIDE.UI.Panels.AgentPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Br.Bg.App}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>   <!-- Tab bar -->
            <RowDefinition Height="*"/>    <!-- Message list -->
            <RowDefinition Height="Auto"/> <!-- Diff viewer (hidden until needed) -->
            <RowDefinition Height="4"/>    <!-- Splitter -->
            <RowDefinition Height="160" MinHeight="80"/> <!-- Input area -->
        </Grid.RowDefinitions>

        <!-- Tab bar -->
        <Border Grid.Row="0" Background="#141814"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <!-- Active tab — top green indicator line + label -->
                <Border Background="{StaticResource Br.Bg.Active}"
                        BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,1,0">
                    <StackPanel>
                        <!-- NVIDIA-green top bar = active tab indicator -->
                        <Border Height="2" Background="{StaticResource Br.Accent.Green}"/>
                        <TextBlock Text="⚡  Code Agent" Margin="14,0,14,0"
                                   VerticalAlignment="Center" Height="26"
                                   FontSize="12" Foreground="{StaticResource Br.Text.White}"
                                   Padding="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Mode indicator -->
                <TextBlock x:Name="TbMode" Text="● PLAN"
                           Foreground="{StaticResource Br.Accent.Green}"
                           FontSize="10" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
        </Border>

        <!-- Message list (scrollable conversation) -->
        <ScrollViewer x:Name="MsgScroll" Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="MsgList" Padding="0,4"
                          AutomationProperties.AutomationId="AgentPanel.MessageList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,1" Padding="12,8"
                                Background="{Binding BubbleBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Role icon — Segoe MDL2 Assets glyph -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding RoleIcon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" VerticalAlignment="Top"
                                           HorizontalAlignment="Center" Margin="0,2,0,0"
                                           Foreground="{Binding RoleColor}"/>
                                <!-- Content -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding RoleLabel}"
                                               Foreground="{Binding RoleColor}"
                                               FontSize="10" FontWeight="Bold"
                                               Margin="0,0,0,3"/>
                                    <!-- Selectable text (Option A: per-message selection via read-only TextBox) -->
                                    <TextBox Text="{Binding Content, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             IsTabStop="False"
                                             Foreground="#E0E0E0"
                                             FontFamily="Consolas, 'Cascadia Code', monospace"
                                             FontSize="12"
                                             TextWrapping="Wrap"
                                             SelectionBrush="#3A5A8A"
                                             CaretBrush="Transparent">
                                        <TextBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Copy selection"   Command="ApplicationCommands.Copy"/>
                                                <MenuItem Header="Select all"       Command="ApplicationCommands.SelectAll"/>
                                                <Separator/>
                                                <MenuItem Header="Copy message"     Click="MsgCopyMessage_Click"/>
                                                <MenuItem Header="Copy all messages" Click="MsgCopyAll_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Save chat to…"    Click="MsgSaveChat_Click"/>
                                            </ContextMenu>
                                        </TextBox.ContextMenu>
                                    </TextBox>
                                    <!-- Token count badge (assistant only, shown after response completes) -->
                                    <TextBlock Text="{Binding TokenLabel}"
                                               Visibility="{Binding HasTokenLabel}"
                                               Foreground="{StaticResource Br.Text.Muted}"
                                               FontSize="9" Margin="0,4,0,0"/>
                                    <!-- Tool call badge (if applicable) -->
                                    <ItemsControl ItemsSource="{Binding ToolBadges}"
                                                  Margin="0,4,0,0"
                                                  Visibility="{Binding HasTools}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A241A" CornerRadius="3"
                                                        Padding="6,2" Margin="0,0,4,0">
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{StaticResource Br.Accent.Blue}"
                                                               FontSize="10"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Diff viewer panel (collapsed until write_file approval) -->
        <Border x:Name="DiffPanel" Grid.Row="2"
                Visibility="Collapsed"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0"
                MaxHeight="340">
            <!-- DiffViewer inserted here at runtime -->
        </Border>

        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch"
                      Background="{StaticResource Br.Border}" Cursor="SizeNS"/>

        <!-- Input area -->
        <Border Grid.Row="4" Background="{StaticResource Br.Bg.Panel}"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0">
            <DockPanel Margin="8,6">

                <!-- Bottom toolbar — two rows to avoid overflow -->
                <Grid DockPanel.Dock="Bottom" Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24"/>  <!-- Context row: workspace / rules / agent badges -->
                        <RowDefinition Height="6"/>   <!-- gap -->
                        <RowDefinition Height="26"/>  <!-- Action row: mode toggle + token + send -->
                    </Grid.RowDefinitions>

                    <!-- ── Context row ─────────────────────────────────────────── -->
                    <DockPanel Grid.Row="0">

                        <!-- Workspace badge — click to open folder picker -->
                        <Border x:Name="WsBadge" CornerRadius="3" Padding="6,2"
                                Margin="0,0,6,0" DockPanel.Dock="Left"
                                Background="#3A3010" Cursor="Hand"
                                ToolTip="Click to open a project folder"
                                MouseLeftButtonUp="WsBadge_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📁" FontSize="10" Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="WsLabel" Text="no folder open"
                                           Foreground="#CCA700" FontSize="10"
                                           VerticalAlignment="Center" MaxWidth="140"
                                           TextTrimming="CharacterEllipsis"
                                           AutomationProperties.AutomationId="AgentPanel.WorkspaceBadge"/>
                            </StackPanel>
                        </Border>

                        <!-- Rules badge — shown when .agent.md is active -->
                        <Border x:Name="RulesBadge" CornerRadius="3" Padding="6,2"
                                Margin="0,0,6,0" DockPanel.Dock="Left"
                                Background="#102A20" Visibility="Collapsed"
                                AutomationProperties.AutomationId="AgentPanel.RulesBadge"
                                Cursor="Hand" MouseLeftButtonUp="RulesBadge_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📋" FontSize="10" Margin="0,0,3,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="RulesLabel" Text=".agent.md"
                                           Foreground="#4EC9B0" FontSize="10"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Global Agent badge -->
                        <Border x:Name="GlobalAgentBadge" CornerRadius="3" Padding="6,2"
                                Margin="0,0,6,0" DockPanel.Dock="Left"
                                Background="#1A2A1A" Cursor="Hand"
                                ToolTip="Global Agent — applies to all workspaces. Click to change."
                                AutomationProperties.AutomationId="AgentPanel.GlobalAgentBadge"
                                MouseLeftButtonUp="GlobalAgentBadge_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⚙" FontSize="10" Margin="0,0,3,0"
                                           Foreground="#6A9955" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GlobalAgentLabel" Text="No global agent"
                                           Foreground="#6A9955" FontSize="10"
                                           VerticalAlignment="Center" MaxWidth="100"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <!-- Workspace Rules button -->
                        <Border x:Name="WorkspaceRulesBtn" CornerRadius="3" Padding="6,2"
                                Margin="0,0,6,0" DockPanel.Dock="Left"
                                Background="#1A1A2A" Cursor="Hand"
                                ToolTip="Project/Workspace Rules — fine-tune agent rules for this workspace"
                                AutomationProperties.AutomationId="AgentPanel.WorkspaceRules"
                                MouseLeftButtonUp="WorkspaceRulesBtn_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📝" FontSize="10" Margin="0,0,3,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Foreground="#7A7ACC" FontSize="10"
                                           VerticalAlignment="Center">Workspace Rules</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border/><!-- flex spacer -->
                    </DockPanel>

                    <!-- ── Action row ───────────────────────────────────────────── -->
                    <DockPanel Grid.Row="2">

                        <!-- Mode toggle -->
                        <Border Background="{StaticResource Br.Bg.Input}" CornerRadius="3"
                                Padding="2" Margin="0,0,8,0" DockPanel.Dock="Left">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RbPlan" Content=" Plan "
                                             GroupName="Mode" IsChecked="True"
                                             Foreground="{StaticResource Br.Text.Primary}"
                                             FontSize="11" VerticalAlignment="Center"
                                             AutomationProperties.AutomationId="AgentPanel.ModePlan"
                                             Checked="ModeChanged"/>
                                <RadioButton x:Name="RbExec" Content=" Execute "
                                             GroupName="Mode" Margin="4,0,0,0"
                                             Foreground="{StaticResource Br.Text.Primary}"
                                             FontSize="11" VerticalAlignment="Center"
                                             AutomationProperties.AutomationId="AgentPanel.ModeExecute"
                                             Checked="ModeChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Token counter + mini progress bar -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Vertical"
                                    VerticalAlignment="Center" Margin="0,0,8,0" Width="90">
                            <TextBlock x:Name="TbTokens" Text="0 tokens"
                                       Foreground="{StaticResource Br.Text.Muted}"
                                       FontSize="9" HorizontalAlignment="Center"/>
                            <Border Height="3" CornerRadius="2"
                                    Background="{StaticResource Br.Bg.App}" Margin="0,2,0,0">
                                <Border x:Name="CtxBar" Height="3" CornerRadius="2"
                                        HorizontalAlignment="Left" Width="0"
                                        Background="{StaticResource Br.Accent.Blue}"/>
                            </Border>
                        </StackPanel>

                        <!-- Stop + Send buttons -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="BtnStop" Content="■ Stop" Width="70"
                                    Background="#3A1A1A" Foreground="{StaticResource Br.Error}"
                                    BorderBrush="#5A2A2A" FontSize="11"
                                    AutomationProperties.AutomationId="AgentPanel.Stop"
                                    Click="BtnStop_Click" IsEnabled="False"/>
                            <Button x:Name="BtnSend" Content="Send  ↵" Width="84"
                                    Background="#2A5200"
                                    Foreground="{StaticResource Br.Accent.Green}"
                                    BorderBrush="#3A7000"
                                    FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0"
                                    AutomationProperties.AutomationId="AgentPanel.Send"
                                    Click="BtnSend_Click"/>
                        </StackPanel>

                        <Border/><!-- flex spacer -->
                    </DockPanel>

                </Grid>

                <!-- Text input with placeholder -->
                <Grid>
                    <TextBox x:Name="TbInput"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="{StaticResource Br.Bg.Input}"
                             BorderBrush="{StaticResource Br.Border}"
                             BorderThickness="1" Padding="8,6"
                             FontFamily="Consolas, 'Cascadia Code', monospace"
                             FontSize="12"
                             AutomationProperties.AutomationId="AgentPanel.Input"
                             KeyDown="TbInput_KeyDown"
                             TextChanged="TbInput_TextChanged"/>
                    <TextBlock x:Name="TbPlaceholder"
                               Text="Ask the agent anything… (Enter to send, Shift+Enter for newline)"
                               Foreground="#555" FontSize="11"
                               IsHitTestVisible="False"
                               VerticalAlignment="Top" Margin="9,8,0,0"/>
                </Grid>
            </DockPanel>
        </Border>

    </Grid>
</UserControl>
