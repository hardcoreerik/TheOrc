<UserControl x:Class="OrchestratorIDE.UI.Panels.TrainingPitPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0E0E0E"
             AutomationProperties.AutomationId="TrainingPit.Panel">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="PitButton" TargetType="Button">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: header -->
            <RowDefinition Height="Auto"/>  <!-- 1: inventory row -->
            <RowDefinition Height="Auto"/>  <!-- 2: night harvest -->
            <RowDefinition Height="Auto"/>  <!-- 3: review captures -->
            <RowDefinition Height="Auto"/>  <!-- 4: WARCHIEF FORGE -->
            <RowDefinition Height="Auto"/>  <!-- 5: queue header -->
            <RowDefinition Height="*"/>     <!-- 6: queue list -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="⛏ Training Pit" FontSize="16" FontWeight="SemiBold"
                       Foreground="#D4D4D4" VerticalAlignment="Center"/>
            <Border x:Name="PhaseBadge" Background="#1A2A00" CornerRadius="3"
                    Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="PhaseText" Text="Collecting examples — training not started"
                           FontSize="11" Foreground="#CCA700"/>
            </Border>
            <Button x:Name="BtnRefresh" Style="{StaticResource PitButton}"
                    Background="#111111" BorderBrush="#2A2A2A" Foreground="#999999"
                    Content="⟳ Refresh" HorizontalAlignment="Right" DockPanel.Dock="Right"
                    Click="BtnRefresh_Click"
                    AutomationProperties.AutomationId="TrainingPit.Refresh"/>
            <!-- Live VRAM meter (nvidia-smi, refreshed with the live timer) -->
            <StackPanel x:Name="PnlVram" Orientation="Horizontal" DockPanel.Dock="Right"
                        Margin="0,0,12,0" VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock x:Name="TbVram" Text="" FontSize="11" FontFamily="Consolas"
                           Foreground="#999999" VerticalAlignment="Center" Margin="0,0,6,0"
                           AutomationProperties.AutomationId="TrainingPit.Vram"/>
                <ProgressBar x:Name="VramBar" Width="70" Height="7" BorderThickness="0"
                             Background="#111111" Foreground="#76B900" Maximum="100"
                             VerticalAlignment="Center"
                             AutomationProperties.AutomationId="TrainingPit.VramBar"/>
            </StackPanel>
        </DockPanel>

        <!-- ── Inventory row: Datasets | Adapters | Models ───────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,12" Height="180">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Datasets -->
            <Border Grid.Column="0" Background="#141814" CornerRadius="6" Padding="10,8" Margin="0,0,6,0"
                    BorderBrush="#2A2A2A" BorderThickness="1"
                    ToolTip="Datasets on disk in training_pit/datasets/. The textbook(s) the model learns from.">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="📚" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="DATASETS" FontSize="11" FontWeight="Bold" Foreground="#A8CC80"
                                   Margin="6,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DatasetCount" Text="0" FontSize="11" Foreground="#666666"
                                   VerticalAlignment="Center"
                                   AutomationProperties.AutomationId="TrainingPit.DatasetCount"/>
                    </DockPanel>
                    <TextBlock x:Name="DatasetEmpty" DockPanel.Dock="Bottom" Text="no datasets yet"
                               FontSize="10" Foreground="#666666" FontStyle="Italic" Margin="2,4,0,0"
                               Visibility="Collapsed"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="DatasetList"
                                      AutomationProperties.AutomationId="TrainingPit.DatasetList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0E120E" BorderBrush="#2A2A2A" BorderThickness="1"
                                            CornerRadius="3" Padding="8,5" Margin="0,0,0,4">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#D4D4D4"/>
                                                <TextBlock Text="{Binding TrainCount, StringFormat={}{0:N0}}"
                                                           FontSize="12" Foreground="#A8CC80" FontFamily="Consolas"
                                                           HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Border Background="#1F3D00" CornerRadius="2" Padding="4,1" Margin="0,0,4,0">
                                                    <TextBlock FontSize="9" Foreground="#A8CC80">
                                                        <Run Text="train "/><Run Text="{Binding TrainCount}"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#1A2A00" CornerRadius="2" Padding="4,1" Margin="0,0,4,0">
                                                    <TextBlock FontSize="9" Foreground="#CCA700">
                                                        <Run Text="eval "/><Run Text="{Binding EvalCount}"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#2A0A0A" CornerRadius="2" Padding="4,1">
                                                    <TextBlock FontSize="9" Foreground="#F09090">
                                                        <Run Text="neg "/><Run Text="{Binding NegCount}"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Adapters -->
            <Border Grid.Column="1" Background="#141014" CornerRadius="6" Padding="10,8" Margin="3,0,3,0"
                    BorderBrush="#2A2A2A" BorderThickness="1"
                    ToolTip="Trained LoRA adapters in training_pit/outputs/. Each can be applied to a base model via Ollama.">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="🧬" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="ADAPTERS" FontSize="11" FontWeight="Bold" Foreground="#E8A030"
                                   Margin="6,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="AdapterCount" Text="0" FontSize="11" Foreground="#666666"
                                   VerticalAlignment="Center"
                                   AutomationProperties.AutomationId="TrainingPit.AdapterCount"/>
                    </DockPanel>
                    <TextBlock x:Name="AdapterEmpty" DockPanel.Dock="Bottom"
                               Text="no adapters yet — train one below"
                               FontSize="10" Foreground="#666666" FontStyle="Italic" Margin="2,4,0,0"
                               Visibility="Collapsed"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="AdapterList"
                                      AutomationProperties.AutomationId="TrainingPit.AdapterList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#120E0A" BorderBrush="#2A2A2A" BorderThickness="1"
                                            CornerRadius="3" Padding="8,5" Margin="0,0,0,4">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#E8C080"/>
                                                <Border Background="{Binding TierBg}" CornerRadius="2"
                                                        Padding="5,1" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                                    <TextBlock Text="{Binding Tier}" FontSize="9"
                                                               Foreground="{Binding TierFg}"/>
                                                </Border>
                                            </DockPanel>
                                            <TextBlock Text="{Binding BaseModelShort}" FontSize="10" Foreground="#999999"
                                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding MetricsLine}" FontSize="9" Foreground="#A8CC80"
                                                       FontFamily="Consolas" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Models -->
            <Border Grid.Column="2" Background="#101414" CornerRadius="6" Padding="10,8" Margin="6,0,0,0"
                    BorderBrush="#2A2A2A" BorderThickness="1"
                    ToolTip="Ollama models on this host. Targets for training or fine-tune output.">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="🧠" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="MODELS" FontSize="11" FontWeight="Bold" Foreground="#80C0E0"
                                   Margin="6,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ModelCount" Text="0" FontSize="11" Foreground="#666666"
                                   VerticalAlignment="Center"
                                   AutomationProperties.AutomationId="TrainingPit.ModelCount"/>
                    </DockPanel>
                    <TextBlock x:Name="ModelEmpty" DockPanel.Dock="Bottom"
                               Text="Ollama not reachable"
                               FontSize="10" Foreground="#666666" FontStyle="Italic" Margin="2,4,0,0"
                               Visibility="Collapsed"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ModelList"
                                      AutomationProperties.AutomationId="TrainingPit.ModelList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0E1214" BorderBrush="#2A2A2A" BorderThickness="1"
                                            CornerRadius="3" Padding="8,4" Margin="0,0,0,3">
                                        <DockPanel>
                                            <TextBlock Text="{Binding NameShort}" FontSize="11" Foreground="#D4D4D4"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SizeText}" FontSize="10" Foreground="#80A0B0"
                                                       FontFamily="Consolas" HorizontalAlignment="Right"
                                                       DockPanel.Dock="Right"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ── Night harvest section ──────────────────────────────────── -->
        <Border Grid.Row="2" Background="#101410" BorderBrush="#2A2A2A" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <StackPanel>
                <!-- Header row: dot + title + status + buttons -->
                <DockPanel>
                    <Ellipse x:Name="LiveDot" Width="9" Height="9" Fill="#76B900"
                             VerticalAlignment="Center" Visibility="Collapsed" Margin="0,0,8,0"
                             AutomationProperties.AutomationId="TrainingPit.LiveDot"/>
                    <TextBlock Text="🌙" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Night harvest" FontSize="12" FontWeight="SemiBold"
                               Foreground="#D4D4D4" Margin="8,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="HarvestStatus" Text="not running" FontSize="11"
                               Foreground="#999999" VerticalAlignment="Center"
                               AutomationProperties.AutomationId="TrainingPit.HarvestStatus"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <Button x:Name="BtnStartHarvest" Style="{StaticResource PitButton}"
                                Background="#1F3D00" BorderBrush="#76B900" Foreground="#A8CC80"
                                Content="▶ Start harvest" Click="BtnStartHarvest_Click"
                                AutomationProperties.AutomationId="TrainingPit.HarvestStart"/>
                        <Button x:Name="BtnStopHarvest" Style="{StaticResource PitButton}"
                                Background="#1A2A00" BorderBrush="#CCA700" Foreground="#CCA700"
                                Content="⏸ Finish current plan, then stop" Margin="8,0,0,0"
                                Click="BtnStopHarvest_Click" IsEnabled="False"
                                AutomationProperties.AutomationId="TrainingPit.HarvestStop"/>
                    </StackPanel>
                </DockPanel>

                <!-- Picker row: generator + judge + goals/cycle + run-until -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Generator" FontSize="11" Foreground="#999999"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip="Model that authors new goal prompts. Must not be a boss/gemma family — the boss can't feed itself its own distribution."/>
                    <ComboBox Grid.Column="1" x:Name="CbGenModel" FontSize="11" Margin="0,0,14,0"
                              SelectionChanged="CbGenModel_SelectionChanged"
                              AutomationProperties.AutomationId="TrainingPit.HarvestGenModel">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" Foreground="{Binding TextBrush}" FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Column="2" Text="Judge" FontSize="11" Foreground="#999999"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip="Model that triages farmed captures for fabrication risk."/>
                    <ComboBox Grid.Column="3" x:Name="CbJudgeModel" FontSize="11" Margin="0,0,14,0"
                              AutomationProperties.AutomationId="TrainingPit.HarvestJudgeModel">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" Foreground="{Binding TextBrush}" FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Column="4" Text="Goals/cycle" FontSize="11" Foreground="#999999"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip="How many goals each cycle authors before farming. 25 is a balanced default."/>
                    <TextBox Grid.Column="5" x:Name="TbGoalsPerCycle" Text="25" FontSize="11"
                             Background="#0E0E0E" Foreground="#D4D4D4" BorderBrush="#555555"
                             Padding="4,3" Margin="0,0,14,0"
                             AutomationProperties.AutomationId="TrainingPit.HarvestGoalsPerCycle"/>

                    <TextBlock Grid.Column="6" Text="Run until" FontSize="11" Foreground="#999999"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip="When the harvest stops on its own. 'Stop manually' = runs until you click Stop or the stop file is created."/>
                    <ComboBox Grid.Column="7" x:Name="CbHarvestDuration" FontSize="11"
                              AutomationProperties.AutomationId="TrainingPit.HarvestDuration"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Review captures — the reviewer dataset, growing passively ── -->
        <Border Grid.Row="3" Background="#101014" BorderBrush="#2A2A2A" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                ToolTip="Each capture is a paired (Codex verdict, TheOrc verdict) example. Builds the dataset for the future theorc-reviewer:v1 adapter on qwen2.5-coder:14b.">
            <StackPanel>
                <!-- Header row: title + counts + action buttons -->
                <DockPanel>
                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Review captures" FontSize="12" FontWeight="SemiBold"
                               Foreground="#D4D4D4" Margin="8,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ReviewStatus" Text="0 staged · last: never"
                               FontSize="11" Foreground="#999999" VerticalAlignment="Center"
                               AutomationProperties.AutomationId="TrainingPit.ReviewStatus"/>
                    <!-- Capture increment: calls auto-capture.ps1 (marker-based range) -->
                    <Button x:Name="BtnCaptureIncrement" Style="{StaticResource PitButton}"
                            Background="#1A2D1A" BorderBrush="#60A060" Foreground="#80C080"
                            Content="⬇ Capture increment" HorizontalAlignment="Right"
                            DockPanel.Dock="Right" Click="BtnCaptureIncrement_Click"
                            Margin="0,0,6,0"
                            AutomationProperties.AutomationId="TrainingPit.CaptureIncrement"
                            ToolTip="Run Codex + TheOrc on commits since the last capture and save the pair as a training example. Advances the capture marker."/>
                    <!-- Review branch: full branch vs upstream, no marker update -->
                    <Button x:Name="BtnReviewNow" Style="{StaticResource PitButton}"
                            Background="#1A1F3D" BorderBrush="#80A0E0" Foreground="#A0C0F0"
                            Content="▶ Review branch" HorizontalAlignment="Right"
                            DockPanel.Dock="Right" Click="BtnReviewNow_Click"
                            AutomationProperties.AutomationId="TrainingPit.ReviewNow"
                            ToolTip="Run Codex + TheOrc on the full branch diff vs upstream. Does not advance the capture marker."/>
                </DockPanel>

                <!-- Uncaptured-commits indicator -->
                <TextBlock x:Name="CaptureMarkerStatus"
                           Text="" FontSize="10" Foreground="#60A060" FontFamily="Consolas"
                           Margin="0,4,0,0"
                           AutomationProperties.AutomationId="TrainingPit.CaptureMarkerStatus"/>

                <!-- Progress bar + threshold callout -->
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" x:Name="ReviewProgressBar" Height="6"
                                 BorderThickness="0" Background="#111111" Foreground="#80A0E0"
                                 Maximum="50" Value="0" VerticalAlignment="Center"
                                 AutomationProperties.AutomationId="TrainingPit.ReviewProgress"/>
                    <TextBlock Grid.Column="1" x:Name="ReviewThreshold"
                               Text="0 of 50 toward an experimental adapter"
                               FontSize="10" Foreground="#80A0B0" FontFamily="Consolas"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <!-- Latest capture line -->
                <TextBlock x:Name="ReviewLatest" Text="" FontSize="10" Foreground="#666666"
                           FontStyle="Italic" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"
                           AutomationProperties.AutomationId="TrainingPit.ReviewLatest"/>
            </StackPanel>
        </Border>

        <!-- ── WARCHIEF FORGE — Phase 3 training ──────────────────────── -->
        <Expander Grid.Row="4" x:Name="ExpForge" Margin="0,0,0,12"
                  AutomationProperties.AutomationId="TrainingPit.Forge"
                  Expanded="ExpForge_Expanded">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🏛" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="ORC ACADEMY" FontSize="12" FontWeight="Bold"
                               Foreground="#E8A030" Margin="8,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Phase 3 — train the boss adapter from the reviewed dataset"
                               FontSize="11" Foreground="#999999" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ForgeBadge" Text="" FontSize="11" FontWeight="SemiBold"
                               Foreground="#76B900" Margin="10,0,0,0" VerticalAlignment="Center"
                               AutomationProperties.AutomationId="TrainingPit.ForgeBadge"/>
                </StackPanel>
            </Expander.Header>
            <Border Background="#14100A" BorderBrush="#3A2A10" BorderThickness="1"
                    CornerRadius="6" Padding="12,10" Margin="0,6,0,0">
                <StackPanel>
                    <!-- Dataset provenance card -->
                    <Border Background="#0E0C08" BorderBrush="#2A2A2A" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="ForgeDataset" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#E8C080"
                                       Text="Dataset: loading…"
                                       AutomationProperties.AutomationId="TrainingPit.ForgeDataset"/>
                            <TextBlock FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="What it is: goal → plan examples teaching the boss (theorc-boss:gemma4) to decompose one-sentence coding goals into 2–4 task swarm plans with correct roles and concrete files.&#x0a;How it was made: live swarm captures → auto-scoring rubric → deterministic pre-screen → local judge triage → human review (every approval and rejection logged in reviewed_v1.json).&#x0a;Intended use: QLoRA adapter (r16/α32, 4-bit NF4 base) for the orchestration role only — workers are unaffected. Output: training_pit/outputs/lora_v1/."/>
                        </StackPanel>
                    </Border>

                    <!-- ── Base model + dataset + output name pickers ──────────────────── -->
                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- Row 0: Base model picker + HF repo override -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Base model" FontSize="11"
                                   Foreground="#999999" VerticalAlignment="Center" Margin="0,0,6,0"
                                   ToolTip="Ollama model to fine-tune. Picking one auto-fills its HF repo to the right."/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CbBaseModel" FontSize="11"
                                  Margin="0,0,14,0" SelectionChanged="CbBaseModel_SelectionChanged"
                                  AutomationProperties.AutomationId="TrainingPit.ForgeBaseModel">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}" Foreground="{Binding TextBrush}" FontSize="11"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="HF repo" FontSize="11"
                                   Foreground="#999999" VerticalAlignment="Center" Margin="0,0,6,0"
                                   ToolTip="HuggingFace repo passed to train_lora.py --base. Edit to override the auto-fill."/>
                        <TextBox Grid.Row="0" Grid.Column="3" x:Name="TbHfRepo" Text="google/gemma-4-12b-it"
                                 FontSize="11" Background="#0E0E0E" Foreground="#D4D4D4"
                                 BorderBrush="#555555" Padding="4,3" FontFamily="Consolas"
                                 AutomationProperties.AutomationId="TrainingPit.ForgeHfRepo"/>

                        <!-- Row 2: Dataset picker + Output name -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Dataset" FontSize="11"
                                   Foreground="#999999" VerticalAlignment="Center" Margin="0,0,6,0"
                                   ToolTip="Which reviewed dataset to train on. Each version has its own train/eval/negative splits."/>
                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CbDataset" FontSize="11"
                                  Margin="0,0,14,0" SelectionChanged="CbDataset_SelectionChanged"
                                  AutomationProperties.AutomationId="TrainingPit.ForgeDatasetPicker">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="#D4D4D4" FontSize="11"/>
                                        <TextBlock Text="{Binding CountsText}" Foreground="#A8CC80"
                                                   FontSize="10" FontFamily="Consolas" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Output" FontSize="11"
                                   Foreground="#999999" VerticalAlignment="Center" Margin="0,0,6,0"
                                   ToolTip="Folder name under training_pit/outputs/ where the adapter is written."/>
                        <TextBox Grid.Row="2" Grid.Column="3" x:Name="TbOutputName" Text="lora_v1"
                                 FontSize="11" Background="#0E0E0E" Foreground="#D4D4D4"
                                 BorderBrush="#555555" Padding="4,3" FontFamily="Consolas"
                                 AutomationProperties.AutomationId="TrainingPit.ForgeOutputName"/>
                    </Grid>

                    <!-- Controls row -->
                    <DockPanel Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock Text="VRAM cap" FontSize="11" Foreground="#999999" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CbVramCap" Width="110" Margin="6,0,14,0" FontSize="11"
                                      AutomationProperties.AutomationId="TrainingPit.ForgeVramCap">
                                <!-- Fully self-templated: the default/Fluent theme renders the
                                     closed box dark with washed-out text and ignores Foreground.
                                     This template guarantees black-on-light in every state. -->
                                <ComboBox.Template>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <ToggleButton ClickMode="Press" Focusable="False"
                                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="#0E0E0E" BorderBrush="#555555"
                                                                BorderThickness="1" CornerRadius="3">
                                                            <Path Data="M0,0 L4,4 8,0" Stroke="#D4D4D4" StrokeThickness="1.5"
                                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                  Margin="0,0,8,0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                              Margin="8,3,22,3" VerticalAlignment="Center"
                                                              TextElement.Foreground="White"
                                                              TextElement.FontWeight="SemiBold"
                                                              IsHitTestVisible="False"/>
                                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                                   AllowsTransparency="True" StaysOpen="False">
                                                <Border Background="#0E0E0E" BorderBrush="#555555" BorderThickness="1"
                                                        CornerRadius="3" MinWidth="{TemplateBinding ActualWidth}">
                                                    <ItemsPresenter/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </ComboBox.Template>
                                <ComboBoxItem Content="No cap" IsSelected="True" Tag="0" Foreground="White" FontWeight="SemiBold"/>
                                <ComboBoxItem Content="12 GB" Tag="12" Foreground="White" FontWeight="SemiBold"/>
                                <ComboBoxItem Content="10 GB" Tag="10" Foreground="White" FontWeight="SemiBold"/>
                                <ComboBoxItem Content="8 GB"  Tag="8"  Foreground="White" FontWeight="SemiBold"/>
                                <ComboBoxItem Content="6 GB"  Tag="6"  Foreground="White" FontWeight="SemiBold"/>
                            </ComboBox>
                            <CheckBox x:Name="ChkDryRun" Content="Dry run (validate only)" FontSize="11"
                                      Foreground="#999999" VerticalAlignment="Center"
                                      AutomationProperties.AutomationId="TrainingPit.ForgeDryRun"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Button x:Name="BtnForgeStart" Style="{StaticResource PitButton}"
                                    Background="#3D2A00" BorderBrush="#E8A030" Foreground="#E8C080"
                                    Content="🏛 Start training" Click="BtnForgeStart_Click"
                                    AutomationProperties.AutomationId="TrainingPit.ForgeStart"/>
                            <Button x:Name="BtnForgeResume" Style="{StaticResource PitButton}"
                                    Background="#1A2A00" BorderBrush="#76B900" Foreground="#A8CC80"
                                    Content="⏯ Resume" Margin="8,0,0,0" IsEnabled="False"
                                    Click="BtnForgeResume_Click"
                                    AutomationProperties.AutomationId="TrainingPit.ForgeResume"/>
                            <Button x:Name="BtnForgeStop" Style="{StaticResource PitButton}"
                                    Background="#2A0A0A" BorderBrush="#F44747" Foreground="#F09090"
                                    Content="⏹ Stop" Margin="8,0,0,0" IsEnabled="False"
                                    Click="BtnForgeStop_Click"
                                    ToolTip="Stops the trainer. Progress is checkpointed every 50 steps — Resume continues from the last checkpoint."
                                    AutomationProperties.AutomationId="TrainingPit.ForgeStop"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Live status -->
                    <DockPanel>
                        <Ellipse x:Name="ForgeDot" Width="9" Height="9" Fill="#E8A030"
                                 VerticalAlignment="Center" Visibility="Collapsed" Margin="0,0,8,0"/>
                        <TextBlock x:Name="ForgeStatus" Text="Idle — adapter not yet trained" FontSize="11"
                                   Foreground="#999999" VerticalAlignment="Center"
                                   AutomationProperties.AutomationId="TrainingPit.ForgeStatus"/>
                        <TextBlock x:Name="ForgeMetrics" Text="" FontSize="11" Foreground="#E8C080"
                                   FontFamily="Consolas" HorizontalAlignment="Right" DockPanel.Dock="Right"
                                   AutomationProperties.AutomationId="TrainingPit.ForgeMetrics"/>
                    </DockPanel>
                    <ProgressBar x:Name="ForgeBar" Height="8" Margin="0,6,0,0" BorderThickness="0"
                                 Background="#111111" Foreground="#E8A030" Maximum="100"
                                 AutomationProperties.AutomationId="TrainingPit.ForgeBar"/>
                </StackPanel>
            </Border>
        </Expander>

        <!-- ── Queue header ───────────────────────────────────────────── -->
        <DockPanel Grid.Row="5" Margin="0,0,0,6">
            <TextBlock Text="Your review queue" FontSize="12" FontWeight="SemiBold" Foreground="#D4D4D4"/>
            <TextBlock Text="  — riskiest first. You make the final call." FontSize="11" Foreground="#999999"
                       VerticalAlignment="Bottom"/>
            <TextBlock x:Name="QueueCount" Text="" FontSize="11" Foreground="#999999"
                       HorizontalAlignment="Right" DockPanel.Dock="Right" VerticalAlignment="Bottom"
                       AutomationProperties.AutomationId="TrainingPit.QueueCount"/>
        </DockPanel>

        <!-- ── Review queue ───────────────────────────────────────────── -->
        <Border Grid.Row="6" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="QueueList" AutomationProperties.AutomationId="TrainingPit.Queue">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#2A2A2A" BorderThickness="0,0,0,1" Background="#0E0E0E">
                                <StackPanel>
                                    <Button Click="QueueHeader_Click" Tag="{Binding}" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            HorizontalContentAlignment="Stretch" Padding="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#161616" Padding="10,7">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <DockPanel>
                                            <Border Background="{Binding RiskBg}" CornerRadius="3" Padding="7,1"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RiskLabel}" FontSize="10"
                                                           Foreground="{Binding RiskFg}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="#D4D4D4"
                                                       Margin="10,0,0,0" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ScoreText}" FontSize="11" Foreground="#999999"
                                                       HorizontalAlignment="Right" DockPanel.Dock="Right"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Button>
                                    <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                                Margin="10,8,10,10">
                                        <TextBlock Text="{Binding Goal}" FontSize="11" Foreground="#999999"
                                                   TextWrapping="Wrap" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding TaskChips}" Margin="0,0,0,8">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#141814" BorderBrush="#2A2A2A" BorderThickness="1"
                                                            CornerRadius="3" Padding="7,2" Margin="0,0,6,4">
                                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#A8CC80"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding JudgeNote}" FontSize="11" Foreground="#CCA700"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"
                                                   Visibility="{Binding HasJudgeNote, Converter={StaticResource BoolToVis}}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource PitButton}" Content="✓ Keep it"
                                                    Background="#1F3D00" BorderBrush="#76B900" Foreground="#76B900"
                                                    Click="BtnKeepSilver_Click" Tag="{Binding}"/>
                                            <Button Style="{StaticResource PitButton}" Content="★ Keep — top quality"
                                                    Background="#1A2A00" BorderBrush="#CCA700" Foreground="#CCA700"
                                                    Margin="8,0,0,0" Click="BtnKeepGold_Click" Tag="{Binding}"/>
                                            <Button Style="{StaticResource PitButton}" Content="✕ Throw out"
                                                    Background="#2A0A0A" BorderBrush="#5A0000" Foreground="#F44747"
                                                    Margin="8,0,0,0" Click="BtnReject_Click" Tag="{Binding}"/>
                                            <Button Style="{StaticResource PitButton}" Content="📄 See full plan"
                                                    Background="#111111" BorderBrush="#2A2A2A" Foreground="#999999"
                                                    Margin="8,0,0,0" Click="BtnOpenCapture_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
