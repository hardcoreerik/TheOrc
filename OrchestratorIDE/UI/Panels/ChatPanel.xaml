<UserControl x:Class="OrchestratorIDE.UI.Panels.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Br.Bg.App}"
             AutomationProperties.AutomationId="Panel.Chat">

    <UserControl.Resources>

        <!-- User bubble style -->
        <Style x:Key="UserBubble" TargetType="Border">
            <Setter Property="Background"       Value="#1A2A1A"/>
            <Setter Property="BorderBrush"      Value="#2A4A2A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8,8,2,8"/>
            <Setter Property="Padding"          Value="12,8"/>
            <Setter Property="Margin"           Value="60,4,0,4"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MaxWidth"         Value="680"/>
        </Style>

        <!-- Assistant bubble style -->
        <Style x:Key="AssistantBubble" TargetType="Border">
            <Setter Property="Background"       Value="#111611"/>
            <Setter Property="BorderBrush"      Value="#1E2E1E"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8,8,8,2"/>
            <Setter Property="Padding"          Value="14,10"/>
            <Setter Property="Margin"           Value="0,4,60,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth"         Value="780"/>
        </Style>

        <!-- Tool call chip style -->
        <Style x:Key="ToolChip" TargetType="Border">
            <Setter Property="Background"       Value="#0E160E"/>
            <Setter Property="BorderBrush"      Value="#1E2E1E"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="4"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="Margin"           Value="0,2,60,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- Model combobox style -->
        <Style x:Key="ModelCombo" TargetType="ComboBox">
            <Setter Property="Background"    Value="#1A1A1A"/>
            <Setter Property="Foreground"    Value="#D4D4D4"/>
            <Setter Property="BorderBrush"   Value="#2E3A2E"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="Padding"       Value="6,3"/>
            <Setter Property="MinWidth"      Value="200"/>
        </Style>

        <!-- Send button style -->
        <Style x:Key="SendBtn" TargetType="Button">
            <Setter Property="Background"    Value="#1F3D00"/>
            <Setter Property="Foreground"    Value="#76B900"/>
            <Setter Property="BorderBrush"   Value="#2A5A00"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="14,8"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A5A00"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#76B900"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <DockPanel>

        <!-- ── Header bar ─────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#0E120E"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,0,0,1"
                Padding="12,7">
            <DockPanel>

                <!-- Right: Clear + Export buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnClear"
                            Content="🗑  Clear"
                            Margin="0,0,8,0"
                            Padding="8,4"
                            FontSize="11"
                            Cursor="Hand"
                            ToolTip="Clear conversation history"
                            Click="BtnClear_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        BorderBrush="#333333"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A1A1A"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#F44747"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="#666666"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#F44747"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="BtnExport"
                            Content="💾  Save"
                            Padding="8,4"
                            FontSize="11"
                            Cursor="Hand"
                            ToolTip="Save conversation to a markdown file"
                            Click="BtnExport_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        BorderBrush="#333333"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1A2A1A"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#76B900"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="#666666"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#76B900"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Left: branding + model picker -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💬" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Just Chat"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="Model:"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CbModel"
                              Style="{StaticResource ModelCombo}"
                              SelectionChanged="CbModel_SelectionChanged"
                              AutomationProperties.AutomationId="Chat.ModelPicker"/>
                    <!-- Search indicator -->
                    <Border x:Name="BdrSearching"
                            Background="#1A2800" BorderBrush="#2A4A00"
                            BorderThickness="1" CornerRadius="3"
                            Padding="6,2" Margin="12,0,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TbSearching"
                                   Text="🔍 Searching…"
                                   Foreground="#76B900"
                                   FontSize="10"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── Input bar ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#0E120E"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <DockPanel>
                <Button x:Name="BtnSend"
                        DockPanel.Dock="Right"
                        Content="Send  ⏎"
                        Style="{StaticResource SendBtn}"
                        Margin="10,0,0,0"
                        Click="BtnSend_Click"
                        IsEnabled="True"
                        AutomationProperties.AutomationId="Chat.Send"/>
                <Border Background="#141814"
                        BorderBrush="#2A3A2A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="1">
                    <TextBox x:Name="TbInput"
                             Background="Transparent"
                             Foreground="#D4D4D4"
                             CaretBrush="#76B900"
                             BorderThickness="0"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             Padding="10,8"
                             MinHeight="44"
                             MaxHeight="140"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             KeyDown="TbInput_KeyDown"
                             AutomationProperties.AutomationId="Chat.Input">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="5"
                                                    Padding="{TemplateBinding Padding}">
                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="#76B900"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>
            </DockPanel>
        </Border>

        <!-- ── Chat area ──────────────────────────────────────────────────── -->
        <ScrollViewer x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,8">
            <StackPanel x:Name="ChatStack"
                        Orientation="Vertical"
                        Margin="0,8,0,16">

                <!-- Welcome message (replaced by real content after first send) -->
                <Border x:Name="BdrWelcome"
                        Style="{StaticResource AssistantBubble}">
                    <StackPanel>
                        <TextBlock Text="👋  Ready to research"
                                   Foreground="#76B900"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#A8CC80"
                                   FontSize="12" LineHeight="20">
                            Ask me anything — I can search the web, read articles, and compile research into structured reports with clickable sources.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#5A7A40"
                                   FontSize="11" Margin="0,8,0,0" LineHeight="18">
                            💡  Try: "Summarise the latest news on [topic]" · "Compare X vs Y with sources" · "Find and summarise the docs for [library]"
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#444444"
                                   FontSize="10" Margin="0,10,0,0">
                            ⌨  Enter to send · Shift+Enter for new line
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
