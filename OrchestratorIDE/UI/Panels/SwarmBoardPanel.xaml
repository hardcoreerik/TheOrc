<UserControl x:Class="OrchestratorIDE.UI.Panels.SwarmBoardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Br.Bg.App}"
             AutomationProperties.AutomationId="Panel.SwarmBoard">

    <UserControl.Resources>
        <!-- Node style: idle state -->
        <Style x:Key="NodeBorder" TargetType="Border">
            <Setter Property="Background"   Value="#141814"/>
            <Setter Property="BorderBrush"  Value="#2A4A2A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="12,8"/>
            <Setter Property="Cursor"       Value="Arrow"/>
        </Style>

        <!-- Node style: active (animates in code-behind) -->
        <Style x:Key="NodeBorderActive" TargetType="Border">
            <Setter Property="Background"   Value="#1F3D00"/>
            <Setter Property="BorderBrush"  Value="#76B900"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="12,8"/>
        </Style>

        <!-- Boss node style (bigger) -->
        <Style x:Key="BossNodeBorder" TargetType="Border">
            <Setter Property="Background"   Value="#1A2A1A"/>
            <Setter Property="BorderBrush"  Value="#3A6A1A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding"      Value="16,10"/>
        </Style>

        <!-- Task card style -->
        <Style x:Key="TaskCard" TargetType="Border">
            <Setter Property="Background"     Value="#141E14"/>
            <Setter Property="BorderBrush"    Value="#2A3A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="6"/>
            <Setter Property="Padding"        Value="10,6"/>
            <Setter Property="Margin"         Value="0,0,8,0"/>
        </Style>

        <!-- Slot selector button style: inactive state -->
        <Style x:Key="SlotBtn" TargetType="Button">
            <Setter Property="Width"          Value="32"/>
            <Setter Property="Height"         Value="26"/>
            <Setter Property="Margin"         Value="3,0,0,0"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="FontFamily"     Value="Consolas"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Background"     Value="#1A1A1A"/>
            <Setter Property="Foreground"     Value="#888888"/>
            <Setter Property="BorderBrush"    Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#2A2A2A"/>
                                <Setter Property="Foreground"  Value="#D4D4D4"/>
                                <Setter Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stream tab button style -->
        <Style x:Key="StreamTab" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{StaticResource Br.Text.Muted}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"  Value="Transparent"/>
            <Setter Property="Padding"      Value="10,4"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Br.Text.White}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#0E120E"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <DockPanel>
                <!-- Left: brand + status -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" Foreground="{StaticResource Br.Accent.Green}"
                               FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="SWARM"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <!-- Status chip -->
                    <Border x:Name="BdrStatusChip"
                            Background="#1A1A1A" CornerRadius="3" Padding="6,2" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Width="7" Height="7"
                                     Fill="#444444" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="TbStatusChip" Text="IDLE"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#888888" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Model name -->
                    <TextBlock x:Name="TbModelName" Text="—"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <!-- Slots chip -->
                    <Border Background="#1A2A1A" CornerRadius="3" Padding="5,2">
                        <TextBlock x:Name="TbSlots" Text="1 slot"
                                   Foreground="#76B900" FontSize="10"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Right: Stop button -->
                <Button x:Name="BtnStopSwarm"
                        DockPanel.Dock="Right"
                        Content="✗  STOP"
                        Visibility="Collapsed"
                        Background="#2A0A0A"
                        Foreground="#F44747"
                        BorderBrush="#4A1A1A"
                        BorderThickness="1"
                        Padding="10,4"
                        FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnStopSwarm_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A1414"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>

        <!-- ── Steering directive bar (above task strip, active state only) ── -->
        <Border x:Name="BdrDirective"
                DockPanel.Dock="Bottom"
                Background="#0A0F0A"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,1,0,0"
                Padding="8,5"
                Visibility="Collapsed">
            <DockPanel>
                <!-- Send button -->
                <Button x:Name="BtnSendDirective"
                        DockPanel.Dock="Right"
                        Content="⬆ Steer"
                        Margin="6,0,0,0"
                        Padding="10,5"
                        FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnSendDirective_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#1F3D00"
                                    BorderBrush="#2A5A00"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A5A00"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#76B900"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="#76B900"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#444444"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Directive label -->
                <TextBlock DockPanel.Dock="Left"
                           Text="📌"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           FontSize="13"/>

                <!-- Directive input -->
                <TextBox x:Name="TbDirective"
                         Background="#141414"
                         Foreground="#D4D4D4"
                         CaretBrush="#76B900"
                         BorderBrush="#2A3A2A"
                         BorderThickness="1"
                         Padding="8,5"
                         FontSize="12"
                         VerticalContentAlignment="Center"
                         VerticalAlignment="Center"
                         KeyDown="TbDirective_KeyDown"
                         AutomationProperties.AutomationId="Swarm.Directive">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="#76B900"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- ── Task board — bottom strip ──────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#0E120E"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,1,0,0"
                MinHeight="60" MaxHeight="120">
            <DockPanel>
                <!-- "TASKS" label -->
                <Border DockPanel.Dock="Left" Background="#0A0F0A"
                        BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,1,0"
                        Padding="8,0">
                    <TextBlock Text="TASKS" Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="9" FontWeight="Bold" VerticalAlignment="Center"
                               LayoutTransform="{x:Null}"/>
                </Border>

                <!-- Scrollable task card list -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Hidden">
                    <StackPanel x:Name="TaskCardPanel"
                                Orientation="Horizontal"
                                Margin="8,6"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Main: Idle overlay / Active board ──────────────────────────── -->
        <Grid>

            <!-- ── IDLE STATE ─────────────────────────────────────────────── -->
            <Grid x:Name="PnlIdle" Background="{StaticResource Br.Bg.App}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            MaxWidth="480" Margin="24">

                    <!-- Icon -->
                    <TextBlock Text="⬡ ⬡ ⬡" HorizontalAlignment="Center"
                               Foreground="{StaticResource Br.Accent.Green}"
                               FontSize="28" Margin="0,0,0,16" Opacity="0.7"/>

                    <!-- Title -->
                    <TextBlock Text="Swarm Mode"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>

                    <!-- Subtitle -->
                    <TextBlock TextAlignment="Center" TextWrapping="Wrap"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="12" Margin="0,0,0,20">
                        One Boss coordinates up to 3 specialist workers — Researcher, Coder, and UI Developer —
                        running concurrently and checking in via a shared task board.
                    </TextBlock>

                    <!-- Gate warning (shown if not capable) -->
                    <Border x:Name="BdrGateWarn"
                            Background="#2A1A00" BorderBrush="#4A3A00" BorderThickness="1"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,14"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TbGateWarn" TextWrapping="Wrap"
                                   Foreground="#CCA700" FontSize="12" TextAlignment="Center"/>
                    </Border>

                    <!-- ── Ollama parallel slots selector ──────────────────── -->
                    <Border Background="#0E120E" BorderBrush="#252525" BorderThickness="1"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,14">
                        <StackPanel>
                            <DockPanel>
                                <!-- Label + hint -->
                                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <TextBlock Text="OLLAMA_NUM_PARALLEL"
                                               Foreground="#76B900" FontSize="10"
                                               FontWeight="Bold" FontFamily="Consolas"/>
                                    <TextBlock Text="Concurrent model slots · Swarm needs ≥ 3"
                                               Foreground="#666666" FontSize="10"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Slot picker buttons: 1 · 2 · 3 · 4 -->
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button x:Name="BtnSlot1" Content="1" Tag="1"
                                            Style="{StaticResource SlotBtn}"
                                            Click="BtnSlot_Click"
                                            AutomationProperties.AutomationId="Swarm.Slot1"/>
                                    <Button x:Name="BtnSlot2" Content="2" Tag="2"
                                            Style="{StaticResource SlotBtn}"
                                            Click="BtnSlot_Click"
                                            AutomationProperties.AutomationId="Swarm.Slot2"/>
                                    <Button x:Name="BtnSlot3" Content="3" Tag="3"
                                            Style="{StaticResource SlotBtn}"
                                            Click="BtnSlot_Click"
                                            AutomationProperties.AutomationId="Swarm.Slot3"/>
                                    <Button x:Name="BtnSlot4" Content="4" Tag="4"
                                            Style="{StaticResource SlotBtn}"
                                            Click="BtnSlot_Click"
                                            AutomationProperties.AutomationId="Swarm.Slot4"/>
                                </StackPanel>
                            </DockPanel>

                            <!-- Restart bar — hidden until user changes slot count -->
                            <DockPanel x:Name="PnlSlotRestart"
                                       Visibility="Collapsed"
                                       Margin="0,8,0,0"
                                       LastChildFill="True">

                                <!-- Restart button -->
                                <Button x:Name="BtnRestartOllama"
                                        DockPanel.Dock="Right"
                                        Content="↻  Restart Ollama"
                                        Margin="10,0,0,0"
                                        Padding="10,4"
                                        FontSize="11" FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Click="BtnRestartOllama_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="#2A1F00"
                                                    BorderBrush="#4A3A00"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3A2A00"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush"  Value="#76B900"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush"  Value="#333333"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="#CCA700"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Hint text -->
                                <TextBlock Text="Slot count changed · Ollama needs a restart to apply."
                                           Foreground="#888888"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Goal input -->
                    <Border Background="#141E14" BorderBrush="#2A4A2A"
                            BorderThickness="1" CornerRadius="8" Padding="2">
                        <TextBox x:Name="TbGoal"
                                 Background="Transparent"
                                 Foreground="#D4D4D4"
                                 CaretBrush="#76B900"
                                 BorderThickness="0"
                                 FontSize="13" FontFamily="Segoe UI"
                                 Padding="10,8"
                                 MinHeight="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="Build a Reddit front page news scraper that pulls top posts, scores, and links."
                                 AutomationProperties.AutomationId="Swarm.GoalInput"/>
                    </Border>

                    <Button x:Name="BtnLaunch"
                            Content="Launch Swarm  ⚡"
                            Margin="0,12,0,0"
                            Padding="20,10"
                            FontSize="13" FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            Click="BtnLaunch_Click"
                            AutomationProperties.AutomationId="Swarm.Launch">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"  Value="{StaticResource Br.Accent.Green}"/>
                                <Setter Property="Foreground"  Value="#0E0E0E"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor"      Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#8FD120"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#2A3A1A"/>
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── ACTIVE STATE ────────────────────────────────────────────── -->
            <Grid x:Name="PnlActive" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" MinWidth="220"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: Hub-and-spoke diagram ──────────────────────────── -->
                <Grid Grid.Column="0" Background="#0A0F0A">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Node diagram area -->
                    <Grid x:Name="DiagramGrid" Grid.Row="0" Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Boss -->
                            <RowDefinition Height="32"/>    <!-- connector space -->
                            <RowDefinition Height="Auto"/>  <!-- Workers row -->
                            <RowDefinition Height="*"/>     <!-- padding -->
                        </Grid.RowDefinitions>

                        <!-- TheOrc node (Boss) -->
                        <Border x:Name="NodeBoss"
                                Grid.Row="0"
                                Style="{StaticResource BossNodeBorder}"
                                HorizontalAlignment="Center"
                                MinWidth="130">
                            <StackPanel HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="⬡" FontSize="18" Margin="0,0,6,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Br.Accent.Green}"/>
                                    <TextBlock Text="TheOrc" FontSize="13" FontWeight="Bold"
                                               FontFamily="Consolas"
                                               Foreground="{StaticResource Br.Accent.Green}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="TbBossStatus"
                                           Text="Orchestrating…"
                                           Foreground="{StaticResource Br.Text.Muted}"
                                           FontSize="10" HorizontalAlignment="Center"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Connection lines canvas (drawn in code-behind) -->
                        <Canvas x:Name="NodeCanvas"
                                Grid.Row="0" Grid.RowSpan="3"
                                IsHitTestVisible="False"/>

                        <!-- Workers row -->
                        <UniformGrid x:Name="WorkerGrid"
                                     Grid.Row="2"
                                     Rows="1" Columns="3"
                                     HorizontalAlignment="Stretch">

                            <!-- Researcher -->
                            <Border x:Name="NodeResearcher"
                                    Style="{StaticResource NodeBorder}"
                                    Margin="4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="20"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="RESEARCHER" FontSize="9" FontWeight="Bold"
                                               Foreground="#4A9FD9" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="TbResearcherStatus"
                                               Text="idle" FontSize="10"
                                               Foreground="{StaticResource Br.Text.Muted}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Coder -->
                            <Border x:Name="NodeCoder"
                                    Style="{StaticResource NodeBorder}"
                                    Margin="4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="💻" FontSize="20"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="CODER" FontSize="9" FontWeight="Bold"
                                               Foreground="#76B900" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="TbCoderStatus"
                                               Text="idle" FontSize="10"
                                               Foreground="{StaticResource Br.Text.Muted}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- UI Developer -->
                            <Border x:Name="NodeUIDev"
                                    Style="{StaticResource NodeBorder}"
                                    Margin="4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🎨" FontSize="20"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="UI DEV" FontSize="9" FontWeight="Bold"
                                               Foreground="#C586C0" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="TbUIDevStatus"
                                               Text="idle" FontSize="10"
                                               Foreground="{StaticResource Br.Text.Muted}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                        </UniformGrid>
                    </Grid>

                    <!-- Goal label -->
                    <Border Grid.Row="1" Background="#0E120E"
                            BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0"
                            Padding="8,6">
                        <TextBlock x:Name="TbActiveGoal"
                                   Text="Goal:"
                                   Foreground="{StaticResource Br.Text.Muted}"
                                   FontSize="11" TextWrapping="Wrap"
                                   FontFamily="Segoe UI"/>
                    </Border>
                </Grid>

                <!-- ── Splitter ───────────────────────────────────────────── -->
                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                              Background="{StaticResource Br.Border}" Cursor="SizeWE"/>

                <!-- ── Right: Live stream ─────────────────────────────────── -->
                <DockPanel Grid.Column="2" Background="{StaticResource Br.Bg.Panel}">

                    <!-- Stream tab bar -->
                    <Border DockPanel.Dock="Top"
                            Background="#0E120E"
                            BorderBrush="{StaticResource Br.Border}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <!-- Agent tabs (left) -->
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <Button x:Name="TabBoss"
                                        Content="⬡ TheOrc"
                                        Style="{StaticResource StreamTab}"
                                        Click="Tab_Click" Tag="boss"/>
                                <Button x:Name="TabResearcher"
                                        Content="🔍 Researcher"
                                        Style="{StaticResource StreamTab}"
                                        Click="Tab_Click" Tag="researcher"
                                        Visibility="Collapsed"/>
                                <Button x:Name="TabCoder"
                                        Content="💻 Coder"
                                        Style="{StaticResource StreamTab}"
                                        Click="Tab_Click" Tag="coder"
                                        Visibility="Collapsed"/>
                                <Button x:Name="TabUIDev"
                                        Content="🎨 UI Dev"
                                        Style="{StaticResource StreamTab}"
                                        Click="Tab_Click" Tag="uidev"
                                        Visibility="Collapsed"/>
                            </StackPanel>

                            <!-- Thinking toggle (right) -->
                            <Button x:Name="BtnThinkToggle"
                                    DockPanel.Dock="Right"
                                    Click="BtnThinkToggle_Click"
                                    Padding="8,4"
                                    Margin="4,2"
                                    Cursor="Hand"
                                    ToolTip="Toggle model thinking layer">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A2A1A"/>
                                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#2A4A2A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💭" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TbThinkLabel"
                                               Text=" Thinking"
                                               FontSize="10"
                                               Foreground="#666666"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TbThinkCount"
                                               Text=""
                                               FontSize="10"
                                               Foreground="#444444"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </DockPanel>
                    </Border>

                    <!-- Thinking layer (hidden by default; toggled by BtnThinkToggle) -->
                    <Border DockPanel.Dock="Top"
                            x:Name="BdrThinking"
                            Visibility="Collapsed"
                            Background="#0A0A0A"
                            BorderBrush="#1A2A1A"
                            BorderThickness="0,0,0,1"
                            MaxHeight="180">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="  ─── model thinking ───"
                                       Foreground="#333333"
                                       FontSize="10" FontFamily="Consolas"
                                       Padding="12,4,0,2"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="TbThinking"
                                         Background="Transparent"
                                         Foreground="#3A5A3A"
                                         FontFamily="Cascadia Code, Consolas, monospace"
                                         FontSize="11"
                                         FontStyle="Italic"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         Padding="12,4"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Disabled"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Stream output -->
                    <ScrollViewer x:Name="StreamScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBox x:Name="TbStream"
                                 Background="Transparent"
                                 Foreground="#C8D4C8"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="12"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 Padding="12,10"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"
                                 AutomationProperties.AutomationId="Swarm.Stream"/>
                    </ScrollViewer>
                </DockPanel>
            </Grid>

        </Grid>
    </DockPanel>
</UserControl>
