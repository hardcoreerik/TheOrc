<UserControl x:Class="OrchestratorIDE.UI.Panels.PitBossPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0A0A"
             AutomationProperties.AutomationId="PitBoss.Panel">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Chip button style -->
        <Style x:Key="ChipBtn" TargetType="Button">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Send button -->
        <Style x:Key="SendBtn" TargetType="Button" BasedOn="{StaticResource ChipBtn}">
            <Setter Property="Background" Value="#2A3A1A"/>
            <Setter Property="BorderBrush" Value="#4A6A2A"/>
            <Setter Property="Foreground" Value="#A8CC80"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="Padding" Value="14,6"/>
        </Style>

        <!-- Action button -->
        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource ChipBtn}">
            <Setter Property="Background" Value="#1A1A2A"/>
            <Setter Property="BorderBrush" Value="#3A3A6A"/>
            <Setter Property="Foreground" Value="#9090E8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Launch button -->
        <Style x:Key="LaunchBtn" TargetType="Button" BasedOn="{StaticResource ChipBtn}">
            <Setter Property="Background" Value="#2A1A3A"/>
            <Setter Property="BorderBrush" Value="#6A2A9A"/>
            <Setter Property="Foreground" Value="#C080E8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="700"/>
            <Setter Property="Padding" Value="20,8"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- header bar -->
            <RowDefinition Height="*"/>    <!-- body -->
            <RowDefinition Height="Auto"/> <!-- footer actions -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#111" BorderBrush="#1F2A1F" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0">
                <!-- Back -->
                <Button DockPanel.Dock="Left" x:Name="BtnBack"
                        Style="{StaticResource ActionBtn}"
                        Content="← Back to Pit" Click="BtnBack_Click"
                        AutomationProperties.AutomationId="PitBoss.BackBtn"
                        VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🤖" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="PIT BOSS" FontSize="14" FontWeight="800" Foreground="#A8CC80"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="  TRAINING WIZARD" FontSize="12" Foreground="#555"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- History toggle (visible when plans exist) -->
                <Button DockPanel.Dock="Right" x:Name="BtnViewHistory"
                        Style="{StaticResource ActionBtn}"
                        Content="📋  History" Click="BtnViewHistory_Click"
                        VerticalAlignment="Center" Margin="0,0,8,0"
                        Visibility="Collapsed"
                        AutomationProperties.AutomationId="PitBoss.ViewHistoryBtn"/>

                <!-- Model indicator -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TbModelLabel" Text="" FontSize="10" Foreground="#555"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Ellipse x:Name="ModelDot" Width="6" Height="6" Fill="#3A6A2A"
                             VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ HISTORY LANDING VIEW ═══ -->
        <Grid Grid.Row="1" x:Name="HistoryBody" Background="#0A0A0A" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>   <!-- toolbar -->
                <RowDefinition Height="*"/>    <!-- scrollable plan list -->
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0D0D12" BorderBrush="#1A1A2A" BorderThickness="0,0,0,1" Padding="16,0">
                <DockPanel>
                    <Button DockPanel.Dock="Right" x:Name="BtnNewPlan"
                            Style="{StaticResource SendBtn}"
                            Content="➕  New Plan" Click="BtnNewPlan_Click"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="PitBoss.NewPlanBtn"/>
                    <TextBlock Text="SAVED TRAINING PLANS" FontSize="10" FontWeight="700"
                               Foreground="#556" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
                <StackPanel x:Name="PlanHistoryList" Margin="0,4"/>
            </ScrollViewer>
        </Grid>

        <!-- ═══ BODY: Chat (left) + Plan preview (right) ═══ -->
        <Grid Grid.Row="1" x:Name="WizardBody">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>         <!-- chat -->
                <ColumnDefinition Width="1"/>          <!-- splitter -->
                <ColumnDefinition Width="340"/>        <!-- plan preview -->
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Chat ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- message scroll -->
                    <RowDefinition Height="Auto"/> <!-- step indicator -->
                    <RowDefinition Height="Auto"/> <!-- suggestion chips -->
                    <RowDefinition Height="Auto"/> <!-- input row -->
                </Grid.RowDefinitions>

                <!-- Messages -->
                <ScrollViewer Grid.Row="0" x:Name="ChatScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,12,16,8">
                    <StackPanel x:Name="ChatStack">
                        <!-- Messages are added programmatically -->
                    </StackPanel>
                </ScrollViewer>

                <!-- Step indicator -->
                <Border Grid.Row="1" Padding="16,6,16,0">
                    <DockPanel>
                        <TextBlock x:Name="TbStepIndicator"
                                   Text="● ● ● ○ ○ ○ ○ ○   step 1 of 8"
                                   FontSize="10" Foreground="#444"
                                   FontFamily="Consolas" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="TbRoundHint" Text="" FontSize="10"
                                   Foreground="#555" HorizontalAlignment="Right"/>
                    </DockPanel>
                </Border>

                <!-- Suggestion chips (goal shortcuts) -->
                <Border Grid.Row="2" Padding="16,6,16,4"
                        x:Name="ChipRow">
                    <WrapPanel x:Name="ChipPanel" Orientation="Horizontal">
                        <!-- populated dynamically -->
                    </WrapPanel>
                </Border>

                <!-- Input row -->
                <Border Grid.Row="3" Background="#0E0E0E"
                        BorderBrush="#1F1F1F" BorderThickness="0,1,0,0"
                        Padding="16,10">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" x:Name="BtnSend"
                                Style="{StaticResource SendBtn}"
                                Content="Send ▶" Click="BtnSend_Click"
                                IsEnabled="False"
                                AutomationProperties.AutomationId="PitBoss.SendBtn"
                                Margin="8,0,0,0"/>
                        <TextBox x:Name="TbInput"
                                 Background="#141414" Foreground="#D4D4D4"
                                 FontSize="12" FontFamily="Segoe UI"
                                 BorderBrush="#2A2A2A" BorderThickness="1"
                                 Padding="10,6" CaretBrush="#A8CC80"
                                 TextWrapping="Wrap" MaxLines="4" AcceptsReturn="False"
                                 KeyDown="TbInput_KeyDown"
                                 TextChanged="TbInput_TextChanged"
                                 AutomationProperties.AutomationId="PitBoss.InputBox">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="HintBrush" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Describe your training goal, or pick a suggestion above…"
                                                           Foreground="#444" FontSize="12" Margin="10,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ── Divider ── -->
            <Border Grid.Column="1" Background="#1A1A1A"/>

            <!-- ── RIGHT: Plan preview ── -->
            <Grid Grid.Column="2" Background="#0C0C12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>  <!-- pane header -->
                    <RowDefinition Height="*"/>   <!-- plan content -->
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#0E0E1A" BorderBrush="#1A1A2A" BorderThickness="0,0,0,1"
                        Padding="14,0">
                    <TextBlock Text="📋  TRAINING PLAN" FontSize="10" FontWeight="700"
                               Foreground="#7B7BCC" VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,12">
                    <Grid>
                    <StackPanel x:Name="PlanStack" Visibility="Collapsed">

                        <!-- Goal -->
                        <TextBlock Text="GOAL" FontSize="9" Foreground="#555" FontWeight="700"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="PlanGoal" Text="—" FontSize="11" Foreground="#D4D4D4"
                                   TextWrapping="Wrap" Margin="0,0,0,14"/>

                        <!-- Persona -->
                        <TextBlock Text="PERSONA" FontSize="9" Foreground="#555" FontWeight="700"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="PlanPersona" Text="—" FontSize="10" Foreground="#AAA"
                                   TextWrapping="Wrap" FontStyle="Italic" Margin="0,0,0,14"/>

                        <!-- Task mix -->
                        <TextBlock Text="TASK MIX" FontSize="9" Foreground="#555" FontWeight="700"
                                   Margin="0,0,0,6"/>
                        <ItemsControl x:Name="PlanTaskMix" Margin="0,0,0,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Key}"
                                                   FontSize="9" Foreground="#888" FontFamily="Consolas"/>
                                        <Border Grid.Column="1" Background="#1A1A1A" Height="8"
                                                CornerRadius="2" Margin="4,0">
                                            <Border Background="#2A4A1A" CornerRadius="2"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding PctText}"
                                                   FontSize="9" Foreground="#A8CC80" FontFamily="Consolas"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Dataset -->
                        <TextBlock Text="DATASET" FontSize="9" Foreground="#555" FontWeight="700"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="PlanDataset" Text="—" FontSize="10" Foreground="#D4D4D4"
                                   TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock x:Name="PlanLanguages" Text="—" FontSize="10" Foreground="#64B4F0"
                                   Margin="0,0,0,14"/>

                        <!-- Model / Adapter -->
                        <TextBlock Text="MODEL  →  ADAPTER" FontSize="9" Foreground="#555" FontWeight="700"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="PlanModel" Text="—" FontSize="10" Foreground="#D4D4D4"
                                   TextWrapping="Wrap" Margin="0,0,0,14"/>

                        <!-- Estimate -->
                        <TextBlock Text="ESTIMATE" FontSize="9" Foreground="#555" FontWeight="700"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="PlanEstimate" Text="—" FontSize="10" Foreground="#E8A030"
                                   TextWrapping="Wrap" Margin="0,0,0,14"/>

                        <!-- HIVEMIND -->
                        <Border x:Name="HiveBadge" Visibility="Collapsed"
                                Background="#1A0A2A" BorderBrush="#5A1A9A" BorderThickness="1"
                                CornerRadius="4" Padding="10,6" Margin="0,0,0,14">
                            <TextBlock Text="🐝  HIVEMIND-ready — plan can be distributed across nodes"
                                       FontSize="9" Foreground="#C080E8" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Notes -->
                        <TextBlock Text="NOTES" FontSize="9" Foreground="#555" FontWeight="700"
                                   Margin="0,0,0,4"
                                   x:Name="NotesLabel" Visibility="Collapsed"/>
                        <TextBlock x:Name="PlanNotes" Text="" FontSize="10" Foreground="#888"
                                   TextWrapping="Wrap" Visibility="Collapsed"/>

                    </StackPanel>

                    <!-- Empty state -->
                    <TextBlock x:Name="PlanEmpty"
                               Text="Answer the questions on the left and your training plan will appear here in real time."
                               FontSize="11" Foreground="#444" TextWrapping="Wrap"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="16,40"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══ FOOTER ═══ -->
        <Border Grid.Row="2" Background="#0E0E0E" BorderBrush="#1F1F1F" BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel>
                <!-- Status text -->
                <TextBlock x:Name="TbStatus" Text="Ready — answer the first question to begin."
                           FontSize="10" Foreground="#555" VerticalAlignment="Center"/>

                <!-- Action buttons (right-aligned) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnSavePlan"
                            Style="{StaticResource ActionBtn}"
                            Content="💾 Save Plan" Click="BtnSavePlan_Click"
                            IsEnabled="False"
                            AutomationProperties.AutomationId="PitBoss.SavePlanBtn"/>
                    <Button x:Name="BtnLaunchPlan"
                            Style="{StaticResource LaunchBtn}"
                            Content="🚀 Launch Training" Click="BtnLaunchPlan_Click"
                            IsEnabled="False"
                            AutomationProperties.AutomationId="PitBoss.LaunchBtn"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
