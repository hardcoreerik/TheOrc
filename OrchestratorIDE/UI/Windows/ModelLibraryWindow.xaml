<Window x:Class="OrchestratorIDE.UI.Windows.ModelLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Model Library — TheOrc"
        Width="800" Height="560"
        MinWidth="640" MinHeight="400"
        Background="{StaticResource Br.Bg.App}"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0A0A0A" BorderBrush="#1E2E1E"
                BorderThickness="0,0,0,1" Padding="16,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Model Library"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="15" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" FontFamily="Segoe UI" Margin="0,4,0,0"
                               Text="Manage downloaded models and their swarm role assignments"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="⬡ Open Downloader"
                        Click="BtnOpenDownloader_Click"
                        Padding="12,6" VerticalAlignment="Center"
                        Background="{StaticResource Br.Accent.Green}"
                        Foreground="White" BorderThickness="0"
                        FontFamily="Segoe UI" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- Model list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ModelListPanel" Margin="12"/>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#060606" BorderBrush="#111111"
                BorderThickness="0,1,0,0" Padding="12,6">
            <TextBlock x:Name="TxtLibStatus"
                       Text="Scanning model directories…"
                       Foreground="{StaticResource Br.Text.Muted}"
                       FontFamily="Segoe UI" FontSize="11"/>
        </Border>
    </Grid>
</Window>
