<Window x:Class="OrchestratorIDE.UI.Windows.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help — TheOrc"
        Width="1000" Height="680"
        MinWidth="720" MinHeight="440"
        Background="{StaticResource Br.Bg.App}"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.AutomationId="Help.Window">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0A0A0A" BorderBrush="#1E2E1E"
                BorderThickness="0,0,0,1" Padding="16,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="📖 Help &amp; Documentation"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="15" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TxtSubtitle"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" FontFamily="Segoe UI" Margin="0,4,0,0"
                               Text="All guides ship inside the app — no internet needed"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="Open on GitHub ↗"
                        Click="BtnOpenGitHub_Click" ToolTip="View this guide in the online repository"
                        Padding="12,6" VerticalAlignment="Center"
                        Background="{StaticResource Br.Bg.Input}"
                        Foreground="{StaticResource Br.Text.Default}"
                        BorderBrush="{StaticResource Br.Border}" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- Body: nav | content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200" MaxWidth="380"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: search + guide list -->
            <DockPanel Grid.Column="0" Background="{StaticResource Br.Bg.Sidebar}">
                <Border DockPanel.Dock="Top" Padding="10,10,10,6">
                    <TextBox x:Name="TxtSearch"
                             AutomationProperties.AutomationId="Help.Search"
                             Background="{StaticResource Br.Bg.Input}"
                             Foreground="{StaticResource Br.Text.Default}"
                             BorderBrush="{StaticResource Br.Border}" BorderThickness="1"
                             Padding="8,6" FontFamily="Segoe UI" FontSize="12"
                             TextChanged="TxtSearch_TextChanged"
                             ToolTip="Search guide titles and content"/>
                </Border>
                <TextBlock DockPanel.Dock="Top" x:Name="TxtSearchHint"
                           Text="Type to search all guides"
                           Foreground="{StaticResource Br.Text.Muted}"
                           FontSize="10" FontFamily="Segoe UI" Margin="12,0,12,6"/>
                <ListBox x:Name="LstGuides"
                         AutomationProperties.AutomationId="Help.GuideList"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="LstGuides_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,7"/>
                            <Setter Property="Foreground" Value="{StaticResource Br.Text.Default}"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource Br.Bg.Active}"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource Br.Accent.Neon}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource Br.Bg.Hover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>

            <Border Grid.Column="1" Width="1" Background="{StaticResource Br.Border}"/>

            <!-- Right: rendered guide -->
            <FlowDocumentScrollViewer x:Name="DocViewer" Grid.Column="2"
                                      AutomationProperties.AutomationId="Help.DocViewer"
                                      Background="{StaticResource Br.Bg.App}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      IsToolBarVisible="False"
                                      Padding="24,16"/>
        </Grid>
    </Grid>
</Window>
