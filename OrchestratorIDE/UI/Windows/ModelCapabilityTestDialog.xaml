<Window x:Class="OrchestratorIDE.UI.Windows.ModelCapabilityTestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Run Model Capability Test — TheOrc"
        Width="760" Height="640"
        MinWidth="560" MinHeight="480"
        Background="{StaticResource Br.Bg.App}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        AutomationProperties.AutomationId="ModelCapTest.Root"
        AutomationProperties.Name="Model Capability Test Dialog">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- model + run bar -->
            <RowDefinition Height="Auto"/>   <!-- phase strip -->
            <RowDefinition Height="Auto"/>   <!-- live test cards -->
            <RowDefinition Height="*"/>      <!-- activity feed -->
            <RowDefinition Height="44"/>     <!-- bottom bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0A0A0A" BorderBrush="#1E2E1E"
                BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Model Capability Test"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock Text="Measures write_file JSON reliability at Small / Medium / Large payload sizes."
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                </StackPanel>
                <TextBlock x:Name="TbElapsed" DockPanel.Dock="Right"
                           Foreground="{StaticResource Br.Text.Muted}"
                           FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ── Model + run bar ───────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#0C0C0C" BorderBrush="#1E2E1E"
                BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Model:"
                           Foreground="{StaticResource Br.Text.Muted}"
                           FontFamily="Segoe UI" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>

                <TextBox x:Name="TbModelId" Grid.Column="1"
                         Background="#111A11"
                         Foreground="{StaticResource Br.Text.White}"
                         CaretBrush="{StaticResource Br.Accent.Green}"
                         BorderBrush="#2A3A2A" BorderThickness="1"
                         FontFamily="Consolas" FontSize="12"
                         Padding="8,5" VerticalAlignment="Center"
                         AutomationProperties.AutomationId="ModelCapTest.ModelId"
                         AutomationProperties.Name="Model ID"/>

                <ComboBox x:Name="CbTestLevel" Grid.Column="2"
                          Margin="8,0,0,0"
                          Background="#111A11"
                          Foreground="{StaticResource Br.Text.White}"
                          BorderBrush="#2A3A2A" BorderThickness="1"
                          FontFamily="Segoe UI" FontSize="12"
                          Width="150" Padding="8,5"
                          AutomationProperties.AutomationId="ModelCapTest.TestLevel"
                          AutomationProperties.Name="Test Level">
                    <ComboBoxItem Content="Small only"   Tag="FileWriteSmall"  IsSelected="True"/>
                    <ComboBoxItem Content="Medium only"  Tag="FileWriteMedium"/>
                    <ComboBoxItem Content="Large only"   Tag="FileWriteLarge"/>
                    <ComboBoxItem Content="All three ★"  Tag="All"/>
                </ComboBox>

                <Button x:Name="BtnRun" Grid.Column="3"
                        Content="▶  Run"
                        Click="BtnRun_Click"
                        Margin="8,0,0,0"
                        Padding="14,6"
                        Background="{StaticResource Br.Accent.Green}"
                        Foreground="White" BorderThickness="0"
                        FontFamily="Segoe UI" FontSize="12"
                        Cursor="Hand"
                        AutomationProperties.AutomationId="ModelCapTest.Run"
                        AutomationProperties.Name="Run Test"/>

                <Button x:Name="BtnCancel" Grid.Column="4"
                        Content="■  Stop"
                        Click="BtnCancel_Click"
                        Margin="6,0,0,0"
                        Padding="10,6"
                        Background="#1A1A1A" Foreground="#888888"
                        BorderBrush="#333333" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12"
                        Cursor="Hand"
                        IsEnabled="False"
                        AutomationProperties.AutomationId="ModelCapTest.Cancel"/>
            </Grid>
        </Border>

        <!-- ── Phase strip ───────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#080C08" BorderBrush="#1A2A1A"
                BorderThickness="0,0,0,1" Padding="12,7">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Border x:Name="PhaseIdle" CornerRadius="3" Padding="10,4" Margin="0,0,3,0">
                    <TextBlock Text="○  Idle" FontFamily="Segoe UI" FontSize="11"/>
                </Border>

                <TextBlock Text="→" Foreground="#333333" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,3,0"/>

                <Border x:Name="PhaseSending" CornerRadius="3" Padding="10,4" Margin="0,0,3,0">
                    <TextBlock Text="📡  Sending" FontFamily="Segoe UI" FontSize="11"/>
                </Border>

                <TextBlock Text="→" Foreground="#333333" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,3,0"/>

                <Border x:Name="PhaseWaiting" CornerRadius="3" Padding="10,4" Margin="0,0,3,0">
                    <TextBlock Text="⏳  Model thinking" FontFamily="Segoe UI" FontSize="11"/>
                </Border>

                <TextBlock Text="→" Foreground="#333333" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,3,0"/>

                <Border x:Name="PhaseReceived" CornerRadius="3" Padding="10,4" Margin="0,0,3,0">
                    <TextBlock x:Name="TbPhaseReceived"
                               Text="📥  Received" FontFamily="Segoe UI" FontSize="11"/>
                </Border>

                <TextBlock Text="→" Foreground="#333333" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,3,0"/>

                <Border x:Name="PhaseAnalyzing" CornerRadius="3" Padding="10,4" Margin="0,0,3,0">
                    <TextBlock Text="🔍  Analyzing" FontFamily="Segoe UI" FontSize="11"/>
                </Border>

                <TextBlock Text="→" Foreground="#333333" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,3,0"/>

                <Border x:Name="PhaseDone" CornerRadius="3" Padding="10,4">
                    <TextBlock x:Name="TbPhaseDone"
                               Text="Done" FontFamily="Segoe UI" FontSize="11"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ── Live test cards ───────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#0A0A0A" BorderBrush="#1A2A1A"
                BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel x:Name="PnlTestCards" Orientation="Horizontal"/>
        </Border>

        <!-- ── Activity feed ─────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="4"
                      x:Name="LogScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#060606">
            <StackPanel x:Name="PnlLog" Margin="12,8,12,8"/>
        </ScrollViewer>

        <!-- ── Bottom bar ────────────────────────────────────────────── -->
        <Border Grid.Row="5" Background="#070707" BorderBrush="#111111"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <Button DockPanel.Dock="Right" Content="Close"
                        Click="BtnClose_Click"
                        Padding="14,6" Margin="8,0,0,0"
                        Background="#1A2A1A" Foreground="{StaticResource Br.Text.White}"
                        BorderBrush="#2A3A2A" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12"
                        Cursor="Hand"
                        AutomationProperties.AutomationId="ModelCapTest.Close"/>
                <TextBlock x:Name="TbStatus"
                           Foreground="{StaticResource Br.Text.Muted}"
                           FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center"
                           Text="Choose a model and test level, then click Run."/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
