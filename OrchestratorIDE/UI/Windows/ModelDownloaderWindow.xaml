<Window x:Class="OrchestratorIDE.UI.Windows.ModelDownloaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Model Downloader — TheOrc"
        Width="900" Height="680"
        MinWidth="720" MinHeight="500"
        Background="{StaticResource Br.Bg.App}"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.AutomationId="Window.ModelDownloader">

    <Window.Resources>
        <!-- Pill badge style for source tags -->
        <Style x:Key="SourceBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header / search -->
            <RowDefinition Height="*"/>      <!-- Content: results | detail -->
            <RowDefinition Height="Auto"/>   <!-- Download progress -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0A0A0A" BorderBrush="#1E2E1E"
                BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Model Downloader"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBlock Foreground="{StaticResource Br.Text.Muted}" FontSize="11"
                               FontFamily="Segoe UI">
                        Search HuggingFace for GGUF models · curated catalog enriches results with role guidance
                    </TextBlock>
                </StackPanel>

                <!-- Search box + button -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#111111" BorderBrush="#2A3A2A" BorderThickness="1"
                            CornerRadius="4" Padding="8,0">
                        <TextBox x:Name="TxtSearch"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource Br.Text.White}"
                                 FontFamily="Segoe UI" FontSize="13"
                                 VerticalAlignment="Center" Height="32"
                                 KeyDown="TxtSearch_KeyDown"
                                 AutomationProperties.AutomationId="Downloader.SearchBox">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="HintBrush" TileMode="None"
                                                     Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Search models… (Enter to search)"
                                                           Foreground="#555555" FontFamily="Segoe UI"
                                                           FontSize="12"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <Button Grid.Column="1" x:Name="BtnSearch"
                            Content="Search" Margin="8,0,0,0"
                            Padding="14,7"
                            Background="{StaticResource Br.Accent.Green}"
                            Foreground="White" FontFamily="Segoe UI" FontSize="12"
                            BorderThickness="0"
                            Click="BtnSearch_Click"
                            AutomationProperties.AutomationId="Downloader.BtnSearch">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#5A9A00"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2A3A2A"/>
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Main content: Results list (left) | Detail pane (right) ──────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="260"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Results list ──────────────────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Status / count -->
                <Border Grid.Row="0" Background="#0D0D0D" Padding="10,5">
                    <DockPanel>
                        <TextBlock x:Name="TxtResultCount"
                                   DockPanel.Dock="Left"
                                   Text="Type to search"
                                   Foreground="{StaticResource Br.Text.Muted}"
                                   FontFamily="Segoe UI" FontSize="11"/>
                        <TextBlock x:Name="TxtSearchStatus"
                                   DockPanel.Dock="Right" HorizontalAlignment="Right"
                                   Text=""
                                   Foreground="{StaticResource Br.Accent.Green}"
                                   FontFamily="Segoe UI" FontSize="11"/>
                    </DockPanel>
                </Border>

                <!-- Result cards -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ResultsPanel" Margin="6">
                        <!-- Populated in code-behind -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5"
                          Background="#1A1A1A" ResizeBehavior="PreviousAndNext"/>

            <!-- ── Detail pane ────────────────────────────────────────────── -->
            <Grid Grid.Column="2">
                <!-- Placeholder when nothing is selected -->
                <Border x:Name="PanelNoSelection"
                        Background="#080808" Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⬡" Foreground="#1A3A1A"
                                   FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Select a model to see details"
                                   Foreground="{StaticResource Br.Text.Muted}"
                                   FontFamily="Segoe UI" FontSize="13"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Search above · Press Enter to find models"
                                   Foreground="#333333" FontFamily="Segoe UI" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Detail view (shown when a model is selected) -->
                <ScrollViewer x:Name="PanelDetail"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed"
                              Background="#080808">
                    <StackPanel Margin="20,16">

                        <!-- Model name + badges -->
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <!-- Curated badge -->
                                <Border x:Name="BdrCuratedBadge"
                                        Background="#1A3A1A" CornerRadius="3"
                                        Padding="5,2" Margin="0,0,6,0"
                                        Visibility="Collapsed">
                                    <TextBlock Text="⬡ CURATED" Foreground="{StaticResource Br.Accent.Green}"
                                               FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                                </Border>
                                <!-- Swarm capable badge -->
                                <Border x:Name="BdrSwarmBadge"
                                        Background="#1A2A3A" CornerRadius="3"
                                        Padding="5,2" Margin="0,0,6,0"
                                        Visibility="Collapsed">
                                    <TextBlock Text="🐝 SWARM READY" Foreground="#4A9FD9"
                                               FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                                </Border>
                            </StackPanel>

                            <TextBlock x:Name="TxtDetailName"
                                       Foreground="{StaticResource Br.Text.White}"
                                       FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtDetailPublisher"
                                       Foreground="{StaticResource Br.Text.Muted}"
                                       FontSize="12" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Quick stats row -->
                        <WrapPanel Margin="0,0,0,16" x:Name="WpDetailStats">
                            <!-- Populated in code-behind -->
                        </WrapPanel>

                        <!-- Description -->
                        <TextBlock x:Name="TxtDetailDesc"
                                   Foreground="{StaticResource Br.Text.White}"
                                   FontFamily="Segoe UI" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,12"
                                   LineHeight="20"/>

                        <!-- Intended use -->
                        <Border x:Name="BdrIntendedUse"
                                Background="#0D1A0D" BorderBrush="#1A3A1A" BorderThickness="1"
                                CornerRadius="4" Padding="12,8" Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="INTENDED USE" Foreground="{StaticResource Br.Accent.Green}"
                                           FontSize="9" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtIntendedUse"
                                           Foreground="{StaticResource Br.Text.White}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           TextWrapping="Wrap" LineHeight="19"/>
                            </StackPanel>
                        </Border>

                        <!-- Tool use notes -->
                        <Border x:Name="BdrToolUse"
                                Background="#1A1400" BorderBrush="#3A2800" BorderThickness="1"
                                CornerRadius="4" Padding="12,8" Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="TOOL USE / FUNCTION CALLING" Foreground="#FFB300"
                                           FontSize="9" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtToolUse"
                                           Foreground="{StaticResource Br.Text.White}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           TextWrapping="Wrap" LineHeight="19"/>
                            </StackPanel>
                        </Border>

                        <!-- Swarm role recommendations -->
                        <StackPanel x:Name="SpSwarmRoles"
                                    Orientation="Horizontal" Margin="0,0,0,16"
                                    Visibility="Collapsed">
                            <TextBlock Text="Swarm roles:"
                                       Foreground="{StaticResource Br.Text.Muted}"
                                       FontFamily="Segoe UI" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <!-- Role chips added in code-behind -->
                        </StackPanel>

                        <!-- ── Quantization variants ───────────────────── -->
                        <Border Background="#0D0D0D" BorderBrush="#1A2A1A" BorderThickness="1"
                                CornerRadius="4" Margin="0,0,0,16">
                            <StackPanel>
                                <Border Background="#111111" Padding="12,8">
                                    <DockPanel>
                                        <TextBlock Text="QUANTIZATION OPTIONS"
                                                   DockPanel.Dock="Left"
                                                   Foreground="{StaticResource Br.Accent.Green}"
                                                   FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="TxtVariantLoadStatus"
                                                   DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   Text="Loading…"
                                                   Foreground="{StaticResource Br.Text.Muted}"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </DockPanel>
                                </Border>
                                <StackPanel x:Name="SpVariants" Margin="0"/>
                            </StackPanel>
                        </Border>

                        <!-- Role assignment -->
                        <Border Background="#0D0D0D" BorderBrush="#1A1A2A" BorderThickness="1"
                                CornerRadius="4" Padding="12,10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="ASSIGN ROLE AFTER DOWNLOAD"
                                           Foreground="{StaticResource Br.Text.Muted}"
                                           FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"
                                           Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="RbRoleWorker"   Content="Worker · Coder"
                                                 Foreground="#4ACA4A" FontFamily="Segoe UI" FontSize="12"
                                                 GroupName="DownloadRole" Margin="0,0,16,0" IsChecked="True"/>
                                    <RadioButton x:Name="RbRoleBoss"     Content="Boss · Orchestrator"
                                                 Foreground="#FFB300" FontFamily="Segoe UI" FontSize="12"
                                                 GroupName="DownloadRole" Margin="0,0,16,0"/>
                                    <RadioButton x:Name="RbRoleResearcher" Content="Researcher"
                                                 Foreground="#4A9FD9" FontFamily="Segoe UI" FontSize="12"
                                                 GroupName="DownloadRole" Margin="0,0,16,0"/>
                                    <RadioButton x:Name="RbRoleLibrary"  Content="Library only"
                                                 Foreground="{StaticResource Br.Text.Muted}"
                                                 FontFamily="Segoe UI" FontSize="12"
                                                 GroupName="DownloadRole"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Button x:Name="BtnDownloadGguf"
                                    Content="⬇  Download GGUF"
                                    Padding="16,9"
                                    Background="{StaticResource Br.Accent.Green}"
                                    Foreground="White"
                                    FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Margin="0,0,10,0"
                                    IsEnabled="False"
                                    Click="BtnDownloadGguf_Click"
                                    AutomationProperties.AutomationId="Downloader.BtnDownload">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#5A9A00"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bd" Property="Background" Value="#1A2A1A"/>
                                                            <Setter Property="Foreground" Value="#444444"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="BtnOllamaPull"
                                    Content="🦙  Ollama Pull"
                                    Padding="14,9"
                                    Background="#1A1A3A" Foreground="#4A9FD9"
                                    FontFamily="Segoe UI" FontSize="13"
                                    BorderBrush="#2A2A5A" BorderThickness="1"
                                    IsEnabled="False"
                                    Click="BtnOllamaPull_Click"
                                    AutomationProperties.AutomationId="Downloader.BtnOllamaPull">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bd" Property="Background" Value="#111111"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#1A1A2A"/>
                                                            <Setter Property="Foreground" Value="#333333"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ── Download progress (hidden until download starts) ─────────────── -->
        <Border x:Name="PanelDownloadProgress"
                Grid.Row="2"
                Background="#0D1A0D" BorderBrush="#1E3E1E" BorderThickness="0,1,0,0"
                Padding="16,10"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock x:Name="TxtDlFileName"
                               DockPanel.Dock="Left"
                               Foreground="{StaticResource Br.Text.White}"
                               FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtDlStats"
                               DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource Br.Accent.Green}"
                               FontFamily="Consolas" FontSize="11"/>
                </DockPanel>

                <ProgressBar Grid.Row="1" x:Name="PbDownload"
                             Height="5" Minimum="0" Maximum="100"
                             Foreground="{StaticResource Br.Accent.Green}"
                             Background="#1A1A1A" BorderThickness="0"
                             Margin="0,0,0,6"/>

                <DockPanel Grid.Row="2">
                    <TextBlock x:Name="TxtDlStatus"
                               DockPanel.Dock="Left"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontFamily="Segoe UI" FontSize="11"/>
                    <Button x:Name="BtnCancelDownload"
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Content="✕ Cancel"
                            Padding="10,3"
                            Background="#2A0A0A" Foreground="#F44747"
                            BorderBrush="#4A1A1A" BorderThickness="1"
                            FontFamily="Segoe UI" FontSize="11"
                            Click="BtnCancelDownload_Click"/>
                </DockPanel>
            </Grid>
        </Border>

        <!-- ── Status bar ────────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#060606" BorderBrush="#111111"
                BorderThickness="0,1,0,0" Padding="12,4">
            <DockPanel>
                <TextBlock x:Name="TxtWindowStatus"
                           DockPanel.Dock="Left"
                           Text="Ready — enter a search query and press Enter"
                           Foreground="{StaticResource Br.Text.Muted}"
                           FontFamily="Segoe UI" FontSize="11"/>
                <TextBlock x:Name="TxtHardwareSummary"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"
                           Foreground="{StaticResource Br.Accent.Green}"
                           FontFamily="Segoe UI" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
