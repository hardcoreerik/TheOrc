<Window x:Class="OrchestratorIDE.UI.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TheOrc — Personalize Your Agent"
        Width="580" Height="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#161616"
        Foreground="#D4D4D4"
        FontFamily="Consolas, 'Cascadia Code', monospace">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="FontFamily" Value="Consolas, 'Cascadia Code', monospace"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#252525"/>
            <Setter Property="Foreground"  Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#2E3A2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="6,5"/>
            <Setter Property="FontFamily"  Value="Consolas, 'Cascadia Code', monospace"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="CaretBrush" Value="#76B900"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"  Value="#252525"/>
            <Setter Property="Foreground"  Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#2E3A2E"/>
            <Setter Property="Padding"     Value="14,7"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="FontFamily"  Value="Consolas, 'Cascadia Code', monospace"/>
            <Setter Property="FontSize"    Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Header — TheOrc brand strip -->
        <Border DockPanel.Dock="Top" Background="#0E0E0E"
                BorderBrush="#2A3A2A" BorderThickness="0,0,0,1">
            <!-- Left NVIDIA-green accent stripe -->
            <DockPanel>
                <Border DockPanel.Dock="Left" Width="4" Background="#76B900"/>
                <StackPanel Margin="16,14,16,14">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="⬡" Foreground="#76B900" FontSize="20"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="TheOrc" Foreground="#FFFFFF"
                                   FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  Personalize Your Agent"
                                   Foreground="#7A8A6A" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock FontSize="10" Foreground="#5A6A4A"
                               Text="Hardware and profile pre-filled. Add your name and any context the agent should always know."/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom" Background="#0E0E0E"
                BorderBrush="#2A3A2A" BorderThickness="0,1,0,0"
                Padding="20,12">
            <DockPanel>
                <Button x:Name="BtnSkip" DockPanel.Dock="Left"
                        Content="Skip for now"
                        Background="Transparent" BorderBrush="#2E3A2E"
                        Foreground="#7A8A6A" Click="BtnSkip_Click"/>
                <Button x:Name="BtnSave" DockPanel.Dock="Right"
                        Content="✓  Save &amp; Start"
                        Background="#2A5200" BorderBrush="#3A7000"
                        Foreground="#76B900" FontWeight="Bold"
                        Click="BtnSave_Click"/>
            </DockPanel>
        </Border>

        <!-- Body -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,16,20,16">

                <!-- Name / Handle -->
                <TextBlock Text="Your name or handle" FontSize="11"
                           Foreground="#7A8A6A" Margin="0,0,0,4"/>
                <TextBox x:Name="TbName" FontSize="13"
                         AutomationProperties.AutomationId="FirstRun.Name"/>

                <!-- Detected hardware (read-only display) -->
                <Border Background="#141814" CornerRadius="4"
                        BorderBrush="#2E3A2E" BorderThickness="1"
                        Padding="12,10" Margin="0,16,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⬡" Foreground="#76B900" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="DETECTED SYSTEM" FontSize="10" FontWeight="Bold"
                                       Foreground="#76B900"/>
                        </StackPanel>
                        <TextBlock x:Name="TbHardwareSummary"
                                   FontSize="11" Foreground="#A8CC80"
                                   TextWrapping="Wrap" LineHeight="18"/>
                    </StackPanel>
                </Border>

                <!-- ── Trust Level ─────────────────────────────────────────── -->
                <TextBlock Text="Default trust level" FontSize="11"
                           Foreground="#7A8A6A" Margin="0,20,0,4"/>
                <TextBlock FontSize="10" Foreground="#4A5A3A" TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Text="How much the agent can do without your explicit approval. You can change this any time from the toolbar."/>

                <!-- 4 trust pills -->
                <WrapPanel>
                    <Button x:Name="BtnTrustPlan" Content="📋  Plan" Tag="Plan"
                            Click="BtnTrustPill_Click" Margin="0,0,6,0"
                            ToolTip="Read-only planning mode — no file writes or shell commands.">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TrustPillStyle}"/>
                        </Button.Style>
                    </Button>
                    <Button x:Name="BtnTrustGuarded" Content="🛡  Guarded" Tag="Guarded"
                            Click="BtnTrustPill_Click" Margin="0,0,6,0"
                            ToolTip="Every file write and shell command requires your explicit approval. (Recommended for new users)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TrustPillStyle}"/>
                        </Button.Style>
                    </Button>
                    <Button x:Name="BtnTrustStandard" Content="⚡  Standard" Tag="Standard"
                            Click="BtnTrustPill_Click" Margin="0,0,6,0"
                            ToolTip="File writes are auto-approved; shell commands still prompt.">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TrustPillStyle}"/>
                        </Button.Style>
                    </Button>
                    <Button x:Name="BtnTrustFullAuto" Content="🔓  Full Auto" Tag="FullAuto"
                            Click="BtnTrustPill_Click"
                            ToolTip="All tool calls auto-approved — no prompts. Use only in trusted, sandboxed environments.">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TrustPillStyle}"/>
                        </Button.Style>
                    </Button>
                </WrapPanel>

                <!-- Description for selected tier -->
                <TextBlock x:Name="TbTrustDesc"
                           FontSize="10" Foreground="#5A7A40" TextWrapping="Wrap"
                           Margin="0,6,0,0"/>

                <!-- ── Swarm capability hint ───────────────────────────────── -->
                <Border x:Name="BdrSwarmHint"
                        Background="#0E1A1E" BorderBrush="#1A4A60"
                        BorderThickness="1" CornerRadius="4"
                        Padding="12,10" Margin="0,16,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="⬡" Foreground="#4FC3F7" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="SWARM MODE AVAILABLE" FontSize="10"
                                       FontWeight="Bold" Foreground="#4FC3F7"/>
                        </StackPanel>
                        <TextBlock FontSize="10" Foreground="#7AB8CC" TextWrapping="Wrap"
                                   LineHeight="18"
                                   Text="A Nemotron model was detected on this machine. TheOrc can orchestrate a swarm of specialist agents — Researcher, Coder, and UI Developer — to tackle complex tasks in parallel. Switch to Swarm mode from the toolbar at any time."/>
                    </StackPanel>
                </Border>

                <!-- Extra context -->
                <TextBlock Text="Additional context  (optional)" FontSize="11"
                           Foreground="#7A8A6A" Margin="0,16,0,4"/>
                <TextBlock FontSize="10" Foreground="#4A5A3A" TextWrapping="Wrap"
                           Margin="0,0,0,6"
                           Text="Anything the agent should always know: your tools, your environment, your preferred workflows, cleared scope for security work, etc."/>
                <TextBox x:Name="TbExtra"
                         Height="90" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         AutomationProperties.AutomationId="FirstRun.Extra"
                         TextChanged="TbExtra_TextChanged"/>

                <!-- Preview -->
                <TextBlock Text="PREVIEW — .agent.md header" FontSize="10" FontWeight="Bold"
                           Foreground="#76B900" Margin="0,20,0,6"/>
                <Border Background="#0A0A0A" CornerRadius="4"
                        BorderBrush="#2E3A2E" BorderThickness="1"
                        Padding="10,8">
                    <TextBox x:Name="TbPreview"
                             IsReadOnly="True" Background="Transparent"
                             BorderThickness="0"
                             Foreground="#76B900" FontSize="11"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Height="160"
                             AutomationProperties.AutomationId="FirstRun.Preview"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
