<UserControl x:Class="OrchestratorIDE.UI.Controls.UnknownToolCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Br.Bg.App}">

    <!--
    ═══════════════════════════════════════════════════════════════
    UNKNOWN TOOL CARD  — Layer 2
    Shown in the diff panel slot when the agent calls a tool that
    isn't registered.

    ┌────────────────────────────────────────────────────────────┐
    │ ⚠  Unknown Tool Called                                     │
    ├────────────────────────────────────────────────────────────┤
    │  The agent called:  create_project(...)                    │
    │                                                            │
    │  project_type = "Windows Forms App"                        │
    │  project_name = "SimpleCalculator"                         │
    │                                                            │
    │  This tool doesn't exist. Choose how to proceed:          │
    ├────────────────────────────────────────────────────────────┤
    │  [↩ Auto-translate]  [⊘ Skip]  [🔧 Implement it…]         │
    └────────────────────────────────────────────────────────────┘
    ═══════════════════════════════════════════════════════════════
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>    <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Body -->
            <RowDefinition Height="Auto"/>  <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#3A2800"
                BorderBrush="#664400" BorderThickness="0,0,0,1">
            <DockPanel Margin="10,0">
                <TextBlock Text="⚠" Foreground="#CCA700"
                           FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Unknown Tool Called"
                           Foreground="#CCA700" FontWeight="SemiBold"
                           FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="TbToolName"
                           DockPanel.Dock="Right"
                           Foreground="#888" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
            </DockPanel>
        </Border>

        <!-- ── Body ───────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12,10">

                <!-- What the agent tried to call -->
                <TextBlock Text="The agent tried to call:"
                           Foreground="{StaticResource Br.Text.Muted}"
                           FontSize="11" Margin="0,0,0,4"/>

                <Border Background="#1A1A1A" BorderBrush="#444"
                        BorderThickness="1" CornerRadius="3" Padding="10,8"
                        Margin="0,0,0,10">
                    <TextBlock x:Name="TbCallPreview"
                               FontFamily="Consolas, Courier New" FontSize="12"
                               Foreground="#D69D85" TextWrapping="Wrap"/>
                </Border>

                <!-- Arguments -->
                <TextBlock x:Name="TbArgsHeader"
                           Text="Arguments:"
                           Foreground="{StaticResource Br.Text.Muted}"
                           FontSize="11" Margin="0,0,0,4"/>
                <Border x:Name="ArgsBox"
                        Background="#1A1A1A" BorderBrush="#444"
                        BorderThickness="1" CornerRadius="3" Padding="10,8"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="TbArgs"
                               FontFamily="Consolas, Courier New" FontSize="12"
                               Foreground="#D4D4D4" TextWrapping="Wrap"/>
                </Border>

                <!-- Explanation -->
                <TextBlock Text="This tool isn't registered. Choose how to proceed:"
                           Foreground="{StaticResource Br.Text.Muted}"
                           FontSize="11" Margin="0,0,0,4"/>

                <!-- Button explanations -->
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="↩" Foreground="#4EC9B0" FontSize="12" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="6,0,0,6" FontSize="11" Foreground="#CCCCCC" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold" Foreground="#4EC9B0">Auto-translate</Run>
                        <Run> — feed the agent a rich error message listing available tools and a hint. The agent self-corrects on the next step.</Run>
                    </TextBlock>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="⊘" Foreground="#888" FontSize="12" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="6,0,0,6" FontSize="11" Foreground="#CCCCCC" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold" Foreground="#888888">Skip</Run>
                        <Run> — tell the agent this call was skipped and let it continue. Use when the tool call was noise.</Run>
                    </TextBlock>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="🔧" FontSize="11" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="6,0,0,0" FontSize="11" Foreground="#CCCCCC" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold" Foreground="#569CD6">Implement it</Run>
                        <Run> — open the tool editor to write a real handler for this tool (Phase 6 — coming soon).</Run>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Action buttons ─────────────────────────────────── -->
        <Border Grid.Row="2" Background="#2D2D2D"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0"
                Padding="10,8">
            <DockPanel>
                <!-- Implement it (stub — Layer 3) -->
                <Button x:Name="BtnImplement"
                        DockPanel.Dock="Right"
                        Content="🔧  Implement it…"
                        Width="130" Margin="0,0,0,0"
                        Background="#1A2A3A" Foreground="#569CD6"
                        BorderBrush="#2A4A6A"
                        Click="BtnImplement_Click"
                        ToolTip="Open tool editor — Phase 6"/>

                <!-- Skip -->
                <Button x:Name="BtnSkip"
                        DockPanel.Dock="Right"
                        Content="⊘  Skip"
                        Width="80" Margin="0,0,8,0"
                        Background="#2D2D2D" Foreground="#888888"
                        BorderBrush="#555"
                        Click="BtnSkip_Click"
                        ToolTip="Tell the agent this call was skipped"/>

                <!-- Auto-translate (primary) -->
                <Button x:Name="BtnAutoTranslate"
                        Content="↩  Auto-translate"
                        Width="130" Margin="0,0,8,0"
                        Background="#1A3A2A" Foreground="#4EC9B0"
                        BorderBrush="#2A5A3A"
                        Click="BtnAutoTranslate_Click"
                        ToolTip="Feed a rich error to the agent so it self-corrects"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
