<Window x:Class="OrchestratorIDE.UI.Controls.UserInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Question"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="#CCCCCC"
        BorderBrush="#3C3C3C"
        BorderThickness="1"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="18,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Agent icon + header -->
        <DockPanel Margin="0,0,0,12">
            <TextBlock Text="⚡" FontSize="18" VerticalAlignment="Top"
                       Margin="0,2,10,0" Foreground="#569CD6"/>
            <StackPanel>
                <TextBlock Text="The agent needs your input to continue"
                           Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
                <TextBlock x:Name="TbQuestion"
                           Text=""
                           Foreground="#D4D4D4"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           AutomationProperties.AutomationId="UserInputDialog.Question"/>
            </StackPanel>
        </DockPanel>

        <!-- Input field -->
        <TextBox x:Name="TbAnswer"
                 Margin="0,0,0,16"
                 Padding="8,6"
                 FontFamily="Consolas, 'Cascadia Code', monospace"
                 FontSize="13"
                 Background="#2D2D2D"
                 Foreground="#D4D4D4"
                 BorderBrush="#569CD6"
                 BorderThickness="1"
                 CaretBrush="#D4D4D4"
                 SelectionBrush="#264F78"
                 AutomationProperties.AutomationId="UserInputDialog.Answer"
                 TextChanged="TbAnswer_TextChanged"/>

        <!-- Hint (shown when options are hinted in the question) -->
        <TextBlock x:Name="TbHint"
                   Text=""
                   Foreground="#555555"
                   FontSize="10"
                   Margin="0,-10,0,14"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancel" Content="Cancel"
                    Background="#2D2D2D" Foreground="#888888"
                    BorderBrush="#444444"
                    Margin="0,0,8,0"
                    AutomationProperties.AutomationId="UserInputDialog.Cancel"
                    Click="BtnCancel_Click"/>
            <Button x:Name="BtnOk" Content="Send to Agent"
                    Background="#0E639C" Foreground="White"
                    BorderBrush="#1177BB"
                    IsDefault="True"
                    AutomationProperties.AutomationId="UserInputDialog.Ok"
                    Click="BtnOk_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
