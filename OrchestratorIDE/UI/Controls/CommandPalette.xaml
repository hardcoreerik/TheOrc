<UserControl x:Class="OrchestratorIDE.UI.Controls.CommandPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="540"
             Background="Transparent"
             KeyDown="OnKeyDown">

    <Border Background="{StaticResource Br.Bg.Panel}"
            BorderBrush="{StaticResource Br.Border}"
            BorderThickness="1" CornerRadius="4">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.6" BlurRadius="24" ShadowDepth="4"/>
        </Border.Effect>

        <DockPanel>
            <!-- Search input -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource Br.Bg.Input}"
                    BorderBrush="{StaticResource Br.Border}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text=">" Foreground="{StaticResource Br.Accent.Blue}"
                               FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBox x:Name="SearchBox"
                             Margin="28,0,8,0"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource Br.Text.Primary}"
                             FontFamily="Consolas, 'Cascadia Code', monospace"
                             FontSize="14" Padding="0,10"
                             CaretBrush="{StaticResource Br.Text.Primary}"
                             AutomationProperties.AutomationId="CommandPalette.Search"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown"/>
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="Type a command…"
                               Foreground="#555" FontSize="13"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="30,0,0,0"/>
                </Grid>
            </Border>

            <!-- Results list -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource Br.Bg.Panel}"
                    Padding="4,2">
                <TextBlock x:Name="TbHint"
                           Text="↑↓ navigate  ·  Enter select  ·  Esc close"
                           Foreground="#444" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,2"/>
            </Border>

            <ListBox x:Name="ResultsList"
                     Background="Transparent" BorderBrush="Transparent"
                     MaxHeight="320"
                     AutomationProperties.AutomationId="CommandPalette.Results"
                     SelectionChanged="ResultsList_SelectionChanged"
                     MouseDoubleClick="ResultsList_DoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,7"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource Br.Text.Primary}"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Br.Bg.Hover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource Br.Bg.Active}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                       FontSize="13" VerticalAlignment="Center"
                                       Foreground="{Binding IconColor}"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Label}"
                                           FontSize="12" FontWeight="{Binding LabelWeight}"/>
                                <TextBlock Text="{Binding Detail}"
                                           FontSize="10" Foreground="{StaticResource Br.Text.Muted}"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Shortcut}"
                                       Foreground="#555" FontSize="10"
                                       VerticalAlignment="Center" Margin="8,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
