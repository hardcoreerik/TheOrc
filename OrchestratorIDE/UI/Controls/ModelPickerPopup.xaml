<UserControl x:Class="OrchestratorIDE.UI.Controls.ModelPickerPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="460" MaxHeight="420"
             Background="{StaticResource Br.Bg.Panel}"
             BorderBrush="{StaticResource Br.Border}"
             KeyDown="OnKeyDown">

    <Border BorderBrush="{StaticResource Br.Border}" BorderThickness="1"
            Background="{StaticResource Br.Bg.Panel}">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="#2D2D2D"
                    BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,0,1"
                    Padding="12,8">
                <DockPanel>
                    <TextBlock Text="SELECT MODEL" Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" x:Name="TbInstalled"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="10" VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>

            <!-- Model list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ModelList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemBorder"
                                    BorderBrush="{StaticResource Br.Border}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,8" Cursor="Hand"
                                    MouseLeftButtonDown="Model_Click"
                                    Background="{Binding RowBg}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>  <!-- Active dot -->
                                        <ColumnDefinition Width="*"/>   <!-- Info -->
                                        <ColumnDefinition Width="Auto"/> <!-- Badges -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Active indicator -->
                                    <TextBlock Grid.Column="0" Text="{Binding ActiveDot}"
                                               Foreground="{StaticResource Br.Accent.Green}"
                                               VerticalAlignment="Top" Margin="0,2,0,0"
                                               FontSize="10"/>

                                    <!-- Model info -->
                                    <StackPanel Grid.Column="1" Margin="6,0,8,0">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{Binding NameColor}"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{StaticResource Br.Text.Muted}"
                                                   FontSize="10" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding ModelId}"
                                                   Foreground="#555" FontSize="9"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>

                                    <!-- Badges: context + toolset -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                        <Border Background="{StaticResource Br.Bg.Input}"
                                                CornerRadius="3" Padding="4,1" Margin="0,0,0,3">
                                            <TextBlock Text="{Binding ContextBadge}"
                                                       Foreground="{StaticResource Br.Accent.Blue}"
                                                       FontSize="9" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Border Background="{StaticResource Br.Bg.Input}"
                                                CornerRadius="3" Padding="4,1">
                                            <TextBlock Text="{Binding ToolSetBadge}"
                                                       Foreground="{StaticResource Br.Warning}"
                                                       FontSize="9" HorizontalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>
