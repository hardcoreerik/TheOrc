<UserControl x:Class="OrchestratorIDE.UI.Controls.DiffViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Br.Bg.App}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>  <!-- Header bar -->
            <RowDefinition Height="*"/>   <!-- Diff content -->
            <RowDefinition Height="Auto"/> <!-- Reason + buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D2D"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">
                <TextBlock x:Name="TbFilePath"
                           Text="file.cs" FontWeight="SemiBold"
                           VerticalAlignment="Center" FontSize="12"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="TbStats" Text=""
                               Foreground="{StaticResource Br.Text.Muted}"
                               VerticalAlignment="Center" FontSize="11" Margin="0,0,12,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Diff lines -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <ItemsControl x:Name="DiffLines">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>   <!-- Old line# -->
                                <ColumnDefinition Width="40"/>   <!-- New line# -->
                                <ColumnDefinition Width="12"/>   <!-- +/- gutter -->
                                <ColumnDefinition Width="*"/>    <!-- Content -->
                            </Grid.ColumnDefinitions>

                            <!-- Row background tint -->
                            <Grid.Background>
                                <SolidColorBrush Color="{Binding RowColor}"/>
                            </Grid.Background>

                            <TextBlock Grid.Column="0" Text="{Binding OldLineNum}"
                                       Foreground="#555" FontFamily="Consolas" FontSize="11"
                                       HorizontalAlignment="Right" Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding NewLineNum}"
                                       Foreground="#555" FontFamily="Consolas" FontSize="11"
                                       HorizontalAlignment="Right" Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Gutter}"
                                       Foreground="{Binding GutterColor}" FontFamily="Consolas" FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding Text}"
                                       Foreground="{Binding TextColor}" FontFamily="Consolas" FontSize="12"
                                       TextWrapping="NoWrap" Padding="4,1"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Reason + action buttons -->
        <Border Grid.Row="2" Background="#2D2D2D"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0"
                Padding="8,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnReject" Content="✗  Reject" Width="90"
                            Background="#3A1A1A" Foreground="#F44747"
                            BorderBrush="#5A2A2A" Margin="0,0,8,0"
                            Click="BtnReject_Click"/>
                    <Button x:Name="BtnApprove" Content="✓  Apply" Width="90"
                            Background="#1A3A1A" Foreground="#4EC9B0"
                            BorderBrush="#2A5A2A"
                            Click="BtnApprove_Click"/>
                </StackPanel>
                <TextBlock x:Name="TbReason" Text="" Foreground="{StaticResource Br.Text.Muted}"
                           FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"
                           Margin="0,0,12,0"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
