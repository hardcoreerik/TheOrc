<Window x:Class="OrchestratorIDE.UI.Dialogs.SandboxBypassDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sandbox Escape Detected"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1A1A"
        Foreground="#CCCCCC"
        BorderBrush="#4A3800"
        BorderThickness="1"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="Foreground"  Value="#666666"/>
            <Setter Property="Margin"      Value="0,8,0,2"/>
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBox">
            <Setter Property="FontFamily"     Value="Consolas"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="Background"     Value="#111111"/>
            <Setter Property="Foreground"     Value="#D4D4D4"/>
            <Setter Property="BorderBrush"    Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"        Value="6,4"/>
            <Setter Property="IsReadOnly"     Value="True"/>
            <Setter Property="TextWrapping"   Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
        </Style>
    </Window.Resources>

    <StackPanel>

        <!-- ── Amber warning banner ────────────────────────────── -->
        <Border Background="#1C1400" BorderBrush="#C08000" BorderThickness="0,0,0,2"
                Padding="16,12">
            <DockPanel>
                <TextBlock Text="🔒" FontSize="28" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="SANDBOX ESCAPE DETECTED"
                               Foreground="#F0C060" FontSize="13" FontWeight="Bold"
                               FontFamily="Consolas"/>
                    <TextBlock x:Name="TbSubtitle"
                               Foreground="#AA8840" FontSize="11" FontFamily="Consolas"
                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Detail fields ───────────────────────────────────── -->
        <StackPanel Margin="16,10,16,0">

            <TextBlock Text="An agent is trying to access a path OUTSIDE the workspace sandbox."
                       Foreground="#BBBBBB" FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,6"/>
            <TextBlock Text="This may be intentional (e.g. writing a global config) or may indicate prompt injection / a runaway agent."
                       Foreground="#666666" FontSize="10" TextWrapping="Wrap"
                       Margin="0,0,0,2"/>

            <TextBlock Text="TOOL" Style="{StaticResource FieldLabel}"/>
            <TextBox   x:Name="TbTool" Style="{StaticResource FieldValue}"/>

            <TextBlock Text="AGENT" Style="{StaticResource FieldLabel}"/>
            <TextBox   x:Name="TbAgent" Style="{StaticResource FieldValue}"/>

            <TextBlock Text="SANDBOX ROOT  (safe zone)" Style="{StaticResource FieldLabel}"/>
            <TextBox   x:Name="TbSandboxRoot" Style="{StaticResource FieldValue}"
                       Foreground="#76B900"/>

            <TextBlock Text="TARGET PATH  (outside sandbox ⚠)" Style="{StaticResource FieldLabel}"/>
            <TextBox   x:Name="TbTargetPath" Style="{StaticResource FieldValue}"
                       Foreground="#F0C060"/>

        </StackPanel>

        <!-- ── Risk note ────────────────────────────────────────── -->
        <Border Margin="16,12,16,0" Background="#120C00" BorderBrush="#3A2800"
                BorderThickness="1" CornerRadius="3" Padding="10,8">
            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                       Foreground="#887744"
                       Text="Allowing once lets this single operation proceed.  Future escapes will ask again.  Denying feeds an error back to the agent so it can try a path inside the workspace instead."/>
        </Border>

        <!-- ── Buttons ──────────────────────────────────────────── -->
        <DockPanel Margin="16,14,16,16">
            <Button x:Name="BtnDeny"
                    DockPanel.Dock="Right"
                    Content="🚫  Deny"
                    Background="#2A0000" Foreground="#F44747"
                    BorderBrush="#6A1010"
                    IsCancel="True"
                    Click="BtnDeny_Click"/>
            <Button x:Name="BtnAllow"
                    DockPanel.Dock="Right"
                    Content="⚠  Allow Once"
                    Background="#1C1400" Foreground="#F0C060"
                    BorderBrush="#6A5010"
                    Margin="0,0,8,0"
                    Click="BtnAllow_Click"/>
            <TextBlock VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="9"
                       Foreground="#444444"
                       Text="Esc = Deny"/>
        </DockPanel>

    </StackPanel>
</Window>
