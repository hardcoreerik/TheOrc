<Window x:Class="OrchestratorIDE.UI.Dialogs.WorkspaceRulesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workspace Rules"
        Width="720" Height="540"
        MinWidth="540" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="#161616"
        Foreground="#D4D4D4"
        FontFamily="Consolas, 'Cascadia Code', monospace">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="FontFamily" Value="Consolas, 'Cascadia Code', monospace"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"    Value="#3C3C3C"/>
            <Setter Property="Foreground"    Value="#CCCCCC"/>
            <Setter Property="BorderBrush"   Value="#474747"/>
            <Setter Property="Padding"       Value="14,6"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FontFamily"    Value="Consolas, 'Cascadia Code', monospace"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground"    Value="#CCCCCC"/>
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Padding"       Value="10,8"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#264F78"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#141814"
                BorderBrush="#474747" BorderThickness="0,0,0,1"
                Padding="18,14">
            <StackPanel>
                <TextBlock Text="📝  Workspace Rules" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="TbWorkspacePath" Text="No workspace open"
                           Foreground="#888" FontSize="10" Margin="0,4,0,0"/>
                <TextBlock x:Name="TbCurrentStatus" Text=""
                           Foreground="#4EC9B0" FontSize="10" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom" Background="#141814"
                BorderBrush="#474747" BorderThickness="0,1,0,0"
                Padding="12,10">
            <DockPanel>
                <Button x:Name="BtnEditExisting" Content="✏  Edit existing rules"
                        DockPanel.Dock="Left" Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Background="#1E3A1E" Foreground="#4EC9B0" BorderBrush="#2D5A2D"
                        Click="BtnEditExisting_Click"/>
                <Button x:Name="BtnOpenBlank" Content="+ Blank .agent.md"
                        DockPanel.Dock="Left"
                        Background="#141814" Foreground="#888"
                        Click="BtnOpenBlank_Click"/>
                <Button x:Name="BtnApply" Content="Apply preset →"
                        DockPanel.Dock="Right"
                        Background="#2A5200" Foreground="#76B900" BorderBrush="#3A7000"
                        FontWeight="SemiBold" IsEnabled="False"
                        Click="BtnApply_Click"/>
                <Button Content="Cancel" DockPanel.Dock="Right"
                        Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>
            </DockPanel>
        </Border>

        <!-- Body: preset list + preview -->
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Preset list -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="PRESETS"
                           FontSize="10" Foreground="#888" FontWeight="Bold"
                           Margin="12,10,0,6"/>
                <ListBox x:Name="PresetList"
                         Background="#141814"
                         BorderThickness="0"
                         SelectionChanged="PresetList_SelectionChanged">
                    <!-- Items bound in code-behind -->
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#474747" Cursor="SizeWE"/>

            <!-- Preview pane -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="PREVIEW"
                           FontSize="10" Foreground="#888" FontWeight="Bold"
                           Margin="12,10,0,6"/>
                <TextBox x:Name="PreviewBox"
                         IsReadOnly="True"
                         Background="#1E1E1E"
                         Foreground="#D4D4D4"
                         BorderThickness="0"
                         Padding="12,8"
                         FontSize="11"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="← Select a preset to preview its content"/>
            </DockPanel>
        </Grid>

    </DockPanel>
</Window>
