<Window x:Class="OrchestratorIDE.UI.Dialogs.AgentBuilderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Builder"
        Width="900" Height="620" MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#161616"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Nav button style -->
        <Style x:Key="NavBtn" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8A9A7A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bdr" Background="Transparent"
                                BorderThickness="2,0,0,0" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bdr" Property="Background" Value="#1A2A0A"/>
                                <Setter TargetName="Bdr" Property="BorderBrush" Value="#76B900"/>
                                <Setter Property="Foreground" Value="#C8E0A0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bdr" Property="Background" Value="#1A2010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Preview TextBox style -->
        <Style x:Key="PreviewBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0E120E"/>
            <Setter Property="Foreground" Value="#C8D8B8"/>
            <Setter Property="BorderBrush" Value="#2E3A2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Courier New"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- Action button style -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A2A0A"/>
            <Setter Property="Foreground" Value="#76B900"/>
            <Setter Property="BorderBrush" Value="#2A4A0A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#223A10"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecBtn" TargetType="Button">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="Foreground" Value="#8A9A7A"/>
            <Setter Property="BorderBrush" Value="#2E3A2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#242424"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Body -->
            <RowDefinition Height="52"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── HEADER ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#141814"
                BorderBrush="#2E3A2E" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <!-- Left: brand + title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="3" Height="20" Background="#76B900"
                            CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="⚡" Foreground="#76B900" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <TextBlock Text="AGENT BUILDER"
                               Foreground="#76B900" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock x:Name="TbContextLabel"
                               Foreground="#5A6A4A" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: nav labels -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="AI Generate  ·  Presets  ·  Manual Edit"
                               Foreground="#3A4A3A" FontSize="10"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── BODY ────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="135"/>   <!-- Nav sidebar -->
                <ColumnDefinition Width="1"/>     <!-- Divider -->
                <ColumnDefinition Width="*"/>     <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- Nav sidebar -->
            <ListBox x:Name="NavList" Grid.Column="0"
                     Background="#141814"
                     BorderThickness="0"
                     SelectionMode="Single"
                     SelectionChanged="NavList_SelectionChanged"
                     Padding="0,8,0,0">
                <ListBoxItem Tag="ai" Style="{StaticResource NavBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" Margin="0,0,7,0" FontSize="13"/>
                        <TextBlock Text="AI Generate"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="presets" Style="{StaticResource NavBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" Margin="0,0,7,0" FontSize="13"/>
                        <TextBlock Text="Presets"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="manual" Style="{StaticResource NavBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✏" Margin="0,0,7,0" FontSize="13"/>
                        <TextBlock Text="Manual Edit"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <!-- Divider -->
            <Rectangle Grid.Column="1" Fill="#2E3A2E"/>

            <!-- ── Content area ────────────────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- ╔══════════════════════════════════════╗ -->
                <!-- ║  AI GENERATE PANEL                   ║ -->
                <!-- ╚══════════════════════════════════════╝ -->
                <Grid x:Name="PnlAI" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Hint label -->
                        <RowDefinition Height="80"/>     <!-- Description input -->
                        <RowDefinition Height="Auto"/>   <!-- Generate row -->
                        <RowDefinition Height="1"/>      <!-- Separator -->
                        <RowDefinition Height="*"/>      <!-- Preview -->
                        <RowDefinition Height="Auto"/>   <!-- Refine row (hidden until first gen) -->
                    </Grid.RowDefinitions>

                    <!-- Hint -->
                    <TextBlock Grid.Row="0"
                               Text="Describe your project, tech stack, and any special rules for the agent:"
                               Foreground="#5A6A4A" FontSize="11"
                               Margin="14,12,14,4"/>

                    <!-- Description TextBox -->
                    <TextBox Grid.Row="1"
                             x:Name="TbDescribe"
                             Background="#0E120E"
                             Foreground="#C8D8B8"
                             BorderBrush="#2E3A2E"
                             BorderThickness="1"
                             FontSize="12"
                             Padding="10,8"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="14,0,14,0"
                             KeyDown="TbDescribe_KeyDown"
                             ToolTip="e.g. Python web scraper using requests + BeautifulSoup, saves to SQLite. Handle errors gracefully and always show progress."/>

                    <!-- Generate / Stop row -->
                    <Grid Grid.Row="2" Margin="14,8,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnGenerate" Grid.Column="0"
                                Content="⚡  Generate"
                                Style="{StaticResource ActionBtn}"
                                Click="BtnGenerate_Click"
                                FontWeight="SemiBold"
                                Margin="0,0,8,0"/>

                        <Button x:Name="BtnStop" Grid.Column="1"
                                Content="⏹  Stop"
                                Style="{StaticResource SecBtn}"
                                Click="BtnStop_Click"
                                IsEnabled="False"
                                Margin="0,0,0,0"/>

                        <TextBlock x:Name="TbGeneratingStatus"
                                   Grid.Column="2"
                                   Text=""
                                   Foreground="#5A6A4A" FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <!-- Example prompts hint -->
                        <TextBlock Grid.Column="3"
                                   Text="Ctrl+Enter to generate"
                                   Foreground="#2E3A2E" FontSize="10"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Separator -->
                    <Rectangle Grid.Row="3" Fill="#1E2A1E"/>

                    <!-- Streaming preview -->
                    <Grid Grid.Row="4">
                        <TextBlock x:Name="TbAIHint"
                                   Text="Generated .agent.md will appear here…"
                                   Foreground="#2A3A2A" FontSize="11"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Visible"/>

                        <TextBox x:Name="TbPreviewAI"
                                 Style="{StaticResource PreviewBox}"
                                 Margin="0"
                                 IsReadOnly="False"
                                 TextChanged="TbPreviewAI_TextChanged"/>
                    </Grid>

                    <!-- Refine row (visible after first generation) -->
                    <Grid x:Name="PnlRefine" Grid.Row="5"
                          Visibility="Collapsed"
                          Background="#0A100A">
                        <Border BorderBrush="#1E2A1E" BorderThickness="0,1,0,0">
                            <Grid Margin="14,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TbRefine"
                                         Grid.Column="0"
                                         Background="#0E120E"
                                         Foreground="#C8D8B8"
                                         BorderBrush="#2E3A2E"
                                         BorderThickness="1"
                                         FontSize="11"
                                         Padding="8,6"
                                         ToolTip="e.g. Make it more focused on security, add Python type hints rule"
                                         KeyDown="TbRefine_KeyDown"/>
                                <!-- watermark -->
                                <TextBlock IsHitTestVisible="False"
                                           Text="Refine it: e.g. make it more security-focused…"
                                           Foreground="#2A3A2A" FontSize="11"
                                           FontStyle="Italic"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Panel.ZIndex="1">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=TbRefine}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button x:Name="BtnRefine" Grid.Column="1"
                                        Content="↩ Refine"
                                        Style="{StaticResource SecBtn}"
                                        Click="BtnRefine_Click"
                                        Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ╔══════════════════════════════════════╗ -->
                <!-- ║  PRESETS PANEL                       ║ -->
                <!-- ╚══════════════════════════════════════╝ -->
                <Grid x:Name="PnlPresets" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Preset list -->
                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="PRESETS" FontSize="10" FontWeight="Bold"
                                   Foreground="#5A6A4A"
                                   Margin="12,12,0,6"/>
                        <ListBox x:Name="PresetList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#8A9A7A"
                                 FontSize="12"
                                 SelectionChanged="PresetList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#8A9A7A"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bdr" Background="Transparent"
                                                        BorderThickness="2,0,0,0"
                                                        BorderBrush="Transparent"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bdr" Property="Background" Value="#1A2A0A"/>
                                                        <Setter TargetName="Bdr" Property="BorderBrush" Value="#76B900"/>
                                                        <Setter Property="Foreground" Value="#C8E0A0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bdr" Property="Background" Value="#141A10"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </DockPanel>

                    <Rectangle Grid.Column="1" Fill="#2E3A2E"/>

                    <!-- Preset preview -->
                    <DockPanel Grid.Column="2">
                        <TextBlock DockPanel.Dock="Top"
                                   x:Name="TbPresetDesc"
                                   Text="Select a preset to preview"
                                   Foreground="#5A6A4A" FontSize="11"
                                   Margin="12,12,12,6"/>
                        <TextBox DockPanel.Dock="Bottom"
                                 x:Name="TbPreviewPreset"
                                 Style="{StaticResource PreviewBox}"
                                 Margin="0"
                                 IsReadOnly="True"/>
                    </DockPanel>
                </Grid>

                <!-- ╔══════════════════════════════════════╗ -->
                <!-- ║  MANUAL EDIT PANEL                   ║ -->
                <!-- ╚══════════════════════════════════════╝ -->
                <Grid x:Name="PnlManual" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Edit .agent.md content directly — changes apply when you click Apply:"
                               Foreground="#5A6A4A" FontSize="11"
                               Margin="14,12,14,6"/>
                    <TextBox Grid.Row="1"
                             x:Name="TbManual"
                             Style="{StaticResource PreviewBox}"
                             Margin="0"
                             IsReadOnly="False"
                             AcceptsReturn="True"
                             AcceptsTab="True"/>
                </Grid>

            </Grid>
        </Grid>

        <!-- ── FOOTER ───────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#141814"
                BorderBrush="#2E3A2E" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status -->
                <TextBlock x:Name="TbStatus"
                           Grid.Column="0"
                           Foreground="#5A6A4A" FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="BtnApplyGlobal"
                            Content="Apply as Global Agent"
                            Style="{StaticResource SecBtn}"
                            Click="BtnApplyGlobal_Click"
                            Margin="0,0,8,0"
                            ToolTip="Write to global_agent.md — applies to ALL workspaces"/>

                    <Button x:Name="BtnApplyWorkspace"
                            Content="Apply to Workspace"
                            Style="{StaticResource ActionBtn}"
                            Click="BtnApplyWorkspace_Click"
                            FontWeight="SemiBold"
                            Margin="0,0,8,0"
                            ToolTip="Write .agent.md to the current workspace folder"/>

                    <Button x:Name="BtnCancel"
                            Content="Cancel"
                            Style="{StaticResource SecBtn}"
                            Click="BtnCancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
