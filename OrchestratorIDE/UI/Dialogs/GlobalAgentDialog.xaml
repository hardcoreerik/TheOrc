<Window x:Class="OrchestratorIDE.UI.Dialogs.GlobalAgentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Global Agent"
        Width="680" Height="500"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#CCCCCC"
        FontFamily="Consolas, 'Cascadia Code', monospace">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontFamily" Value="Consolas, 'Cascadia Code', monospace"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"    Value="#3C3C3C"/>
            <Setter Property="Foreground"    Value="#CCCCCC"/>
            <Setter Property="BorderBrush"   Value="#474747"/>
            <Setter Property="Padding"       Value="14,6"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FontFamily"    Value="Consolas, 'Cascadia Code', monospace"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground"    Value="#CCCCCC"/>
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Padding"       Value="10,8"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#264F78"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#252526"
                BorderBrush="#474747" BorderThickness="0,0,0,1"
                Padding="18,14">
            <StackPanel>
                <TextBlock Text="⚙  Global Agent" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="Applies to ALL workspaces unless overridden by a local .agent.md"
                           Foreground="#888" FontSize="10" Margin="0,4,0,0"/>
                <TextBlock x:Name="TbCurrentAgent" Text="Loading…"
                           Foreground="#6A9955" FontSize="10" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="#252526"
                BorderBrush="#474747" BorderThickness="0,1,0,0"
                Padding="12,10">
            <DockPanel>
                <Button x:Name="BtnEdit" Content="✏  Edit manually"
                        DockPanel.Dock="Left"
                        Background="#252526" Foreground="#888"
                        Click="BtnEdit_Click"/>
                <Button x:Name="BtnClear" Content="✕ Clear global agent"
                        DockPanel.Dock="Left" Margin="8,0,0,0"
                        Background="#3A1A1A" Foreground="#CC6666" BorderBrush="#5A2A2A"
                        Click="BtnClear_Click"/>
                <Button x:Name="BtnApply" Content="Apply preset →"
                        DockPanel.Dock="Right"
                        Background="#264F78" Foreground="White" BorderBrush="#3A7AB8"
                        IsEnabled="False"
                        Click="BtnApply_Click"/>
                <Button Content="Cancel" DockPanel.Dock="Right"
                        Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>
            </DockPanel>
        </Border>

        <!-- Body -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="PRESETS"
                           FontSize="10" Foreground="#888" FontWeight="Bold"
                           Margin="12,10,0,6"/>
                <ListBox x:Name="PresetList"
                         Background="#252526"
                         BorderThickness="0"
                         SelectionChanged="PresetList_SelectionChanged"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#474747" Cursor="SizeWE"/>

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="PREVIEW"
                           FontSize="10" Foreground="#888" FontWeight="Bold"
                           Margin="12,10,0,6"/>
                <TextBox x:Name="PreviewBox"
                         IsReadOnly="True"
                         Background="#1E1E1E"
                         Foreground="#D4D4D4"
                         BorderThickness="0"
                         Padding="12,8"
                         FontSize="11"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="← Select a preset to preview"/>
            </DockPanel>
        </Grid>

    </DockPanel>
</Window>
