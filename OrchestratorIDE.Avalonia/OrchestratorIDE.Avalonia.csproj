<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>OrchestratorIDE</RootNamespace>
    <AssemblyName>OrchestratorIDE.Avalonia</AssemblyName>
    <Version>1.11.0</Version>
    <AssemblyVersion>1.11.0.0</AssemblyVersion>
    <FileVersion>1.11.0.0</FileVersion>
    <NoWarn>$(NoWarn);NU1510;AVLN3001</NoWarn>
  </PropertyGroup>

  <!--
    Target-OS detection for every Windows-only Condition below (DefineConstants,
    package refs, Compile Include). RuntimeIdentifier reflects the TARGET OS and is
    set whenever `dotnet build/publish/restore -r <rid>` is used (release.yml always
    passes one); IsOSPlatform('Windows') reflects the BUILD HOST OS instead, which is
    only a correct stand-in when no RID is given (e.g. a plain local `dotnet build`).
    Using host-OS unconditionally was a real bug: cross-compiling `-r osx-arm64` FROM
    a Windows dev machine (e.g. for a local macOS verification build) would still
    define WINDOWS and pull DpapiSecretProtector.cs — a Windows-only DPAPI call — into
    the macOS binary, which would throw PlatformNotSupportedException the first time
    a HIVE secret is touched on the real Mac. CI itself was never affected (each
    release.yml leg builds natively on its own OS runner, so host OS == target OS
    there already) — this only matters for cross-compiled local builds.
  -->
  <PropertyGroup>
    <_TargetsWindows Condition="'$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier.StartsWith('win'))</_TargetsWindows>
    <_TargetsWindows Condition="'$(RuntimeIdentifier)' == ''">$([MSBuild]::IsOSPlatform('Windows'))</_TargetsWindows>
  </PropertyGroup>

  <!--
    Define WINDOWS when targeting Windows so that #if WINDOWS guards in shared
    source files (ScreenRecorder.cs, etc.) select the right platform branch.
    On net10.0 the TFM does NOT define WINDOWS automatically — we add it here.
  -->
  <PropertyGroup Condition="'$(_TargetsWindows)' == 'true'">
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
  </PropertyGroup>

  <!-- Match global usings in WPF project so shared source compiles cleanly. -->
  <ItemGroup>
    <ProjectReference Include="..\OrchestratorIDE.NativeRuntime\OrchestratorIDE.NativeRuntime.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="System.IO" />
    <Using Include="System.Collections.Generic" />
    <Using Include="System.Linq" />
    <Using Include="System.Threading" />
    <Using Include="System.Threading.Tasks" />
  </ItemGroup>

  <!-- Expose internals to both test projects — moved here from OrchestratorIDE.csproj
       (WPF retirement Phase 5); OrchestratorIDE.UnitTests/.UITests now reference this
       project instead. -->
  <ItemGroup>
    <InternalsVisibleTo Include="OrchestratorIDE.UITests" />
    <InternalsVisibleTo Include="OrchestratorIDE.UnitTests" />
    <InternalsVisibleTo Include="OrchestratorIDE.Avalonia.HeadlessTests" />
    <!-- swarmcli is a headless host that needs to init SecretProtection (DpapiSecretProtector
         is internal) before touching HIVE identity/secrets, exactly as App.axaml.cs does. -->
    <InternalsVisibleTo Include="swarmcli" />
  </ItemGroup>

  <!-- Stamp git SHA into AssemblyInformationalVersion (same as WPF project) -->
  <Target Name="StampGitCommit" BeforeTargets="GetAssemblyVersion;GenerateAssemblyInfo">
    <Exec Command="git describe --always --dirty --match _no_tag_" ConsoleToMSBuild="true" ContinueOnError="true" StandardOutputImportance="low" IgnoreExitCode="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="GitCommitHash" />
    </Exec>
    <PropertyGroup>
      <InformationalVersion Condition="'$(GitCommitHash)' != ''">$(Version)+$(GitCommitHash)</InformationalVersion>
      <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    </PropertyGroup>
  </Target>

