<UserControl x:Class="OrchestratorIDE.UI.Panels.SettingsPanel"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Br.Bg.Sidebar}">

    <UserControl.Resources>
        <!-- Pill toggle switch — Avalonia ControlTheme replaces WPF ControlTemplate.Triggers -->
        <ControlTheme x:Key="ToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width"             Value="40"/>
            <Setter Property="Height"            Value="20"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Track" CornerRadius="10" Width="40" Height="20"
                            Background="{StaticResource Br.Bg.Input}">
                        <Ellipse x:Name="Thumb" Width="14" Height="14"
                                 Fill="{StaticResource Br.Text.Muted}"
                                 HorizontalAlignment="Left" Margin="3,0,0,0"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:checked /template/ Border#Track">
                <Setter Property="Background" Value="#2A5200"/>
            </Style>
            <Style Selector="^:checked /template/ Ellipse#Thumb">
                <Setter Property="Fill" Value="{StaticResource Br.Accent.Green}"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Margin" Value="0,0,3,0"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Replicate WPF App.xaml setting styles as Avalonia class-based styles -->
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="Foreground" Value="{StaticResource Br.Text.Muted}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin"     Value="8,8,8,2"/>
        </Style>
        <Style Selector="TextBlock.SettingLabel">
            <Setter Property="Foreground" Value="{StaticResource Br.Text.Primary}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
        <Style Selector="TextBlock.SettingHint">
            <Setter Property="Foreground"   Value="{StaticResource Br.Text.Muted}"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
        </Style>
        <Style Selector="TextBox.SettingInput">
            <Setter Property="Background"      Value="{StaticResource Br.Bg.Input}"/>
            <Setter Property="Foreground"      Value="{StaticResource Br.Text.Primary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Br.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,5"/>
            <Setter Property="FontFamily"      Value="Consolas, 'Cascadia Code', monospace"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>
        <Style Selector="StackPanel.SettingRow">
            <Setter Property="Margin" Value="8,4,8,4"/>
        </Style>
        <Style Selector="Border.SettingRowBorder">
            <Setter Property="Margin"  Value="8,4,8,4"/>
            <Setter Property="Padding" Value="0,6"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#141814"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,0,1"
                Padding="8,6">
            <TextBlock Text="SETTINGS" Foreground="{StaticResource Br.Text.Muted}"
                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <!-- Save / Test buttons pinned to bottom -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource Br.Border}" BorderThickness="0,1,0,0"
                Padding="8,8">
            <Grid ColumnDefinitions="*,*">
                <Button x:Name="BtnTestConn" Grid.Column="0" Content="⚡ Test Connection"
                        Margin="0,0,4,0" Click="BtnTestConn_Click"
                        Background="{StaticResource Br.Bg.Input}"
                        Foreground="{StaticResource Br.Text.Primary}"
                        FontSize="11" Padding="0,6"/>
                <Button x:Name="BtnSave" Grid.Column="1" Content="✓  Save"
                        Margin="4,0,0,0" Click="BtnSave_Click"
                        Background="{StaticResource Br.Bg.Active}"
                        Foreground="{StaticResource Br.Text.White}"
                        FontSize="11" Padding="0,6"/>
            </Grid>
        </Border>

        <!-- Status message -->
        <Border DockPanel.Dock="Bottom" Padding="8,4">
            <TextBlock x:Name="TbStatus" Text="" FontSize="11"
                       TextWrapping="Wrap" Foreground="{StaticResource Br.Accent.Green}"/>
        </Border>

        <!-- Scrollable settings body -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,4,0,16">

                <!-- ── OLLAMA ──────────────────────────────────────────── -->
                <TextBlock Text="OLLAMA" Classes="SectionHeader"/>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Host URL" Classes="SettingLabel"/>
                    <TextBlock Text="Where your Ollama instance is running" Classes="SettingHint"/>
                    <TextBox x:Name="TbOllamaHost"
                             Classes="SettingInput"
                             Text="http://localhost:11434"/>
                </StackPanel>

                <!-- ── AGENT ───────────────────────────────────────────── -->
                <TextBlock Text="AGENT" Classes="SectionHeader" Margin="0,12,0,0"/>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Default Model" Classes="SettingLabel"/>
                    <TextBlock Text="Auto-selected on startup if installed" Classes="SettingHint"/>
                    <TextBox x:Name="TbDefaultModel"
                             Classes="SettingInput"
                             Text="qwen2.5-coder:14b"/>
                </StackPanel>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Max Steps Override" Classes="SettingLabel"/>
                    <TextBlock Text="0 = use model profile default" Classes="SettingHint"/>
                    <TextBox x:Name="TbMaxSteps" Classes="SettingInput" Text="0"/>
                </StackPanel>

                <!-- Toggle: Auto-verify -->
                <Border Classes="SettingRowBorder">
                    <DockPanel LastChildFill="True">
                        <ToggleButton x:Name="TglAutoVerify"
                                      DockPanel.Dock="Right"
                                      Theme="{StaticResource ToggleStyle}"
                                      IsChecked="True"/>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Auto-verify after write" Classes="SettingLabel"/>
                            <TextBlock Text="Run tests automatically after every file write"
                                       Classes="SettingHint" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Toggle: Git checkpoint -->
                <Border Classes="SettingRowBorder">
                    <DockPanel LastChildFill="True">
                        <ToggleButton x:Name="TglAutoCheckpoint"
                                      DockPanel.Dock="Right"
                                      Theme="{StaticResource ToggleStyle}"
                                      IsChecked="True"/>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Git checkpoint before Execute" Classes="SettingLabel"/>
                            <TextBlock Text="Auto-commits workspace before every agent run"
                                       Classes="SettingHint" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Toggle: Restore last model -->
                <Border Classes="SettingRowBorder">
                    <DockPanel LastChildFill="True">
                        <ToggleButton x:Name="TglRestoreLastModel"
                                      DockPanel.Dock="Right"
                                      Theme="{StaticResource ToggleStyle}"
                                      IsChecked="True"/>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Restore last model on startup" Classes="SettingLabel"/>
                            <TextBlock Text="On — reopens with the model you had last time. Off — picks best available."
                                       Classes="SettingHint" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Toggle: Auto-switch for security -->
                <Border Classes="SettingRowBorder">
                    <DockPanel LastChildFill="True">
                        <ToggleButton x:Name="TglAutoModelSwitch"
                                      DockPanel.Dock="Right"
                                      Theme="{StaticResource ToggleStyle}"
                                      IsChecked="True"/>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Auto-switch for security workspaces" Classes="SettingLabel"/>
                            <TextBlock Text="Switches to a security-focused model when a pentest workspace is detected"
                                       Classes="SettingHint" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ── UPDATES ─────────────────────────────────────────── -->
                <TextBlock Text="UPDATES" Classes="SectionHeader" Margin="0,12,0,0"/>

                <!-- Toggle: Check on startup -->
                <Border Classes="SettingRowBorder">
                    <DockPanel LastChildFill="True">
                        <ToggleButton x:Name="TglCheckUpdates"
                                      DockPanel.Dock="Right"
                                      Theme="{StaticResource ToggleStyle}"
                                      IsChecked="True"/>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Check for updates on startup" Classes="SettingLabel"/>
                            <TextBlock Text="Silent check against GitHub Releases once per day"
                                       Classes="SettingHint" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <StackPanel Classes="SettingRow" Orientation="Horizontal">
                    <Button x:Name="BtnCheckNow" Content="⬆ Check Now"
                            Click="BtnCheckNow_Click"
                            Background="{StaticResource Br.Bg.Input}"
                            Foreground="{StaticResource Br.Text.Primary}"
                            FontSize="11" Padding="8,6" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TbVersionInfo" Text=""
                               Classes="SettingHint" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ── AGENT FILE ──────────────────────────────────────── -->
                <TextBlock Text="AGENT FILE" Classes="SectionHeader" Margin="0,12,0,0"/>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Personalise your .agent.md" Classes="SettingLabel"/>
                    <TextBlock Classes="SettingHint" TextWrapping="Wrap"
                               Text="Regenerates the agent knowledge file in your workspace with your hardware, model, and any personal context you want the agent to always know."/>
                    <Button x:Name="BtnRegenerateAgentFile"
                            Content="🗡  Regenerate Agent File"
                            Click="BtnRegenerateAgentFile_Click"
                            Background="{StaticResource Br.Bg.Input}"
                            Foreground="{StaticResource Br.Text.Primary}"
                            FontSize="11" Padding="8,6"
                            HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- ── MULTI-AGENT / PARALLEL INFERENCE ───────────────── -->
                <TextBlock Text="MULTI-AGENT" Classes="SectionHeader" Margin="0,12,0,0"/>

                <Border x:Name="BdrParallelStatus"
                        Background="#141814" CornerRadius="4"
                        BorderBrush="#2E3A2E" BorderThickness="1"
                        Padding="12,10" Margin="8,4,8,4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="⬡" Foreground="#76B900" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TbParallelStatus"
                                       Text="Checking…"
                                       Foreground="#CCA700" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="TbParallelExplain"
                                   Foreground="#5A6A4A" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16"
                                   Text="Loading…"/>
                    </StackPanel>
                </Border>

                <StackPanel Classes="SettingRow" Orientation="Horizontal">
                    <TextBlock Text="Parallel slots:" Classes="SettingLabel"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CbParallelSlots" Width="60" Height="24"
                              Background="{StaticResource Br.Bg.Input}"
                              Foreground="{StaticResource Br.Text.Primary}"
                              BorderBrush="{StaticResource Br.Border}"
                              FontSize="11">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="6"/>
                    </ComboBox>
                    <TextBlock x:Name="TbSlotHint" Text="" FontSize="10"
                               Foreground="{StaticResource Br.Text.Muted}"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Classes="SettingRow" Orientation="Horizontal">
                    <Button x:Name="BtnSetPermanent"
                            Content="⚙  Set permanently"
                            Click="BtnSetPermanent_Click"
                            Background="#1A2A0A" Foreground="#76B900"
                            BorderBrush="#2A4A0A" FontSize="11" Padding="10,6"
                            Margin="0,0,8,0"
                            ToolTip.Tip="Writes OLLAMA_NUM_PARALLEL to your Windows user environment."/>
                    <Button x:Name="BtnCopyRestartCmd"
                            Content="📋  Copy restart command"
                            Click="BtnCopyRestartCmd_Click"
                            Background="{StaticResource Br.Bg.Input}"
                            Foreground="{StaticResource Br.Text.Primary}"
                            FontSize="11" Padding="10,6"
                            ToolTip.Tip="Copies a PowerShell one-liner to restart Ollama with the selected slot count."/>
                </StackPanel>

                <!-- ── HIVE MIND ────────────────────────────────────────── -->
                <TextBlock Text="HIVE MIND" Classes="SectionHeader" Margin="0,12,0,0"/>

                <Border Classes="SettingRowBorder">
                    <DockPanel LastChildFill="True">
                        <ToggleButton x:Name="TglHiveMindEnabled"
                                      DockPanel.Dock="Right"
                                      Theme="{StaticResource ToggleStyle}"
                                      IsChecked="False"/>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Enable HIVE MIND" Classes="SettingLabel"/>
                            <TextBlock Text="Lets this machine join a HIVE MIND mesh (pairing, distributed task dispatch). Takes effect after restarting the app."
                                       Classes="SettingHint" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Classes="SettingRowBorder">
                    <DockPanel LastChildFill="True">
                        <ToggleButton x:Name="TglHiveLiteMode"
                                      DockPanel.Dock="Right"
                                      Theme="{StaticResource ToggleStyle}"
                                      IsChecked="False"/>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Lite Mode" Classes="SettingLabel"/>
                            <TextBlock Text="Turns off the constellation view's flowing-data animation and breathing center node. The warband stops marching, but everything still works — flip this on if the Hive tab feels sluggish on this machine."
                                       Classes="SettingHint" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Classes="SettingRowBorder">
                    <DockPanel LastChildFill="True">
                        <ComboBox x:Name="CmbHiveAcceptControlFrom"
                                  DockPanel.Dock="Right" Width="200"
                                  SelectedIndex="1">
                            <ComboBoxItem Content="Never" Tag="Never"/>
                            <ComboBoxItem Content="Ask each time (default)" Tag="Ask"/>
                            <ComboBoxItem Content="Allowlist only" Tag="Allowlist"/>
                            <ComboBoxItem Content="Always (any paired peer)" Tag="AnyPaired"/>
                        </ComboBox>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Default auto-accept for new peers" Classes="SettingLabel"/>
                            <TextBlock Text="Applied to newly paired nodes -- governs whether they auto-accept a role-assignment request (e.g. &quot;Declare this machine Warchief&quot;) without a per-event approval click. Change an already-paired peer's policy from its card's right-click menu instead."
                                       Classes="SettingHint" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ── NATIVE RUNTIME (Phase 3 telemetry) ──────────────── -->
                <TextBlock Text="NATIVE RUNTIME" Classes="SectionHeader" Margin="0,12,0,0"/>

                <Border x:Name="BdrRuntimeStatus"
                        Background="#141814" CornerRadius="4"
                        BorderBrush="#2E3A2E" BorderThickness="1"
                        Padding="12,10" Margin="8,4,8,4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="⬡" Foreground="#76B900" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TbRuntimeStatus"
                                       Text="Checking…"
                                       Foreground="#CCA700" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="TbRuntimeExplain"
                                   Foreground="#5A6A4A" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16"
                                   Text="Loading…"/>
                    </StackPanel>
                </Border>

                <StackPanel Classes="SettingRow" Orientation="Horizontal">
                    <Button x:Name="BtnRefreshRuntimeStatus"
                            Content="↻  Refresh"
                            Click="BtnRefreshRuntimeStatus_Click"
                            Background="{StaticResource Br.Bg.Input}"
                            Foreground="{StaticResource Br.Text.Primary}"
                            FontSize="11" Padding="8,6"
                            ToolTip.Tip="Re-probes the active IModelRuntime (OllamaRuntime) via GetHealth()/GetStats()"/>
                </StackPanel>

                <Border Classes="SettingRowBorder">
                    <DockPanel LastChildFill="True">
                        <ToggleButton x:Name="TglNativeHiveWorker"
                                      DockPanel.Dock="Right"
                                      Theme="{StaticResource ToggleStyle}"
                                      IsChecked="False"/>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Experimental Native HIVE worker" Classes="SettingLabel"/>
                            <TextBlock Text="Opt-in only. HIVE worker tries local ModelDepot/LLamaSharp role runtime first, then falls back to the configured model runtime on failure."
                                       Classes="SettingHint" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Native Model Root" Classes="SettingLabel"/>
                    <TextBlock Text="Folder scanned for GGUF/LoRA role bindings. Empty uses the normal model storage folder."
                               Classes="SettingHint"/>
                    <Grid ColumnDefinitions="*,32">
                        <TextBox x:Name="TbNativeRuntimeModelRoot"
                                 Grid.Column="0" Classes="SettingInput"/>
                        <Button Grid.Column="1" Content="…" Margin="4,0,0,0"
                                Background="{StaticResource Br.Bg.Input}"
                                Foreground="{StaticResource Br.Text.Primary}"
                                FontSize="12" Click="BtnBrowseNativeRuntimeModelRoot_Click"/>
                    </Grid>
                </StackPanel>

                <Grid Classes="SettingRow" ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Native Context" Classes="SettingLabel"/>
                        <TextBlock Text="Tokens" Classes="SettingHint"/>
                        <TextBox x:Name="TbNativeRuntimeContextSize"
                                 Classes="SettingInput"
                                 Text="8192"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Native GPU Layers" Classes="SettingLabel"/>
                        <TextBlock Text="-1 = all" Classes="SettingHint"/>
                        <TextBox x:Name="TbNativeRuntimeGpuLayers"
                                 Classes="SettingInput"
                                 Text="-1"/>
                    </StackPanel>
                </Grid>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Manual Native Test" Classes="SettingLabel"/>
                    <TextBlock Text="Isolated opt-in smoke tool. Runs a fixed prompt against one resolved ModelDepot binding, then offers explicit Ollama fallback if native fails."
                               Classes="SettingHint"/>
                    <ComboBox x:Name="CbNativeBinding"
                              Background="{StaticResource Br.Bg.Input}"
                              Foreground="{StaticResource Br.Text.Primary}"
                              BorderBrush="{StaticResource Br.Border}"
                              FontSize="11"
                              PlaceholderText="Scan Model Depot to populate bindings"/>
                </StackPanel>

                <StackPanel Classes="SettingRow" Orientation="Horizontal">
                    <Button x:Name="BtnRunNativeRuntimeTest"
                            Content="▶  Run Native Test"
                            Click="BtnRunNativeRuntimeTest_Click"
                            IsEnabled="False"
                            Background="#1A2A0A"
                            Foreground="#76B900"
                            BorderBrush="#2A4A0A"
                            FontSize="11" Padding="8,6"
                            ToolTip.Tip="Attempts the fixed prompt with LLamaSharpRuntime first, then asks before retrying the same test through Ollama."/>
                </StackPanel>

                <Border x:Name="BdrNativeRuntimeTestResult"
                        Background="#141814" CornerRadius="4"
                        BorderBrush="#2E3A2E" BorderThickness="1"
                        Padding="12,10" Margin="8,4,8,4">
                    <StackPanel>
                        <TextBlock x:Name="TbNativeRuntimeTestResult"
                                   Text="Not run yet."
                                   Foreground="#5A6A4A" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16"
                                   FontFamily="Consolas, 'Cascadia Code', monospace"/>
                        <TextBlock Text="Live output"
                                   Margin="0,10,0,4"
                                   Foreground="{StaticResource Br.Text.Muted}"
                                   FontSize="10"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TbNativeRuntimeLiveOutput"
                                   Text="(none)"
                                   Foreground="#5A6A4A" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16"
                                   FontFamily="Consolas, 'Cascadia Code', monospace"/>
                    </StackPanel>
                </Border>

                <!-- ── MODEL DEPOT (Phase 3 — local GGUF/LoRA discovery, no model loading) ── -->
                <TextBlock Text="MODEL DEPOT" Classes="SectionHeader" Margin="0,12,0,0"/>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Scan Folder" Classes="SettingLabel"/>
                    <TextBlock Text="Local-only — ModelDepot.Scan() finds GGUF/LoRA files, never downloads or loads any model"
                               Classes="SettingHint"/>
                    <Grid ColumnDefinitions="*,32">
                        <TextBox x:Name="TbDepotScanFolder"
                                 Grid.Column="0" Classes="SettingInput"/>
                        <Button Grid.Column="1" Content="…" Margin="4,0,0,0"
                                Background="{StaticResource Br.Bg.Input}"
                                Foreground="{StaticResource Br.Text.Primary}"
                                FontSize="12" Click="BtnBrowseDepotScanFolder_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Classes="SettingRow" Orientation="Horizontal">
                    <Button x:Name="BtnScanDepot"
                            Content="🔍  Scan"
                            Click="BtnScanDepot_Click"
                            Background="{StaticResource Br.Bg.Input}"
                            Foreground="{StaticResource Br.Text.Primary}"
                            FontSize="11" Padding="8,6"
                            ToolTip.Tip="Runs ModelDepot.Scan() against the folder above — instant, no GPU/VRAM cost"/>
                </StackPanel>

                <Border x:Name="BdrDepotResults"
                        Background="#141814" CornerRadius="4"
                        BorderBrush="#2E3A2E" BorderThickness="1"
                        Padding="12,10" Margin="8,4,8,4">
                    <TextBlock x:Name="TbDepotResults"
                               Text="Not scanned yet."
                               Foreground="#5A6A4A" FontSize="10"
                               TextWrapping="Wrap" LineHeight="16"
                               FontFamily="Consolas, 'Cascadia Code', monospace"/>
                </Border>

                <!-- ── WORKSPACE ───────────────────────────────────────── -->
                <TextBlock Text="WORKSPACE" Classes="SectionHeader" Margin="0,12,0,0"/>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Default Folder" Classes="SettingLabel"/>
                    <TextBlock Text="Loaded on startup (leave blank to start empty)" Classes="SettingHint"/>
                    <Grid ColumnDefinitions="*,32">
                        <TextBox x:Name="TbDefaultWorkspace"
                                 Grid.Column="0" Classes="SettingInput"/>
                        <Button Grid.Column="1" Content="…" Margin="4,0,0,0"
                                Background="{StaticResource Br.Bg.Input}"
                                Foreground="{StaticResource Br.Text.Primary}"
                                FontSize="12" Click="BtnBrowseWorkspace_Click"/>
                    </Grid>
                </StackPanel>

                <!-- ── INSTALL ─────────────────────────────────────────── -->
                <TextBlock Text="INSTALL" Classes="SectionHeader" Margin="0,12,0,0"/>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Install Folder" Classes="SettingLabel"/>
                    <TextBlock x:Name="TbInstallPath" Classes="SettingHint"
                               TextWrapping="Wrap" Text="…"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button x:Name="BtnOpenInstallFolder"
                                Content="📁  Open Folder"
                                Click="BtnOpenInstallFolder_Click"
                                Background="{StaticResource Br.Bg.Input}"
                                Foreground="{StaticResource Br.Text.Primary}"
                                FontSize="11" Padding="8,6" Margin="0,0,6,0"
                                ToolTip.Tip="Open the TheOrc install folder in Explorer"/>
                        <Button x:Name="BtnOpenDataFolder"
                                Content="🗂  Data Folder"
                                Click="BtnOpenDataFolder_Click"
                                Background="{StaticResource Br.Bg.Input}"
                                Foreground="{StaticResource Br.Text.Primary}"
                                FontSize="11" Padding="8,6"
                                ToolTip.Tip="Open the TheOrc data folder (%AppData%\OrchestratorIDE)"/>
                    </StackPanel>
                </StackPanel>

                <!-- ── SELF-IMPROVE ────────────────────────────────────── -->
                <TextBlock Text="SELF-IMPROVE" Classes="SectionHeader" Margin="0,12,0,0"/>

                <Border Background="#0E1A0E" CornerRadius="4"
                        BorderBrush="#1E3A1E" BorderThickness="1"
                        Padding="10,8" Margin="8,4,8,4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="⬡" Foreground="#76B900" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="TheOrc can improve itself"
                                       Foreground="#76B900" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock Text="Grab the source, then let TheOrc scan its own code and open GitHub issues to suggest fixes and improvements — guided by the active model."
                                   Foreground="#4A6A4A" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="15"/>
                    </StackPanel>
                </Border>

                <StackPanel Classes="SettingRow">
                    <TextBlock Text="Source Folder" Classes="SettingLabel"/>
                    <Grid ColumnDefinitions="*,32">
                        <TextBox x:Name="TbSourceFolder"
                                 Grid.Column="0" Classes="SettingInput"
                                 ToolTip.Tip="Local folder where TheOrc source code will be stored"/>
                        <Button Grid.Column="1" Content="…" Margin="4,0,0,0"
                                Background="{StaticResource Br.Bg.Input}"
                                Foreground="{StaticResource Br.Text.Primary}"
                                FontSize="12" Click="BtnBrowseSourceFolder_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Classes="SettingRow">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button x:Name="BtnGrabSource"
                                Content="⬇  Grab Source"
                                Click="BtnGrabSource_Click"
                                Background="#1A2A0A" Foreground="#76B900"
                                BorderBrush="#2A4A0A" FontSize="11" Padding="10,6"
                                Margin="0,0,8,0"
                                ToolTip.Tip="Clone (or pull) TheOrc from GitHub/main into the source folder"/>
                        <Button x:Name="BtnOpenSourceAsWorkspace"
                                Content="📂  Open in Agent"
                                Click="BtnOpenSourceAsWorkspace_Click"
                                Background="{StaticResource Br.Bg.Input}"
                                Foreground="{StaticResource Br.Text.Primary}"
                                FontSize="11" Padding="10,6"
                                ToolTip.Tip="Load the source folder as the active workspace so TheOrc can edit itself"/>
                    </StackPanel>

                    <Button x:Name="BtnScanImprovements"
                            Content="🔍  Scan GitHub — Suggest Improvements"
                            Click="BtnScanImprovements_Click"
                            Background="#0A1A2A" Foreground="#4EC9B0"
                            BorderBrush="#0A3A4A" FontSize="11" Padding="10,7"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Fetch open GitHub issues + recent commits, then ask the active model to prioritise bugs and suggest improvements"/>
                </StackPanel>

                <Border Padding="8,0,8,4">
                    <TextBlock x:Name="TbSelfImproveStatus" Text=""
                               FontSize="10" TextWrapping="Wrap"
                               Foreground="{StaticResource Br.Accent.Green}"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
