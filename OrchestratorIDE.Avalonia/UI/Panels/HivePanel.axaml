<UserControl x:Class="OrchestratorIDE.UI.Panels.HivePanel"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OrchestratorIDE.UI.Panels"
             Background="#0A0E0A">

    <!--
    ═══════════════════════════════════════════════════════════════════
    HIVE PANEL — Phase 3C (Avalonia port)
    War-camp constellation: peer nodes orbit "This PC" on a canvas.
    Phase 3: DoubleAnimation pulse removed — static opacity only.
    ═══════════════════════════════════════════════════════════════════
    -->

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="130"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────── -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⬡ HIVE MIND" FontSize="16" FontWeight="SemiBold"
                           Foreground="#76B900" VerticalAlignment="Center"
                           AutomationProperties.AutomationId="Hive.Panel"/>
                <TextBlock x:Name="HiveSummary" Text="" FontSize="11" Foreground="#999999"
                           Margin="12,0,0,0" VerticalAlignment="Bottom"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button x:Name="BtnScanLan" Content="📡 Scan LAN"
                        Click="BtnScanLan_Click"
                        Padding="10,4" Margin="0,0,8,0"
                        Background="#1A1A00" BorderBrush="#888800" Foreground="#C8C840"
                        BorderThickness="1" FontSize="11"
                        AutomationProperties.AutomationId="Hive.ScanLan"/>
                <Button x:Name="BtnFindTailscale" Content="🔗 Find Tailscale nodes"
                        Click="BtnFindTailscale_Click"
                        Padding="10,4" Margin="0,0,8,0"
                        Background="#0A1A2A" BorderBrush="#4A9FD9" Foreground="#8FC9F0"
                        BorderThickness="1" FontSize="11"
                        AutomationProperties.AutomationId="Hive.FindTailscale"/>
                <Button x:Name="BtnAddNode" Content="➕ Add node"
                        Click="BtnAddNode_Click"
                        Padding="10,4" Margin="0,0,8,0"
                        Background="#1F3D00" BorderBrush="#76B900" Foreground="#A8CC80"
                        BorderThickness="1" FontSize="11"
                        AutomationProperties.AutomationId="Hive.AddNode"/>
                <Button x:Name="BtnRescan" Content="⟳ Rescan"
                        Click="BtnRescan_Click"
                        Padding="10,4"
                        Background="#111111" BorderBrush="#2A2A2A" Foreground="#999999"
                        BorderThickness="1" FontSize="11"
                        AutomationProperties.AutomationId="Hive.Rescan"/>
            </StackPanel>
        </DockPanel>

        <!-- ── War-camp constellation canvas ──────────────────────── -->
        <Border Grid.Row="1" Background="#0C120C" BorderBrush="#1E2E1E" BorderThickness="1"
                CornerRadius="8" ClipToBounds="True">
            <Canvas x:Name="HiveCanvas" SizeChanged="HiveCanvas_SizeChanged"/>
        </Border>

        <!-- ── Event log strip ────────────────────────────────────── -->
        <Border Grid.Row="2" Margin="0,8,0,0"
                Background="#070D07" BorderBrush="#1A2A1A" BorderThickness="1"
                CornerRadius="6" ClipToBounds="True">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="8,5,8,3">
                    <TextBlock Text="⚡ EVENTS" FontSize="9" FontWeight="Bold"
                               Foreground="#4A6A4A" VerticalAlignment="Center"
                               AutomationProperties.AutomationId="Hive.EventsLabel"/>
                    <TextBlock x:Name="TbEventCount" Text="" FontSize="9"
                               Foreground="#3A4A3A" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </DockPanel>
                <ScrollViewer x:Name="SvEventLog"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="IcEventLog" Margin="8,0,8,6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:EventRow">
                                <TextBlock Text="{Binding Text}"
                                           Foreground="{Binding Color}"
                                           FontFamily="Consolas" FontSize="10"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Discovered nodes strip (beacon / LAN scan results) ── -->
        <Border x:Name="BdrDiscovered" Grid.Row="3" Margin="0,8,0,0"
                Background="#0D1A0D" BorderBrush="#2A4A2A" BorderThickness="1"
                CornerRadius="6" Padding="10,7"
                IsVisible="False">
            <DockPanel>
                <TextBlock Text="📡 DISCOVERED" FontSize="10" FontWeight="Bold"
                           Foreground="#888800" VerticalAlignment="Center"
                           Margin="0,0,10,0" DockPanel.Dock="Left"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="PnlDiscoveredNodes" Orientation="Horizontal"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Hint ───────────────────────────────────────────────── -->
        <TextBlock Grid.Row="4" Margin="2,8,0,0" FontSize="10" Foreground="#666666"
                   TextWrapping="Wrap"
                   AutomationProperties.AutomationId="Hive.HintText"
                   Text="This PC sits at the center. Reachable nodes glow green; lines carry work. Click a node for detail. Use 📡 Scan LAN to find nodes running HIVE MIND."/>
    </Grid>
</UserControl>
