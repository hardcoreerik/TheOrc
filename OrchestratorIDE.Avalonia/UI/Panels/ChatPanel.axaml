<UserControl x:Class="OrchestratorIDE.UI.Panels.ChatPanel"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Br.Bg.App}">

    <!--
    ═══════════════════════════════════════════════════════════════════
    ORCCHAT PANEL — Phase 3B/6 (Avalonia port). Single merged chat surface
    (formerly separate Research/Open modes): web search/fetch tools are
    always available, no system prompt is injected by default, and the
    user controls system prompt/temperature/top-p directly. Dynamic
    bubble-building in code-behind. Final responses rendered as markdown
    via MarkdownView (Phase 6).
    ═══════════════════════════════════════════════════════════════════
    -->

    <DockPanel>

        <!-- ── Header bar ──────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#0E120E"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,0,0,1"
                Padding="12,7">
            <DockPanel>

                <!-- Right: Clear + Export -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnClear"
                            Content="🗑  Clear"
                            Margin="0,0,8,0" Padding="8,4" FontSize="11"
                            Background="Transparent" BorderBrush="#333333"
                            Foreground="#666666" BorderThickness="1"
                            ToolTip.Tip="Erases everything said so far and starts a brand-new conversation. The model only 'forgets' a tone or topic once the messages establishing it are gone — editing the system prompt alone does NOT remove what's already been said, since the model still sees its own earlier replies. Use Clear whenever you want a clean slate, not just a new instruction."
                            Click="BtnClear_Click"/>
                    <Button x:Name="BtnExport"
                            Content="💾  Save"
                            Padding="8,4" FontSize="11"
                            Background="Transparent" BorderBrush="#333333"
                            Foreground="#666666" BorderThickness="1"
                            ToolTip.Tip="Save conversation to a markdown file"
                            Click="BtnExport_Click"/>
                </StackPanel>

                <!-- Left: branding + mode toggle + model picker -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💬" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="OrcChat"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               ToolTip.Tip="Web search/fetch tools are always available, no system prompt is injected by default — set one below if you want one."/>

                    <TextBlock Text="Model:"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CbModel"
                              Background="#1A1A1A" Foreground="#D4D4D4"
                              BorderBrush="#2E3A2E" FontSize="11"
                              Padding="6,3" MinWidth="200"
                              ToolTip.Tip="Which installed model answers in this conversation. Models tagged 'uncensored' in TheOrc's catalog have had their refusal training removed via fine-tuning — pick one of those for Open mode if you want the fewest built-in content restrictions."
                              SelectionChanged="CbModel_SelectionChanged"/>

                    <!-- HIVE node target: "Local" or a specific paired node. Lets a weaker
                         local machine run a chat on a beefier paired machine's Ollama
                         instance, same routing concept SwarmSession already uses per-task,
                         applied to chat (Phase B3 of the uncensored-chat-models plan). -->
                    <TextBlock Text="Node:"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <ComboBox x:Name="CbNode"
                              Background="#1A1A1A" Foreground="#D4D4D4"
                              BorderBrush="#2E3A2E" FontSize="11"
                              Padding="6,3" MinWidth="110"
                              ToolTip.Tip="Where this chat actually runs. 'Local' uses this machine's own Ollama. Selecting a paired HIVE node routes the conversation to that machine's Ollama instead — useful if it has more VRAM or a model this machine doesn't have loaded. Switching nodes mid-conversation starts a fresh chat."
                              SelectionChanged="CbNode_SelectionChanged"/>
                    <!-- Search indicator -->
                    <Border x:Name="BdrSearching"
                            Background="#1A2800" BorderBrush="#2A4A00"
                            BorderThickness="1" CornerRadius="3"
                            Padding="6,2" Margin="12,0,0,0"
                            IsVisible="False">
                        <TextBlock x:Name="TbSearching"
                                   Text="🔍 Searching…"
                                   Foreground="#76B900"
                                   FontSize="10"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Context window usage, updates after each reply (OnUsage) and when
                         the model/node selection changes (context limit re-fetched then). -->
                    <Border x:Name="BdrContextUsage"
                            Background="#141814" BorderBrush="#2A3A2A"
                            BorderThickness="1" CornerRadius="3"
                            Padding="6,2" Margin="12,0,0,0"
                            IsVisible="False">
                        <TextBlock x:Name="TxtContextUsage"
                                   Foreground="#888888"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   ToolTip.Tip="Tokens used by the last reply (prompt + completion) out of this model's native max context, via Ollama's /api/show. This is the model's reported maximum, not necessarily what's actually allocated for this running session -- Ollama can cap it lower."/>
                    </Border>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── System prompt / sampling controls ───────────── -->
        <Border x:Name="BdrOpenControls"
                DockPanel.Dock="Top"
                Background="#0C0F0C"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Vertical" Spacing="6">

                <!-- Row 1: system prompt, multi-line with real room to write -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="System prompt:" Foreground="#666666" FontSize="11"
                               VerticalAlignment="Top" Margin="0,4,6,0"
                               ToolTip.Tip="Sent as a system message ahead of every turn in this conversation. Empty means no system prompt at all -- the model sees only what you type in chat, nothing added by TheOrc. Editing this only affects NEW messages; it does not erase what the model has already said earlier in this conversation (use Clear for that)."/>
                    <TextBox x:Name="TbOpenSystemPrompt"
                             Background="#141814" Foreground="#D4D4D4"
                             BorderBrush="#2A3A2A" FontSize="11"
                             Padding="8,6" MinHeight="56" MaxHeight="120"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             HorizontalAlignment="Stretch"
                             PlaceholderText="(none — leave empty for no system prompt at all. Try a preset below, or write your own.)"
                             ToolTip.Tip="Sent as a system message ahead of every turn in this conversation. Empty means no system prompt at all -- the model sees only what you type in chat, nothing added by TheOrc. Editing this only affects NEW messages; it does not erase what the model has already said earlier in this conversation (use Clear for that)."/>
                </StackPanel>

                <!-- Row 2: presets, concrete behaviorally-specific instructions, not vague
                     dispositions ("be helpful") which tested out to have little effect compared
                     to a concrete instruction the model can actually act on. -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Presets:" Foreground="#666666" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,2,0"/>
                    <Button x:Name="BtnPresetSecurity" Content="🔓 Security Research"
                            Padding="8,3" FontSize="10"
                            Background="Transparent" BorderBrush="#333333"
                            Foreground="#888888" BorderThickness="1"
                            ToolTip.Tip="For authorized security testing and pentesting questions -- explains tools/techniques/exploitation steps directly, notes scope/authorization briefly rather than refusing or hedging on legitimate security work."
                            Click="BtnPresetSecurity_Click"/>
                    <Button x:Name="BtnPresetDirect" Content="⚡ Direct &amp; Unfiltered"
                            Padding="8,3" FontSize="10"
                            Background="Transparent" BorderBrush="#333333"
                            Foreground="#888888" BorderThickness="1"
                            ToolTip.Tip="No disclaimers, warnings, or moral commentary unless you ask for them -- just the direct answer."
                            Click="BtnPresetDirect_Click"/>
                    <Button x:Name="BtnPresetPlainProse" Content="📄 Plain Prose"
                            Padding="8,3" FontSize="10"
                            Background="Transparent" BorderBrush="#333333"
                            Foreground="#888888" BorderThickness="1"
                            ToolTip.Tip="Plain paragraphs, no markdown formatting/bullet lists -- useful if you want prose instead of the model's default structured-list style."
                            Click="BtnPresetPlainProse_Click"/>
                </StackPanel>

                <!-- Row 3: sampling params. Plain TextBox, not NumericUpDown: NumericUpDown's
                     templated inner TextBox part doesn't inherit the outer Foreground/Background
                     set here under the Fluent theme, so the value was invisible (grok review
                     would have caught this if it could see rendered output; a real user testing
                     session caught it instead). Matches the same dark-theme TextBox styling
                     proven everywhere else in this panel. -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Temp:" Foreground="#666666" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip.Tip="Sampling temperature, 0.0-2.0. Higher = more random/creative, lower = more focused/deterministic. Default 0.8."/>
                    <TextBox x:Name="TbOpenTemperature" Text="0.8"
                             Background="#141814" Foreground="#D4D4D4"
                             BorderBrush="#2A3A2A" FontSize="11"
                             Padding="6,3" Width="60" Margin="0,0,16,0"
                             ToolTip.Tip="Sampling temperature, 0.0-2.0. Higher = more random/creative, lower = more focused/deterministic. Default 0.8."/>
                    <TextBlock Text="Top-P:" Foreground="#666666" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip.Tip="Nucleus sampling threshold, 0.0-1.0. Lower = considers fewer, more likely next words; 1.0 = no restriction. Default 0.9."/>
                    <TextBox x:Name="TbOpenTopP" Text="0.9"
                             Background="#141814" Foreground="#D4D4D4"
                             BorderBrush="#2A3A2A" FontSize="11"
                             Padding="6,3" Width="60"
                             ToolTip.Tip="Nucleus sampling threshold, 0.0-1.0. Lower = considers fewer, more likely next words; 1.0 = no restriction. Default 0.9."/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ── Input bar ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#0E120E"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <StackPanel Spacing="8">
                <ItemsControl x:Name="PendingAttachmentsPanel" IsVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <DockPanel>
                    <Button x:Name="BtnAttach"
                            DockPanel.Dock="Left"
                            Content="Attach"
                            Background="#141814" Foreground="#A8CC80"
                            BorderBrush="#2A3A2A" BorderThickness="1"
                            Padding="10,8" FontSize="12" FontWeight="SemiBold"
                            Margin="0,0,10,0"
                            ToolTip.Tip="Attach images or text files to this message."
                            Click="BtnAttach_Click"/>
                <Button x:Name="BtnSend"
                        DockPanel.Dock="Right"
                        Content="Send  ⏎"
                        Background="#1F3D00" Foreground="#76B900"
                        BorderBrush="#2A5A00" BorderThickness="1"
                        Padding="14,8" FontSize="12" FontWeight="SemiBold"
                        Margin="10,0,0,0"
                        ToolTip.Tip="Sends this message and adds it to the conversation. The model sees everything said so far, including its own earlier replies — a new message doesn't reset tone or context, only Clear does that."
                        Click="BtnSend_Click"
                        AutomationProperties.AutomationId="OrcChat.Send"/>
                <Border Background="#141814"
                        BorderBrush="#2A3A2A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="1">
                    <TextBox x:Name="TbInput"
                             Background="Transparent"
                             Foreground="#D4D4D4"
                             CaretBrush="#76B900"
                             BorderThickness="0"
                             FontSize="13"
                             Padding="10,8"
                             MinHeight="44"
                             MaxHeight="140"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PlaceholderText="Ask me anything… (Enter to send, Shift+Enter for new line)"
                             KeyDown="TbInput_KeyDown"
                             AutomationProperties.AutomationId="OrcChat.Input"/>
                </Border>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- ── Chat area ───────────────────────────────────────────── -->
        <ScrollViewer x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,8">
            <StackPanel x:Name="ChatStack"
                        Orientation="Vertical"
                        Margin="0,8,0,16">

                <!-- Welcome card (removed from ChatStack on first send) -->
                <Border x:Name="BdrWelcome"
                        Background="#111611"
                        BorderBrush="#1E2E1E" BorderThickness="1"
                        CornerRadius="8,8,8,2"
                        Padding="14,10" Margin="0,4,60,4"
                        HorizontalAlignment="Left" MaxWidth="780">
                    <StackPanel>
                        <TextBlock x:Name="TxtWelcomeTitle"
                                   Text="👋  OrcChat"
                                   Foreground="#76B900"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtWelcomeBody"
                                   TextWrapping="Wrap"
                                   Foreground="#A8CC80"
                                   FontSize="12" LineHeight="20"
                                   Text="I can search the web and fetch pages when it helps. No system prompt by default — set one above if you want a persona or standing instruction; leave it empty for plain, unfiltered conversation."/>
                        <TextBlock x:Name="TxtWelcomeTip"
                                   TextWrapping="Wrap"
                                   Foreground="#5A7A40"
                                   FontSize="11" Margin="0,8,0,0" LineHeight="18">
                            💡  Try: "Summarise the latest news on [topic]" · "Compare X vs Y with sources" · "Find and summarise the docs for [library]"
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#444444"
                                   FontSize="10" Margin="0,10,0,0">
                            ⌨  Enter to send · Shift+Enter for new line
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
