<UserControl x:Class="OrchestratorIDE.UI.Panels.ChatPanel"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Br.Bg.App}">

    <!--
    ═══════════════════════════════════════════════════════════════════
    CHAT PANEL — Phase 3B (Avalonia port)
    "Just Chat" research panel. Dynamic bubble-building in code-behind.
    Note: Markdown rendering is Phase 6 (Markdown.Avalonia). Until then
    the final assistant response stays as plain text in a TextBox.
    ═══════════════════════════════════════════════════════════════════
    -->

    <DockPanel>

        <!-- ── Header bar ──────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#0E120E"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,0,0,1"
                Padding="12,7">
            <DockPanel>

                <!-- Right: Clear + Export -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnClear"
                            Content="🗑  Clear"
                            Margin="0,0,8,0" Padding="8,4" FontSize="11"
                            Background="Transparent" BorderBrush="#333333"
                            Foreground="#666666" BorderThickness="1"
                            ToolTip.Tip="Clear conversation history"
                            Click="BtnClear_Click"/>
                    <Button x:Name="BtnExport"
                            Content="💾  Save"
                            Padding="8,4" FontSize="11"
                            Background="Transparent" BorderBrush="#333333"
                            Foreground="#666666" BorderThickness="1"
                            ToolTip.Tip="Save conversation to a markdown file"
                            Click="BtnExport_Click"/>
                </StackPanel>

                <!-- Left: branding + model picker -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💬" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Just Chat"
                               Foreground="{StaticResource Br.Text.White}"
                               FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="Model:"
                               Foreground="{StaticResource Br.Text.Muted}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CbModel"
                              Background="#1A1A1A" Foreground="#D4D4D4"
                              BorderBrush="#2E3A2E" FontSize="11"
                              Padding="6,3" MinWidth="200"
                              SelectionChanged="CbModel_SelectionChanged"/>
                    <!-- Search indicator -->
                    <Border x:Name="BdrSearching"
                            Background="#1A2800" BorderBrush="#2A4A00"
                            BorderThickness="1" CornerRadius="3"
                            Padding="6,2" Margin="12,0,0,0"
                            IsVisible="False">
                        <TextBlock x:Name="TbSearching"
                                   Text="🔍 Searching…"
                                   Foreground="#76B900"
                                   FontSize="10"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── Input bar ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#0E120E"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <DockPanel>
                <Button x:Name="BtnSend"
                        DockPanel.Dock="Right"
                        Content="Send  ⏎"
                        Background="#1F3D00" Foreground="#76B900"
                        BorderBrush="#2A5A00" BorderThickness="1"
                        Padding="14,8" FontSize="12" FontWeight="SemiBold"
                        Margin="10,0,0,0"
                        Click="BtnSend_Click"/>
                <Border Background="#141814"
                        BorderBrush="#2A3A2A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="1">
                    <TextBox x:Name="TbInput"
                             Background="Transparent"
                             Foreground="#D4D4D4"
                             CaretBrush="#76B900"
                             BorderThickness="0"
                             FontSize="13"
                             Padding="10,8"
                             MinHeight="44"
                             MaxHeight="140"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PlaceholderText="Ask me anything… (Enter to send, Shift+Enter for new line)"
                             KeyDown="TbInput_KeyDown"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- ── Chat area ───────────────────────────────────────────── -->
        <ScrollViewer x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,8">
            <StackPanel x:Name="ChatStack"
                        Orientation="Vertical"
                        Margin="0,8,0,16">

                <!-- Welcome card (removed from ChatStack on first send) -->
                <Border x:Name="BdrWelcome"
                        Background="#111611"
                        BorderBrush="#1E2E1E" BorderThickness="1"
                        CornerRadius="8,8,8,2"
                        Padding="14,10" Margin="0,4,60,4"
                        HorizontalAlignment="Left" MaxWidth="780">
                    <StackPanel>
                        <TextBlock Text="👋  Ready to research"
                                   Foreground="#76B900"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#A8CC80"
                                   FontSize="12" LineHeight="20">
                            Ask me anything — I can search the web, read articles, and compile research into structured reports with clickable sources.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#5A7A40"
                                   FontSize="11" Margin="0,8,0,0" LineHeight="18">
                            💡  Try: "Summarise the latest news on [topic]" · "Compare X vs Y with sources" · "Find and summarise the docs for [library]"
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#444444"
                                   FontSize="10" Margin="0,10,0,0">
                            ⌨  Enter to send · Shift+Enter for new line
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
