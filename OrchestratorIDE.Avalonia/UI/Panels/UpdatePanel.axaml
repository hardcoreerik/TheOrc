<UserControl x:Class="OrchestratorIDE.UI.Panels.UpdatePanel"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OrchestratorIDE.UI.Panels"
             Background="#0A0E0A">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16,20,20">

            <!-- ── Header ─────────────────────────────────────────────── -->
            <DockPanel Margin="0,0,0,16">
                <TextBlock Text="⬆" Foreground="#76B900" FontSize="20"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="UPDATE" FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                           Foreground="#D4D4D4" VerticalAlignment="Center"/>
                <TextBlock x:Name="TbStatusChip" Text=""
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#76B900" VerticalAlignment="Center"
                           Margin="14,0,0,2"/>
            </DockPanel>

            <!-- ── THIS NODE card ─────────────────────────────────────── -->
            <Border Background="#0E1410" BorderBrush="#2A3A2A" BorderThickness="1"
                    CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="THIS NODE"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                               Foreground="#4A6A4A"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="INSTALLED" FontFamily="Consolas" FontSize="9"
                                       Foreground="#666" Margin="0,0,0,2"/>
                            <TextBlock x:Name="TbInstalledVersion"
                                       Text="v?.?.?" FontFamily="Consolas" FontSize="22"
                                       FontWeight="Bold" Foreground="#D4D4D4"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="→" FontSize="18"
                                   Foreground="#444" VerticalAlignment="Bottom"
                                   HorizontalAlignment="Center" Margin="0,0,0,3"/>

                        <StackPanel Grid.Column="2" Orientation="Vertical">
                            <TextBlock Text="LATEST" FontFamily="Consolas" FontSize="9"
                                       Foreground="#666" Margin="0,0,0,2"/>
                            <TextBlock x:Name="TbLatestVersion"
                                       Text="—" FontFamily="Consolas" FontSize="22"
                                       FontWeight="Bold" Foreground="#76B900"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button x:Name="BtnCheckNow" Content="🔄  Check Now"
                                    Click="BtnCheckNow_Click"
                                    Padding="10,5"
                                    Background="#111" BorderBrush="#333" Foreground="#999"
                                    BorderThickness="1" FontSize="11"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TbReleaseName"
                                   Text="" FontFamily="Consolas" FontSize="11"
                                   Foreground="#888" VerticalAlignment="Center"/>

                        <Button x:Name="BtnUpdateNode"
                                Grid.Column="1"
                                Content="⬆  Update This Node"
                                Click="BtnUpdateNode_Click"
                                IsEnabled="False"
                                Padding="14,6"
                                Background="#1F3D00" BorderBrush="#76B900" Foreground="#A8CC80"
                                BorderThickness="1" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Build / download log ───────────────────────────────── -->
            <Border x:Name="BdrLog"
                    Background="#070D07" BorderBrush="#1A2A1A" BorderThickness="1"
                    CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                    IsVisible="False">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="BUILD LOG" FontFamily="Consolas" FontSize="9"
                                   FontWeight="Bold" Foreground="#4A6A4A"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnCancelUpdate" Content="✕ Cancel"
                                Click="BtnCancelUpdate_Click"
                                Padding="8,3"
                                Background="Transparent" BorderBrush="#553333" Foreground="#AA6666"
                                BorderThickness="1" FontSize="10"
                                HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                    </DockPanel>

                    <!-- Step indicators -->
                    <UniformGrid x:Name="UgSteps" Columns="5" Margin="0,0,0,8">
                        <Border x:Name="StepBorder0" CornerRadius="3" Padding="6,4" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock x:Name="StepIcon0" Text="○" FontFamily="Consolas" FontSize="10"
                                           Foreground="#444" HorizontalAlignment="Center"/>
                                <TextBlock Text=".NET SDK" FontFamily="Consolas" FontSize="8"
                                           Foreground="#555" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="StepBorder1" CornerRadius="3" Padding="6,4" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock x:Name="StepIcon1" Text="○" FontFamily="Consolas" FontSize="10"
                                           Foreground="#444" HorizontalAlignment="Center"/>
                                <TextBlock Text="Pull Src" FontFamily="Consolas" FontSize="8"
                                           Foreground="#555" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="StepBorder2" CornerRadius="3" Padding="6,4" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock x:Name="StepIcon2" Text="○" FontFamily="Consolas" FontSize="10"
                                           Foreground="#444" HorizontalAlignment="Center"/>
                                <TextBlock Text="Build" FontFamily="Consolas" FontSize="8"
                                           Foreground="#555" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="StepBorder3" CornerRadius="3" Padding="6,4" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock x:Name="StepIcon3" Text="○" FontFamily="Consolas" FontSize="10"
                                           Foreground="#444" HorizontalAlignment="Center"/>
                                <TextBlock Text="Stage" FontFamily="Consolas" FontSize="8"
                                           Foreground="#555" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="StepBorder4" CornerRadius="3" Padding="6,4">
                            <StackPanel>
                                <TextBlock x:Name="StepIcon4" Text="○" FontFamily="Consolas" FontSize="10"
                                           Foreground="#444" HorizontalAlignment="Center"/>
                                <TextBlock Text="Relaunch" FontFamily="Consolas" FontSize="8"
                                           Foreground="#555" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <ProgressBar x:Name="UpdateProgress" Height="3" Margin="0,0,0,8"
                                 Background="#1A2A1A" Foreground="#76B900"
                                 Value="0" Maximum="100"/>

                    <Border Background="#050A05" CornerRadius="3" Padding="8,6" Height="180">
                        <ScrollViewer x:Name="SvLog" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="TbLog"
                                     Background="Transparent" Foreground="#88AA88"
                                     FontFamily="Consolas" FontSize="10"
                                     BorderThickness="0" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── HIVE FLEET section (Warchief only) ────────────────── -->
            <Border x:Name="BdrFleet"
                    Background="#0E1410" BorderBrush="#2A3A2A" BorderThickness="1"
                    CornerRadius="6" Padding="16,14"
                    IsVisible="False">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👑" FontSize="13" VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="HIVE FLEET" FontFamily="Consolas" FontSize="9"
                                       FontWeight="Bold" Foreground="#CCA700"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TbFleetStatus" Text=""
                                       FontFamily="Consolas" FontSize="9"
                                       Foreground="#666" VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </StackPanel>
                        <Button x:Name="BtnRefreshFleet" Content="⟳"
                                Click="BtnRefreshFleet_Click"
                                Padding="6,3"
                                Background="Transparent" BorderBrush="#2A3A2A" Foreground="#666"
                                BorderThickness="1" FontSize="10"
                                HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                    </DockPanel>

                    <Border Background="#080E08" BorderBrush="#1A2A1A" BorderThickness="1"
                            CornerRadius="4" Margin="0,0,0,12">
                        <ItemsControl x:Name="IcFleet">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:FleetRow">
                                    <Grid Margin="12,7,12,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="{Binding NameColor}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Version}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="#888"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding StatusText}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="{Binding StatusColor}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Button x:Name="BtnDeployFleet"
                            Content="⬆  Deploy Update to Fleet"
                            Click="BtnDeployFleet_Click"
                            IsEnabled="False"
                            HorizontalAlignment="Right"
                            Padding="14,7"
                            Background="#1A1000" BorderBrush="#CCA700" Foreground="#CCA700"
                            BorderThickness="1" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
