<UserControl x:Class="OrchestratorIDE.UI.Panels.TrainingPitPanel"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OrchestratorIDE.UI.Panels"
             Background="{StaticResource Br.Bg.App}">

    <!--
    ═══════════════════════════════════════════════════════════════════
    TRAINING PIT PANEL — Phase 3C (Avalonia port)
    Dataset dashboard: inventory, harvest, review queue, pipeline stages.
    Whole page scrolls (right-side scrollbar) so the pipeline stages and
    review queue are always reachable regardless of window size. Pipeline
    stages (Generate Dataset / Orc Academy / The Foundry) carry numbered
    badges to read as a left-to-right production line, echoing the
    three-stage-card mockup. Inventory tiles read as stat cards (accent
    bar + large count) rather than plain list headers.
    ═══════════════════════════════════════════════════════════════════
    -->

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>    <!-- 0 header           -->
            <RowDefinition Height="180"/>     <!-- 1 inventory        -->
            <RowDefinition Height="Auto"/>    <!-- 2 night harvest    -->
            <RowDefinition Height="Auto"/>    <!-- 3 review captures  -->
            <RowDefinition Height="Auto"/>    <!-- 4 pipeline label   -->
            <RowDefinition Height="Auto"/>    <!-- 5 pipeline (3 cols)-->
            <RowDefinition Height="Auto"/>    <!-- 6 queue header     -->
            <RowDefinition Height="Auto"/>    <!-- 7 review queue     -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────── -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⛏ Training Pit" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource Br.Text.White}"/>
                <Border x:Name="PhaseBadge" Background="#1A2A10" BorderBrush="#3A5A20"
                        BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="10,0,0,0">
                    <TextBlock x:Name="PhaseText" Text="Phase 1" FontSize="10"
                               Foreground="#76B900" FontFamily="Consolas"/>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        DockPanel.Dock="Right" VerticalAlignment="Center">
                <Button x:Name="BtnPitBoss" Content="🏛 Pit Boss"
                        Click="BtnPitBoss_Click"
                        Padding="10,4" Margin="0,0,8,0"
                        Background="#3D2A00" BorderBrush="#E8A030" Foreground="#E8C080"
                        BorderThickness="1" FontSize="11"/>
                <Button x:Name="BtnRefresh" Content="⟳ Refresh"
                        Click="BtnRefresh_Click"
                        Padding="10,4"
                        Background="#111111" BorderBrush="#2A2A2A" Foreground="#999999"
                        BorderThickness="1" FontSize="11"/>
                <StackPanel x:Name="PnlVram" Orientation="Horizontal" Margin="12,0,0,0"
                            VerticalAlignment="Center" IsVisible="False">
                    <TextBlock x:Name="TbVram" Text="" FontSize="10" Foreground="#80A0C0"
                               FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ProgressBar x:Name="VramBar" Width="80" Height="6"
                                 Minimum="0" Maximum="100" Value="0"
                                 Background="#1A1A1A" Foreground="#4A9FD9"
                                 VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </DockPanel>

        <!-- ── Inventory: datasets / adapters / models (stat tiles) ─── -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Datasets -->
            <Border Grid.Column="0" Background="#101010" CornerRadius="6" Margin="0,0,6,0"
                    BorderBrush="#2A2A2A" BorderThickness="1" ClipToBounds="True">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="3" Background="#5FA030"/>
                    <DockPanel Margin="10,8">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,2">
                            <TextBlock Text="📦" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="DATASETS" FontSize="10" FontWeight="Bold"
                                       Foreground="#A8CC80" Margin="6,0,0,0" VerticalAlignment="Center"
                                       LetterSpacing="0.5"/>
                        </DockPanel>
                        <TextBlock x:Name="DatasetCount" DockPanel.Dock="Top" Text="0" FontSize="22"
                                   FontWeight="Bold" Foreground="{StaticResource Br.Text.White}"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="DatasetEmpty" DockPanel.Dock="Bottom"
                                   Text="No datasets found" FontSize="10" Foreground="#666666"
                                   FontStyle="Italic" Margin="2,4,0,0" IsVisible="False"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="DatasetList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:DatasetInfoAva">
                                        <Border Background="#0E0E0E" BorderBrush="#2A2A2A" BorderThickness="1"
                                                CornerRadius="3" Padding="8,5" Margin="0,0,0,4">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="#A8CC80"
                                                               VerticalAlignment="Center"/>
                                                    <Button Content="📁"
                                                            Click="DatasetOpenFolder_Click"
                                                            Tag="{Binding}"
                                                            DockPanel.Dock="Right"
                                                            Padding="4,1" Margin="2,0,0,0"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="#555555" FontSize="10"
                                                            ToolTip.Tip="Open folder"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding TotalCount}"
                                                               FontSize="10" Foreground="#666666"
                                                               FontFamily="Consolas"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"
                                                               VerticalAlignment="Center"/>
                                                </DockPanel>
                                                <!-- Notes (from .meta.json sidecar) -->
                                                <TextBlock IsVisible="{Binding HasNotes}"
                                                           Text="{Binding Notes}"
                                                           FontSize="9" Foreground="#80C0A0"
                                                           FontStyle="Italic" Margin="0,2,0,2"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <!-- New convention: show role/type/source -->
                                                <StackPanel IsVisible="{Binding IsNewConvention}">
                                                    <TextBlock Text="{Binding Role}" FontSize="9"
                                                               Foreground="#888888" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding DataType}" FontSize="9"
                                                               Foreground="#777777"/>
                                                    <TextBlock Text="{Binding Source}" FontSize="9"
                                                               Foreground="#666666" FontFamily="Consolas"/>
                                                    <TextBlock Text="{Binding CountsLine}" FontSize="9"
                                                               Foreground="#A8CC80" FontFamily="Consolas"/>
                                                    <TextBlock Text="⏳ in progress" FontSize="9"
                                                               Foreground="#CCA700"
                                                               IsVisible="{Binding InProgress}"/>
                                                </StackPanel>
                                                <!-- Legacy convention: just show source -->
                                                <TextBlock IsVisible="{Binding !IsNewConvention}"
                                                           Text="{Binding Source}" FontSize="9"
                                                           Foreground="#666666" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </DockPanel>
            </Border>

            <!-- Adapters -->
            <Border Grid.Column="1" Background="#100E10" CornerRadius="6" Margin="6,0,6,0"
                    BorderBrush="#2A2A2A" BorderThickness="1" ClipToBounds="True">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="3" Background="#A060D0"/>
                    <DockPanel Margin="10,8">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,2">
                            <TextBlock Text="🧬" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="ADAPTERS" FontSize="10" FontWeight="Bold"
                                       Foreground="#C080E0" Margin="6,0,0,0" VerticalAlignment="Center"
                                       LetterSpacing="0.5"/>
                        </DockPanel>
                        <TextBlock x:Name="AdapterCount" DockPanel.Dock="Top" Text="0" FontSize="22"
                                   FontWeight="Bold" Foreground="{StaticResource Br.Text.White}"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="AdapterEmpty" DockPanel.Dock="Bottom"
                                   Text="No adapters yet" FontSize="10" Foreground="#666666"
                                   FontStyle="Italic" Margin="2,4,0,0" IsVisible="False"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="AdapterList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:AdapterRowAva">
                                        <Border Background="#120E0A" BorderBrush="#2A2A2A" BorderThickness="1"
                                                CornerRadius="3" Padding="8,5" Margin="0,0,0,4">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                               FontWeight="SemiBold" Foreground="#E8C080"/>
                                                    <Border Background="{Binding TierBg}" CornerRadius="2"
                                                            Padding="5,1" HorizontalAlignment="Right"
                                                            DockPanel.Dock="Right">
                                                        <TextBlock Text="{Binding Tier}" FontSize="9"
                                                                   Foreground="{Binding TierFg}"/>
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Text="{Binding BaseModelShort}" FontSize="10"
                                                           Foreground="#999999" Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding MetricsLine}" FontSize="9"
                                                           Foreground="#A8CC80" FontFamily="Consolas"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </DockPanel>
            </Border>

            <!-- Models -->
            <Border Grid.Column="2" Background="#101414" CornerRadius="6" Margin="6,0,0,0"
                    BorderBrush="#2A2A2A" BorderThickness="1" ClipToBounds="True">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="3" Background="#4A9FD9"/>
                    <DockPanel Margin="10,8">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,2">
                            <TextBlock Text="🧠" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="MODELS" FontSize="10" FontWeight="Bold"
                                       Foreground="#80C0E0" Margin="6,0,0,0" VerticalAlignment="Center"
                                       LetterSpacing="0.5"/>
                        </DockPanel>
                        <TextBlock x:Name="ModelCount" DockPanel.Dock="Top" Text="0" FontSize="22"
                                   FontWeight="Bold" Foreground="{StaticResource Br.Text.White}"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="ModelEmpty" DockPanel.Dock="Bottom"
                                   Text="Ollama not reachable" FontSize="10" Foreground="#666666"
                                   FontStyle="Italic" Margin="2,4,0,0" IsVisible="False"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="ModelList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:ModelRowAva">
                                        <Border Background="#0E1214" BorderBrush="#2A2A2A" BorderThickness="1"
                                                CornerRadius="3" Padding="8,4" Margin="0,0,0,3">
                                            <DockPanel>
                                                <TextBlock Text="{Binding NameShort}" FontSize="11"
                                                           Foreground="#D4D4D4"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding SizeText}" FontSize="10"
                                                           Foreground="#80A0B0" FontFamily="Consolas"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ── Night harvest ──────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#101410" BorderBrush="#2A2A2A" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <StackPanel>
                <DockPanel>
                    <Ellipse x:Name="LiveDot" Width="9" Height="9" Fill="#76B900"
                             VerticalAlignment="Center" IsVisible="False" Margin="0,0,8,0"/>
                    <TextBlock Text="🌙" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Night harvest" FontSize="12" FontWeight="SemiBold"
                               Foreground="#D4D4D4" Margin="8,0,10,0" VerticalAlignment="Center"/>
                    <Border Background="#1A1A1A" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                        <TextBlock x:Name="HarvestStatus" Text="not running" FontSize="11"
                                   Foreground="#999999"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                DockPanel.Dock="Right">
                        <Button x:Name="BtnStartHarvest" Content="▶ Start harvest"
                                Click="BtnStartHarvest_Click"
                                Padding="10,4"
                                Background="#1F3D00" BorderBrush="#76B900" Foreground="#A8CC80"
                                BorderThickness="1" FontSize="11"/>
                        <Button x:Name="BtnStopHarvest"
                                Content="⏸ Finish current plan, then stop"
                                Click="BtnStopHarvest_Click"
                                Padding="10,4" Margin="8,0,0,0"
                                Background="#1A2A00" BorderBrush="#CCA700" Foreground="#CCA700"
                                BorderThickness="1" FontSize="11" IsEnabled="False"/>
                    </StackPanel>
                </DockPanel>

                <!-- Generator / judge pickers -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Generator" FontSize="11" Foreground="#999999"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip.Tip="Model that authors new goal prompts."/>
                    <ComboBox Grid.Column="1" x:Name="CbGenModel" FontSize="11" Margin="0,0,14,0"
                              SelectionChanged="CbGenModel_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:HarvestModelOptionAva">
                                <TextBlock Text="{Binding Display}" Foreground="{Binding TextBrush}" FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Column="2" Text="Judge" FontSize="11" Foreground="#999999"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip.Tip="Model that triages farmed captures for fabrication risk."/>
                    <ComboBox Grid.Column="3" x:Name="CbJudgeModel" FontSize="11" Margin="0,0,14,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:HarvestModelOptionAva">
                                <TextBlock Text="{Binding Display}" Foreground="{Binding TextBrush}" FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Column="4" Text="Goals/cycle" FontSize="11" Foreground="#999999"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="5" x:Name="TbGoalsPerCycle" Text="25" FontSize="11"
                             Background="#0E0E0E" Foreground="#D4D4D4" BorderBrush="#555555"
                             Padding="4,3" Margin="0,0,14,0"/>

                    <TextBlock Grid.Column="6" Text="Run until" FontSize="11" Foreground="#999999"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="7" x:Name="CbHarvestDuration" FontSize="11"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Review captures ────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#101014" BorderBrush="#2A2A2A" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Review captures" FontSize="12" FontWeight="SemiBold"
                               Foreground="#D4D4D4" Margin="8,0,10,0" VerticalAlignment="Center"/>
                    <Border Background="#1A1A1A" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                        <TextBlock x:Name="ReviewStatus" Text="0 staged · last: never"
                                   FontSize="11" Foreground="#999999"/>
                    </Border>
                    <Button x:Name="BtnCaptureIncrement" Content="⬇ Capture increment"
                            Click="BtnCaptureIncrement_Click"
                            HorizontalAlignment="Right" DockPanel.Dock="Right"
                            Padding="10,4" Margin="0,0,6,0"
                            Background="#1A2D1A" BorderBrush="#60A060" Foreground="#80C080"
                            BorderThickness="1" FontSize="11"/>
                    <Button x:Name="BtnReviewNow" Content="▶ Review branch"
                            Click="BtnReviewNow_Click"
                            HorizontalAlignment="Right" DockPanel.Dock="Right"
                            Padding="10,4"
                            Background="#1A1F3D" BorderBrush="#80A0E0" Foreground="#A0C0F0"
                            BorderThickness="1" FontSize="11"/>
                </DockPanel>

                <TextBlock x:Name="CaptureMarkerStatus" Text="" FontSize="10"
                           Foreground="#60A060" FontFamily="Consolas" Margin="0,4,0,0"/>

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" x:Name="ReviewProgressBar" Height="6"
                                 BorderThickness="0" Background="#111111" Foreground="#80A0E0"
                                 Maximum="50" Value="0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="ReviewThreshold"
                               Text="0 of 50 toward an experimental adapter"
                               FontSize="10" Foreground="#80A0B0" FontFamily="Consolas"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock x:Name="ReviewLatest" Text="" FontSize="10" Foreground="#666666"
                           FontStyle="Italic" Margin="0,6,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- ── Pipeline label ─────────────────────────────────────── -->
        <DockPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="Training pipeline" FontSize="11" FontWeight="Bold" Foreground="#777777"
                       LetterSpacing="0.5"/>
            <TextBlock Text="  — three stages, run left to right" FontSize="11" Foreground="#555555"
                       VerticalAlignment="Bottom"/>
        </DockPanel>

        <!-- ── Pipeline stages, spread across the screen (3 columns) ── -->
        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Stage 1: Generate Dataset ─────────────────────────── -->
            <Border Grid.Column="0" Background="#0A100E" BorderBrush="#1A3A2A" BorderThickness="1"
                    CornerRadius="6" Padding="12,10" Margin="0,0,6,0" VerticalAlignment="Top">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Border Background="#0A2A1A" BorderBrush="#40A070" BorderThickness="1"
                                CornerRadius="10" Width="20" Height="20" Margin="0,0,8,0">
                            <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="#80C0A0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="🧪" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="GENERATE DATASET" FontSize="12" FontWeight="Bold"
                                   Foreground="#80C0E0" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Border Background="#0A1A10" BorderBrush="#2A5A38" BorderThickness="1"
                                CornerRadius="3" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="→ Stage 2" FontSize="9" Foreground="#60A070"/>
                        </Border>
                    </DockPanel>
                    <TextBlock Text="Build synthetic Warchief boss plans — trains the orchestration adapter in ORC ACADEMY (Stage 2)"
                               FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBlock x:Name="GenBadge" Text="" FontSize="11" FontWeight="SemiBold"
                               Foreground="#76B900" Margin="0,0,0,8"/>

                    <!-- Generation target picker -->
                    <Border Background="#0C0C0C" BorderBrush="#2A2A2A" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="GENERATE TARGET" FontSize="9" FontWeight="Bold"
                                       Foreground="#555555" LetterSpacing="0.5" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CbGenTarget" FontSize="11" HorizontalAlignment="Stretch"
                                      SelectionChanged="CbGenTarget_SelectionChanged">
                                <ComboBoxItem x:Name="GenTargetBoss"
                                              Content="🏛  Boss Plans  →  ORC ACADEMY (Stage 2)"
                                              IsSelected="True"/>
                                <ComboBoxItem x:Name="GenTargetToolcaller"
                                              Content="⚒  Toolcaller Examples  →  THE FOUNDRY (Stage 3)"/>
                            </ComboBox>
                            <TextBlock x:Name="TbGenTargetNote"
                                       Text="Synthetic Warchief boss plans for the orchestration role. Output feeds ORC ACADEMY."
                                       FontSize="10" Foreground="#666666" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Model / key / count -->
                    <TextBlock Text="Model" FontSize="10" Foreground="#999999" Margin="0,0,0,2"
                               ToolTip.Tip="Local Ollama model that will generate boss plans. Avoid boss-family models (Gemma 4 12B) — they produce circular training data."/>
                    <ComboBox x:Name="CbGenDatasetModel" FontSize="11" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:HarvestModelOptionAva">
                                <TextBlock Text="{Binding Display}" Foreground="{Binding TextBrush}" FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Key" FontSize="10" Foreground="#999999" Margin="0,0,0,2"
                                       ToolTip.Tip="Output dataset key — saves train_{key}.jsonl and eval_{key}.jsonl"/>
                            <TextBox x:Name="TbGenKey" Text="v4gold" FontSize="11"
                                     Background="#0E0E0E" Foreground="#D4D4D4" BorderBrush="#555555"
                                     Padding="4,3" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Count" FontSize="10" Foreground="#999999" Margin="0,0,0,2"
                                       ToolTip.Tip="Target number of valid examples to generate (rejects don't count)."/>
                            <TextBox x:Name="TbGenCount" Text="200" FontSize="11"
                                     Background="#0E0E0E" Foreground="#D4D4D4" BorderBrush="#555555"
                                     Padding="4,3" FontFamily="Consolas"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="TbGenFieldHint" FontSize="10" Foreground="#666666" FontStyle="Italic"
                               TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Every CODER/UIDEVELOPER task must name its output file(s) in the title — plans that omit filenames are rejected automatically."/>

                    <WrapPanel Margin="0,0,0,8">
                        <Button x:Name="BtnGenStart" Content="🧪 Generate"
                                Click="BtnGenStart_Click"
                                Padding="10,4" Margin="0,0,8,4"
                                Background="#0A2A1A" BorderBrush="#40A070" Foreground="#80C0A0"
                                BorderThickness="1" FontSize="11"/>
                        <Button x:Name="BtnGenStop" Content="⏹ Stop"
                                Click="BtnGenStop_Click"
                                Padding="10,4" Margin="0,0,0,4"
                                Background="#2A0A0A" BorderBrush="#F44747" Foreground="#F09090"
                                BorderThickness="1" FontSize="11" IsEnabled="False"/>
                    </WrapPanel>

                    <!-- Live status -->
                    <DockPanel>
                        <Ellipse x:Name="GenDot" Width="9" Height="9" Fill="#40A070"
                                 VerticalAlignment="Center" IsVisible="False" Margin="0,0,8,0"/>
                        <TextBlock x:Name="GenStatus" Text="Idle — no dataset generated yet"
                                   FontSize="11" Foreground="#999999" VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </DockPanel>
                    <TextBlock x:Name="GenMetrics" Text="" FontSize="11" Foreground="#80C0A0"
                               FontFamily="Consolas" Margin="0,2,0,0"/>
                    <ProgressBar x:Name="GenBar" Height="8" Margin="0,6,0,0"
                                 BorderThickness="0" Background="#111111" Foreground="#40A070"
                                 Maximum="100" Value="0"/>

                    <!-- Post-generation action buttons (shown only after a successful run) -->
                    <Button x:Name="BtnGenLoadAcademy"
                            Content="→ Use this dataset in ORC ACADEMY (Stage 2)"
                            Click="BtnGenLoadAcademy_Click"
                            IsVisible="False"
                            Padding="10,4" Margin="0,0,0,4"
                            Background="#3D2A00" BorderBrush="#E8A030" Foreground="#E8C080"
                            BorderThickness="1" FontSize="11" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Selects this dataset in Stage 2 (ORC ACADEMY) so you can start training immediately"/>
                    <Button x:Name="BtnGenLoadFoundry"
                            Content="→ Captures ready — validate in THE FOUNDRY (Stage 3)"
                            Click="BtnGenLoadFoundry_Click"
                            IsVisible="False"
                            Padding="10,4" Margin="0,0,0,8"
                            Background="#2A1408" BorderBrush="#E06040" Foreground="#E0A080"
                            BorderThickness="1" FontSize="11" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Refreshes THE FOUNDRY gate card — click Validate captures there to proceed"/>

                    <!-- Notes editor + open shortcuts -->
                    <TextBox x:Name="TbGenNotes" Margin="0,10,0,8"
                             PlaceholderText="Dataset description / notes (saved to .meta.json)…"
                             FontSize="11" Background="#0E0E0E" Foreground="#D4D4D4"
                             BorderBrush="#333333" Padding="6,4"/>
                    <WrapPanel>
                        <Button x:Name="BtnGenSaveNotes" Content="💾 Save notes"
                                Click="BtnGenSaveNotes_Click"
                                Padding="8,4" Margin="0,0,6,4"
                                Background="#0A1A2A" BorderBrush="#406080" Foreground="#80A0C0"
                                BorderThickness="1" FontSize="11"
                                ToolTip.Tip="Save description to the dataset's .meta.json sidecar"/>
                        <Button x:Name="BtnGenOpenFolder" Content="📁 Folder"
                                Click="BtnGenOpenFolder_Click"
                                Padding="8,4" Margin="0,0,6,4"
                                Background="#111111" BorderBrush="#2A2A2A" Foreground="#999999"
                                BorderThickness="1" FontSize="11"
                                ToolTip.Tip="Open generator output folder (gen.log, gen_progress.json)"/>
                        <Button x:Name="BtnGenViewFile" Content="📄 File"
                                Click="BtnGenViewFile_Click"
                                Padding="8,4" Margin="0,0,0,4"
                                Background="#111111" BorderBrush="#2A2A2A" Foreground="#999999"
                                BorderThickness="1" FontSize="11"
                                ToolTip.Tip="Open the generated train_{key}.jsonl in the default editor"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ── Stage 2: Orc Academy ──────────────────────────────── -->
            <Border Grid.Column="1" Background="#14100A" BorderBrush="#3A2A10" BorderThickness="1"
                    CornerRadius="6" Padding="12,10" Margin="6,0,6,0" VerticalAlignment="Top">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Border Background="#3D2A00" BorderBrush="#E8A030" BorderThickness="1"
                                CornerRadius="10" Width="20" Height="20" Margin="0,0,8,0">
                            <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="#E8C080"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="🏛" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="ORC ACADEMY" FontSize="12" FontWeight="Bold"
                                   Foreground="#E8A030" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="Phase 3 — train the boss adapter from the reviewed dataset"
                               FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBlock x:Name="ForgeBadge" Text="" FontSize="11" FontWeight="SemiBold"
                               Foreground="#76B900" Margin="0,0,0,10"/>

                    <!-- Dataset provenance card -->
                    <Border Background="#0E0C08" BorderBrush="#2A2A2A" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="ForgeDataset" Text="Dataset: loading…"
                                       FontSize="12" FontWeight="SemiBold" Foreground="#E8C080"
                                       TextWrapping="Wrap"/>
                            <TextBlock FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="What it is: goal → plan examples teaching the boss to decompose coding goals into swarm plans.&#x0a;Intended use: QLoRA adapter (r16/α32, 4-bit NF4) for the orchestration role only."/>
                        </StackPanel>
                    </Border>

                    <!-- Base model + dataset + output pickers -->
                    <TextBlock Text="Base model" FontSize="10" Foreground="#999999" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CbBaseModel" FontSize="11" Margin="0,0,0,8" HorizontalAlignment="Stretch"
                              SelectionChanged="CbBaseModel_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:BaseModelOptionAva">
                                <TextBlock Text="{Binding Display}" Foreground="{Binding TextBrush}" FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="HF repo" FontSize="10" Foreground="#999999" Margin="0,0,0,2"/>
                    <TextBox x:Name="TbHfRepo" Text="google/gemma-4-12b-it" FontSize="11" Margin="0,0,0,8"
                             Background="#0E0E0E" Foreground="#D4D4D4"
                             BorderBrush="#555555" Padding="4,3" FontFamily="Consolas"/>

                    <TextBlock Text="Dataset" FontSize="10" Foreground="#999999" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CbDataset" FontSize="11" Margin="0,0,0,8" HorizontalAlignment="Stretch"
                              SelectionChanged="CbDataset_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:DatasetOptionAva">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayLabel}" Foreground="#D4D4D4" FontSize="11"/>
                                    <TextBlock Text="{Binding CountsText}" Foreground="#A8CC80"
                                               FontSize="10" FontFamily="Consolas" Margin="8,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Output" FontSize="10" Foreground="#999999" Margin="0,0,0,2"/>
                    <TextBox x:Name="TbOutputName" Text="lora_v1" FontSize="11" Margin="0,0,0,8"
                             Background="#0E0E0E" Foreground="#D4D4D4"
                             BorderBrush="#555555" Padding="4,3" FontFamily="Consolas"/>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="VRAM cap" FontSize="11" Foreground="#999999"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="CbVramCap" Width="110" Margin="6,0,0,0" FontSize="11"
                                  Background="#0E0E0E" Foreground="#D4D4D4">
                            <ComboBoxItem Content="No cap" IsSelected="True"/>
                            <ComboBoxItem Content="12 GB"/>
                            <ComboBoxItem Content="10 GB"/>
                            <ComboBoxItem Content="8 GB"/>
                            <ComboBoxItem Content="6 GB"/>
                        </ComboBox>
                    </DockPanel>
                    <CheckBox x:Name="ChkDryRun" Content="Dry run (validate only)" Margin="0,0,0,8"
                              FontSize="11" Foreground="#999999"/>

                    <WrapPanel Margin="0,0,0,8">
                        <Button x:Name="BtnForgeStart" Content="🏛 Start training"
                                Click="BtnForgeStart_Click"
                                Padding="10,4" Margin="0,0,8,4"
                                Background="#3D2A00" BorderBrush="#E8A030" Foreground="#E8C080"
                                BorderThickness="1" FontSize="11"/>
                        <Button x:Name="BtnForgeResume" Content="⏯ Resume"
                                Click="BtnForgeResume_Click"
                                Padding="10,4" Margin="0,0,8,4"
                                Background="#1A2A00" BorderBrush="#76B900" Foreground="#A8CC80"
                                BorderThickness="1" FontSize="11" IsEnabled="False"/>
                        <Button x:Name="BtnForgeStop" Content="⏹ Stop"
                                Click="BtnForgeStop_Click"
                                Padding="10,4" Margin="0,0,0,4"
                                Background="#2A0A0A" BorderBrush="#F44747" Foreground="#F09090"
                                BorderThickness="1" FontSize="11" IsEnabled="False"/>
                    </WrapPanel>

                    <!-- Live status -->
                    <DockPanel>
                        <Ellipse x:Name="ForgeDot" Width="9" Height="9" Fill="#E8A030"
                                 VerticalAlignment="Center" IsVisible="False" Margin="0,0,8,0"/>
                        <TextBlock x:Name="ForgeStatus" Text="Idle — adapter not yet trained"
                                   FontSize="11" Foreground="#999999" VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </DockPanel>
                    <TextBlock x:Name="ForgeMetrics" Text="" FontSize="11" Foreground="#E8C080"
                               FontFamily="Consolas" Margin="0,2,0,0"/>
                    <ProgressBar x:Name="ForgeBar" Height="8" Margin="0,6,0,0"
                                 BorderThickness="0" Background="#111111" Foreground="#E8A030"
                                 Maximum="100"/>
                </StackPanel>
            </Border>

            <!-- ── Stage 3: The Foundry ──────────────────────────────── -->
            <Border Grid.Column="2" Background="#140E0A" BorderBrush="#3A2018" BorderThickness="1"
                    CornerRadius="6" Padding="12,10" Margin="6,0,0,0" VerticalAlignment="Top">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Border Background="#2A1408" BorderBrush="#E06040" BorderThickness="1"
                                CornerRadius="10" Width="20" Height="20" Margin="0,0,8,0">
                            <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="#E0A080"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="⚒" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="THE FOUNDRY" FontSize="12" FontWeight="Bold"
                                   Foreground="#E06040" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Border Background="#1A0A06" BorderBrush="#5A2818" BorderThickness="1"
                                CornerRadius="3" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="swarm captures" FontSize="9" Foreground="#C06040"/>
                        </Border>
                    </DockPanel>
                    <TextBlock Text="Train specialist models from organic swarm captures — smallest safe model that passes the gate"
                               FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBlock x:Name="FoundryBadge" Text="" FontSize="11" FontWeight="SemiBold"
                               Foreground="#76B900" Margin="0,0,0,10"/>

                    <!-- Model family tracks (from training_pit/foundry/configs) -->
                    <ItemsControl x:Name="FoundryTrackList" Margin="0,0,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:FoundryTrackAva">
                                <Border Background="#0E0C0A" BorderBrush="#2A2A2A" BorderThickness="1"
                                        CornerRadius="3" Padding="8,5" Margin="0,0,0,4">
                                    <StackPanel>
                                        <DockPanel>
                                            <Border Background="{Binding StatusBg}" CornerRadius="2"
                                                    Padding="6,1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="9"
                                                           Foreground="{Binding StatusFg}"/>
                                            </Border>
                                            <TextBlock Text="{Binding SizeHypothesis}" FontSize="10"
                                                       Foreground="#80A0B0" FontFamily="Consolas"
                                                       HorizontalAlignment="Right" DockPanel.Dock="Right"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#E0A080" Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding BaseModel}" FontSize="10"
                                                   Foreground="#777777" Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Toolcaller pipeline: swarm captures → validate → export → train -->
                    <Border Background="#0A1018" BorderBrush="#1A2A38" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                        <StackPanel Spacing="3">
                            <TextBlock Text="TRAINING GATES" FontSize="9" FontWeight="Bold"
                                       Foreground="#4A6A88" LetterSpacing="0.5" Margin="0,0,0,4"/>
                            <DockPanel>
                                <TextBlock x:Name="GateStagedIcon" Text="●" FontSize="10" Width="14"
                                           Foreground="#E06040" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GateStagedLabel" Text="0 staged captures"
                                           FontSize="11" Foreground="#999999" VerticalAlignment="Center"/>
                                <TextBlock Text="gate: 150" FontSize="10" Foreground="#555555"
                                           FontFamily="Consolas" HorizontalAlignment="Right"
                                           DockPanel.Dock="Right" VerticalAlignment="Center"/>
                            </DockPanel>
                            <ProgressBar x:Name="GateStagedBar" Height="3" Maximum="150" Value="0"
                                         Background="#111111" Foreground="#E06040" Margin="14,0,0,2"/>
                            <DockPanel>
                                <TextBlock x:Name="GateAcceptedIcon" Text="●" FontSize="10" Width="14"
                                           Foreground="#E06040" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GateAcceptedLabel" Text="0 accepted captures"
                                           FontSize="11" Foreground="#999999" VerticalAlignment="Center"/>
                                <TextBlock Text="gate: 30 eval" FontSize="10" Foreground="#555555"
                                           FontFamily="Consolas" HorizontalAlignment="Right"
                                           DockPanel.Dock="Right" VerticalAlignment="Center"/>
                            </DockPanel>
                            <DockPanel Margin="0,2,0,0">
                                <TextBlock x:Name="GateExportIcon" Text="●" FontSize="10" Width="14"
                                           Foreground="#E06040" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GateExportLabel" Text="Dataset not exported yet"
                                           FontSize="11" Foreground="#999999" VerticalAlignment="Center"/>
                            </DockPanel>
                            <TextBlock x:Name="GateTrainEta" Text="" FontSize="10"
                                       Foreground="#80A0C0" FontFamily="Consolas" Margin="14,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <CheckBox x:Name="ChkFoundryDryRun" Content="Dry run" IsChecked="True" Margin="0,0,0,8"
                              FontSize="11" Foreground="#999999"
                              ToolTip.Tip="Validate gates + model/data load without a real training run. A real run is the explicit approval for ONE training experiment."/>
                    <WrapPanel Margin="0,0,0,8">
                        <Button x:Name="BtnFoundryValidate" Content="✔ Validate captures"
                                Click="BtnFoundryValidate_Click"
                                Padding="10,4" Margin="0,0,6,4"
                                Background="#0A1A2A" BorderBrush="#406080" Foreground="#80A0C0"
                                BorderThickness="1" FontSize="11"
                                ToolTip.Tip="Run the ToolcallerBench mechanical admission gate over staged captures"/>
                        <Button x:Name="BtnFoundryExport" Content="🧪 Export dataset"
                                Click="BtnFoundryExport_Click"
                                Padding="10,4" Margin="0,0,6,4"
                                Background="#0A2A1A" BorderBrush="#40A070" Foreground="#80C0A0"
                                BorderThickness="1" FontSize="11"
                                ToolTip.Tip="Validate + convert accepted toolcaller captures into train/eval JSONL"/>
                        <Button x:Name="BtnFoundryTrain" Content="⚒ Train toolcaller"
                                Click="BtnFoundryTrain_Click"
                                Padding="10,4" Margin="0,0,6,4"
                                Background="#2A1408" BorderBrush="#E06040" Foreground="#E0A080"
                                BorderThickness="1" FontSize="11"
                                ToolTip.Tip="Gated LoRA run per training_pit/foundry/configs/toolcaller_v0.json — preflight blocks until the dataset passes every gate"/>
                        <Button x:Name="BtnFoundryStop" Content="⏹ Stop"
                                Click="BtnFoundryStop_Click"
                                Padding="10,4" Margin="0,0,6,4"
                                Background="#2A0A0A" BorderBrush="#F44747" Foreground="#F09090"
                                BorderThickness="1" FontSize="11" IsEnabled="False"/>
                        <Button x:Name="BtnFoundryFolder" Content="📁"
                                Click="BtnFoundryFolder_Click"
                                Padding="8,4" Margin="0,0,0,4"
                                Background="#111111" BorderBrush="#2A2A2A" Foreground="#999999"
                                BorderThickness="1" FontSize="11"
                                ToolTip.Tip="Open training_pit/foundry"/>
                    </WrapPanel>

                    <!-- Live status -->
                    <DockPanel>
                        <Ellipse x:Name="FoundryDot" Width="9" Height="9" Fill="#E06040"
                                 VerticalAlignment="Center" IsVisible="False" Margin="0,0,8,0"/>
                        <TextBlock x:Name="FoundryStatus" Text="Idle — no specialist trained yet"
                                   FontSize="11" Foreground="#999999" VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </DockPanel>
                    <TextBlock x:Name="FoundryMetrics" Text="" FontSize="11" Foreground="#E0A080"
                               FontFamily="Consolas" Margin="0,2,0,0"/>
                    <ProgressBar x:Name="FoundryBar" Height="8" Margin="0,6,0,0"
                                 BorderThickness="0" Background="#111111" Foreground="#E06040"
                                 Maximum="100"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Queue header ───────────────────────────────────────── -->
        <DockPanel Grid.Row="6" Margin="0,0,0,6">
            <TextBlock Text="Your review queue" FontSize="12" FontWeight="SemiBold"
                       Foreground="#D4D4D4"/>
            <TextBlock Text="  — riskiest first. You make the final call."
                       FontSize="11" Foreground="#999999" VerticalAlignment="Bottom"/>
            <TextBlock x:Name="QueueCount" Text="" FontSize="11" Foreground="#999999"
                       HorizontalAlignment="Right" DockPanel.Dock="Right"
                       VerticalAlignment="Bottom"/>
        </DockPanel>

        <!-- ── Review queue ───────────────────────────────────────── -->
        <Border Grid.Row="7" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6"
                MaxHeight="480" ClipToBounds="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="QueueList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:QueueItem">
                            <Border BorderBrush="#2A2A2A" BorderThickness="0,0,0,1"
                                    Background="#0E0E0E">
                                <StackPanel>
                                    <!-- Header row (click to expand) -->
                                    <Button Click="QueueHeader_Click" Tag="{Binding}"
                                            Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            HorizontalContentAlignment="Stretch" Padding="0">
                                        <Border Background="#161616" Padding="10,7">
                                            <DockPanel>
                                                <Border Background="{Binding RiskBg}" CornerRadius="3"
                                                        Padding="7,1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding RiskLabel}" FontSize="10"
                                                               Foreground="{Binding RiskFg}"/>
                                                </Border>
                                                <TextBlock Text="{Binding Summary}" FontSize="12"
                                                           Foreground="#D4D4D4" Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding ScoreText}" FontSize="11"
                                                           Foreground="#999999"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </Button>

                                    <!-- Expanded detail panel -->
                                    <StackPanel IsVisible="{Binding IsExpanded}"
                                                Margin="10,8,10,10">
                                        <TextBlock Text="{Binding Goal}" FontSize="11"
                                                   Foreground="#999999" TextWrapping="Wrap"
                                                   Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding TaskChips}"
                                                      Margin="0,0,0,8">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#141814" BorderBrush="#2A2A2A"
                                                            BorderThickness="1" CornerRadius="3"
                                                            Padding="7,2" Margin="0,0,6,4">
                                                        <TextBlock Text="{Binding}" FontSize="10"
                                                                   Foreground="#A8CC80"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding JudgeNote}" FontSize="11"
                                                   Foreground="#CCA700" TextWrapping="Wrap"
                                                   Margin="0,0,0,8"
                                                   IsVisible="{Binding HasJudgeNote}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✓ Keep it"
                                                    Click="BtnKeepSilver_Click" Tag="{Binding}"
                                                    Padding="10,4"
                                                    Background="#1F3D00" BorderBrush="#76B900"
                                                    Foreground="#76B900" BorderThickness="1"
                                                    FontSize="11"/>
                                            <Button Content="★ Keep — top quality"
                                                    Click="BtnKeepGold_Click" Tag="{Binding}"
                                                    Padding="10,4" Margin="8,0,0,0"
                                                    Background="#1A2A00" BorderBrush="#CCA700"
                                                    Foreground="#CCA700" BorderThickness="1"
                                                    FontSize="11"/>
                                            <Button Content="✕ Throw out"
                                                    Click="BtnReject_Click" Tag="{Binding}"
                                                    Padding="10,4" Margin="8,0,0,0"
                                                    Background="#2A0A0A" BorderBrush="#5A0000"
                                                    Foreground="#F44747" BorderThickness="1"
                                                    FontSize="11"/>
                                            <Button Content="📄 See full plan"
                                                    Click="BtnOpenCapture_Click" Tag="{Binding}"
                                                    Padding="10,4" Margin="8,0,0,0"
                                                    Background="#111111" BorderBrush="#2A2A2A"
                                                    Foreground="#999999" BorderThickness="1"
                                                    FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
