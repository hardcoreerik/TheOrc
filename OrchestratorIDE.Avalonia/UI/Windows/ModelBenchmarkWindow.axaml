<Window x:Class="OrchestratorIDE.UI.Windows.ModelBenchmarkWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="960"
        Height="720"
        MinWidth="800"
        MinHeight="520"
        Background="#111411"
        Title="Model Benchmark"
        AutomationProperties.AutomationId="ModelBenchmarkWindow.Root">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#141814"
                BorderBrush="#2E3A2E"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="Model Benchmark"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#76B900"/>
                    <TextBlock x:Name="TbSubtitle"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#888888"
                               Text="Context Fabric reader/reviewer benchmark results for native GGUF models"/>
                </StackPanel>
                <Button x:Name="BtnScan"
                        Grid.Column="1"
                        Content="Scan CF Runs"
                        Click="BtnScan_Click"
                        VerticalAlignment="Center"
                        Background="#1B2C1B"
                        Foreground="#76B900"
                        BorderBrush="#3A5A1A"
                        Padding="12,6"
                        ToolTip.Tip="Scan .orc/adversarial/ for existing CF-7 gate results"/>
            </Grid>
        </Border>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1"
                      Padding="16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ItemsPanel" Spacing="10"/>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="#141814"
                BorderBrush="#2E3A2E"
                BorderThickness="0,1,0,0"
                Padding="12">
            <DockPanel>
                <TextBlock x:Name="TbStatus"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="#888888"/>

                <Button Content="Run New Benchmark…"
                        DockPanel.Dock="Left"
                        Margin="12,0,0,0"
                        IsEnabled="False"
                        Background="#141814"
                        Foreground="#555555"
                        BorderBrush="#2A2A2A"
                        Padding="10,6"
                        ToolTip.Tip="Coming in Phase 2 — run a full CF-7 benchmark on any installed GGUF model"/>

                <Button Content="Close"
                        Click="BtnClose_Click"
                        HorizontalAlignment="Right"
                        Background="#1E251E"
                        Foreground="#D4D4D4"
                        BorderBrush="#2E3A2E"
                        Padding="10,6"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
