<Window x:Class="OrchestratorIDE.UI.Windows.ModelLibraryWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="900"
        Height="680"
        MinWidth="760"
        MinHeight="520"
        Background="#111411"
        Title="Model Library"
        AutomationProperties.AutomationId="ModelLibraryWindow.Root">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                Background="#141814"
                BorderBrush="#2E3A2E"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel>
                <TextBlock Text="Model Library"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#76B900"/>
                <TextBlock x:Name="TbStatus"
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="#D4D4D4"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Padding="16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ItemsPanel" Spacing="8"/>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#141814"
                BorderBrush="#2E3A2E"
                BorderThickness="0,1,0,0"
                Padding="12">
            <DockPanel>
                <Button x:Name="BtnOpenDownloader"
                        DockPanel.Dock="Left"
                        Content="Open Downloader"
                        Click="BtnOpenDownloader_Click"
                        Background="#1E251E"
                        Foreground="#D4D4D4"
                        BorderBrush="#2E3A2E"
                        Padding="10,6"/>

                <Button Content="Close"
                        Click="BtnClose_Click"
                        HorizontalAlignment="Right"
                        Background="#1E251E"
                        Foreground="#D4D4D4"
                        BorderBrush="#2E3A2E"
                        Padding="10,6"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
