<Window x:Class="OrchestratorIDE.UI.Windows.ChatModelBenchWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1040"
        Height="760"
        MinWidth="820"
        MinHeight="560"
        Background="#111411"
        Title="Model Bench"
        AutomationProperties.AutomationId="ChatModelBenchWindow.Root">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#141814"
                BorderBrush="#2E3A2E"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel>
                <TextBlock Text="Model Bench"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#76B900"/>
                <TextBlock Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#888888"
                           Text="General chat quality and 'uncensored ability' (over-refusal) ranking across installed models. Every case here has a legitimate answer -- this measures wrongful refusal, not jailbreak resistance."
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Body: model picker (left) + results (right) -->
        <Grid Grid.Row="1" ColumnDefinitions="260,1,*" Margin="0">

            <!-- Model picker -->
            <DockPanel Grid.Column="0" Margin="12">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="MODELS" Foreground="#888888" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                        <Button x:Name="BtnSelectAll" Content="All" Click="BtnSelectAll_Click"
                                FontSize="10" Padding="6,2" Background="#1B2C1B" Foreground="#76B900" BorderBrush="#3A5A1A"/>
                        <Button x:Name="BtnSelectNone" Content="None" Click="BtnSelectNone_Click"
                                FontSize="10" Padding="6,2" Background="#1E1414" Foreground="#CA6A6A" BorderBrush="#5A2A2A"/>
                    </StackPanel>
                </DockPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ModelListPanel" Spacing="2"/>
                </ScrollViewer>
            </DockPanel>

            <Border Grid.Column="1" Background="#2E3A2E"/>

            <!-- Results -->
            <ScrollViewer Grid.Column="2" Padding="16" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ResultsPanel" Spacing="8"/>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="#141814"
                BorderBrush="#2E3A2E"
                BorderThickness="0,1,0,0"
                Padding="12">
            <DockPanel>
                <TextBlock x:Name="TbStatus"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="#888888"/>

                <Button x:Name="BtnRun"
                        Content="▶  Run Bench"
                        Click="BtnRun_Click"
                        DockPanel.Dock="Left"
                        Margin="12,0,0,0"
                        Background="#1B2C1B"
                        Foreground="#76B900"
                        BorderBrush="#3A5A1A"
                        Padding="12,6"/>

                <Button Content="Close"
                        Click="BtnClose_Click"
                        HorizontalAlignment="Right"
                        Background="#1E251E"
                        Foreground="#D4D4D4"
                        BorderBrush="#2E3A2E"
                        Padding="10,6"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
