<Window x:Class="OrchestratorIDE.UI.Windows.AgentRulesWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:OrchestratorIDE.UI.Windows"
        Width="980"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        Background="#111411"
        Title="Agent Rules"
        AutomationProperties.AutomationId="AgentRulesWindow.Root">

    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="320,*">
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#141814"
                BorderBrush="#2E3A2E"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel>
                <TextBlock x:Name="TbTitle"
                           Text="Agent Rules"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#76B900"/>
                <TextBlock x:Name="TbSubtitle"
                           Margin="0,4,0,0"
                           FontSize="11"
                           Foreground="#7A8A6A"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="TbStatus"
                           Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="#D4D4D4"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0"
                Background="#101510"
                BorderBrush="#2E3A2E"
                BorderThickness="0,0,1,0"
                Padding="12">
            <StackPanel Spacing="10">
                <TextBlock Text="Presets"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#D4D4D4"/>

                <ListBox x:Name="LstPresets"
                         SelectionChanged="LstPresets_SelectionChanged"
                         Background="#101510"
                         BorderBrush="#2E3A2E"
                         Foreground="#D4D4D4"
                         AutomationProperties.AutomationId="AgentRulesWindow.Presets">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="windows:AgentPresetItem">
                            <StackPanel Margin="0,3" Spacing="2">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="#D4D4D4"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="10"
                                           Foreground="#7A8A6A"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Background="#141814"
                        BorderBrush="#2E3A2E"
                        BorderThickness="1"
                        Padding="10">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Actions"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#D4D4D4"/>
                        <Button x:Name="BtnApplyPreset"
                                Content="Apply Preset"
                                Click="BtnApplyPreset_Click"
                                IsEnabled="False"
                                Background="#1E251E"
                                Foreground="#D4D4D4"
                                BorderBrush="#2E3A2E"
                                Padding="10,6"
                                AutomationProperties.AutomationId="AgentRulesWindow.ApplyPreset"/>
                        <Button x:Name="BtnOpenExisting"
                                Content="Open Existing"
                                Click="BtnOpenExisting_Click"
                                Background="#1E251E"
                                Foreground="#D4D4D4"
                                BorderBrush="#2E3A2E"
                                Padding="10,6"/>
                        <Button x:Name="BtnOpenBlank"
                                Content="Create Blank Rules"
                                Click="BtnOpenBlank_Click"
                                Background="#1E251E"
                                Foreground="#D4D4D4"
                                BorderBrush="#2E3A2E"
                                Padding="10,6"/>
                        <Button x:Name="BtnClearGlobal"
                                Content="Clear Global Agent"
                                Click="BtnClearGlobal_Click"
                                Background="#2A1919"
                                Foreground="#F3C3C3"
                                BorderBrush="#5A2A2A"
                                Padding="10,6"
                                IsVisible="False"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1"
                Background="#0F140F"
                Padding="14">
            <Grid RowDefinitions="Auto,*">
                <TextBlock x:Name="TbPreviewTitle"
                           Text="Preview"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#D4D4D4"/>

                <TextBox x:Name="TbPreview"
                         Grid.Row="1"
                         Margin="0,10,0,0"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="#0B0F0B"
                         Foreground="#D4D4D4"
                         BorderBrush="#2E3A2E"
                         Padding="12"
                         AutomationProperties.AutomationId="AgentRulesWindow.Preview"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="#141814"
                BorderBrush="#2E3A2E"
                BorderThickness="0,1,0,0"
                Padding="12">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="Close"
                        Click="BtnClose_Click"
                        Background="#1E251E"
                        Foreground="#D4D4D4"
                        BorderBrush="#2E3A2E"
                        Padding="10,6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
