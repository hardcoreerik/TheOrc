<UserControl x:Class="OrchestratorIDE.UI.Controls.ModelPickerPopup"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:OrchestratorIDE.UI.Controls"
             Width="480" MaxHeight="500"
             Background="#252526">
    <Border Background="#252526" BorderBrush="#454545" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,*">
            <!-- Header -->
            <DockPanel Grid.Row="0" Background="#1F1F1F"
                       LastChildFill="False"
                       Margin="0,0,0,0">
                <TextBlock DockPanel.Dock="Left"
                           Text="Select Model" Foreground="#999999"
                           FontSize="11" FontWeight="Bold"
                           Margin="10,6,0,6" VerticalAlignment="Center"/>
                <TextBlock x:Name="TbInstalled" DockPanel.Dock="Right"
                           Text="" Foreground="#555555"
                           FontSize="11" Margin="0,6,10,6"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Model list -->
            <ListBox x:Name="ModelList"
                     Grid.Row="1"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     KeyDown="ModelList_KeyDown"
                     DoubleTapped="ModelList_DoubleTapped"
                     SelectionChanged="ModelList_SelectionChanged">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,5"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#094771"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="controls:ModelItemVm">
                        <Grid ColumnDefinitions="16,*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding ActiveDot}"
                                       Foreground="#4EC9B0" FontSize="8"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{Binding NameColor}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}"
                                           Foreground="#666666" FontSize="11"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                        HorizontalAlignment="Right" Margin="4,0,0,0">
                                <Border Background="#1A3A1A" CornerRadius="2"
                                        Padding="4,1" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding ContextBadge}"
                                               Foreground="#76B900" FontSize="10"/>
                                </Border>
                                <Border Background="#1A1A3A" CornerRadius="2" Padding="4,1">
                                    <TextBlock Text="{Binding ToolSetBadge}"
                                               Foreground="#569CD6" FontSize="10"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
