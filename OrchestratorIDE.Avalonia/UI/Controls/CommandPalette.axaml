<UserControl x:Class="OrchestratorIDE.UI.Controls.CommandPalette"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:OrchestratorIDE.UI.Controls"
             xmlns:converters="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
             x:DataType="controls:CommandPalette"
             Width="560" MaxHeight="400"
             Background="#1C1C1C">
    <Border Background="#252526" BorderBrush="#454545" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,*">
            <!-- Search box -->
            <Border Grid.Row="0" Background="#1F1F1F"
                    BorderBrush="#444444" BorderThickness="0,0,0,1"
                    Padding="10,6">
                <Grid>
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="Type a command or search…"
                               Foreground="#666666" FontSize="14"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <TextBox x:Name="SearchBox"
                             Background="Transparent" Foreground="#CCCCCC"
                             CaretBrush="#76B900" BorderThickness="0"
                             FontSize="14" Padding="0"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown"/>
                </Grid>
            </Border>

            <!-- Results list -->
            <ListBox x:Name="ResultsList"
                     Grid.Row="1"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     KeyDown="ResultsList_KeyDown"
                     DoubleTapped="ResultsList_DoubleTapped">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,5"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#094771"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="controls:PaletteCommand">
                        <Grid ColumnDefinitions="22,*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                       Foreground="{Binding IconColor}"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="#CCCCCC" FontSize="12"/>
                                <TextBlock Text="{Binding Detail}"
                                           Foreground="#666666" FontSize="11"
                                           IsVisible="{Binding Detail, Converter={x:Static converters:StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Shortcut}"
                                       Foreground="#555555" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
