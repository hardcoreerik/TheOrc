 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a PowerShell script to automate Windows service management"}, {"role": "assistant", "content": "{\"plan\":\"Use built-in PowerShell cmdlets like Get-Service, Start-Service for automating Windows service management tasks\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research existing PowerShell cmdlets for Windows service management\",\"description\":\"Identify and document the relevant PowerShell cmdlets that can be used for managing Windows services.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create a PowerShell script to list all Windows services\",\"description\":\"Develop a PowerShell script named 'ListServices.ps1' that retrieves and displays a list of all installed Windows services on the system.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create a PowerShell script to start a Windows service\",\"description\":\"Develop a PowerShell script named 'StartService.ps1' that allows starting a specified Windows service by name.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify the functionality of the created scripts\",\"description\":\"Test both 'ListServices.ps1' and 'StartService.ps1' on a test system to ensure they work as expected.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "202