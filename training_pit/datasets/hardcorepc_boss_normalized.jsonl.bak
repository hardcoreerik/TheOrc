orc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T05:40:03", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 609. Plan generated by qwen2.5-coder:7b."}}
