 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create a PowerShell script to backup all configurations from the embedded device to a local drive."}, {"role": "assistant", "content": "{\"plan\":\"Identify configuration files, create a script to copy them to a local drive, and validate the backup process\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify Configuration Files and Locations\",\"description\":\"Research the locations of all configuration files on the embedded device.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create PowerShell Script for Backup\",\"description\":\"Develop a PowerShell script named 'BackupConfigurations.ps1' that copies all identified configuration files to a specified local drive.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Validate Backup Script\",\"description\":\"Test the backup script on a development environment to ensure it correctly identifies and backs up all configuration files.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T05:25:40", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 577. Plan generated by qwen2.5-coder:7b."}}
