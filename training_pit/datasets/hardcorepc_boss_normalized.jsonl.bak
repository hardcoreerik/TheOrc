 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Refactor a large PowerShell script into smaller, reusable functions."}, {"role": "assistant", "content": "{\"plan\":\"Analyze script, create modular functions for file and network tasks, test each function's correctness\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Analyze existing PowerShell script\",\"description\":\"Review the entire script to understand its functionality and identify logical segments that can be refactored into smaller, reusable functions.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create function for file operations\",\"description\":\"Refactor file-related operations into a new function named `HandleFileOperations` in a file called `FileUtils.ps1`.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create function for network requests\",\"description\":\"Refactor network request logic into a new function named `MakeNetworkRequests` in a file called `NetworkUtils.ps1`.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify functionality of refactored functions\",\"description\":\"Test each newly created function to ensure it performs as expected and the script runs without errors after refactoring.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T01:58:24", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 164. Plan generated by qwen2.5-coder:7b."}}
