 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a C#/WPF desktop application for employee time tracking."}, {"role": "assistant", "content": "{\"plan\":\"Design a C#/WPF application with a data model, main window, and time entry functionality\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research WPF Time Tracking Features\",\"description\":\"Gather information on available WPF libraries and frameworks that can be used for developing a time tracking application.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Design Data Model\",\"description\":\"Create a C# class library defining the data model for employees, tasks, and time entries (e.g., Employee.cs, Task.cs, TimeEntry.cs).\"},{\"role\":\"UIDEVELOPER\",\"priority\":2,\"title\":\"Develop Main Application Window\",\"description\":\"Design and implement the main WPF window with controls for adding tasks, starting/stopping timers, and viewing time entries (e.g., MainWindow.xaml).\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Time Entry Functionality\",\"description\":\"Test the application to ensure that time entries can be accurately started, stopped, and recorded for each task.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T05:15:32", "notes": "Normalized from hardcorepc_raw_ov