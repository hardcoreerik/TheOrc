 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a tool to convert batch files into PowerShell scripts for automation."}, {"role": "assistant", "content": "{\"plan\":\"Develop a C# tool by researching batch file syntax and PowerShell scripting, creating a converter class, and testing accuracy\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research Batch File Syntax\",\"description\":\"Gather documentation and examples of common batch file commands and their syntax.\"},{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Study PowerShell Scripting Basics\",\"description\":\"Learn the basics of PowerShell scripting, including cmdlets, variables, and functions.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create BatchFileToPowerShellConverter.cs\",\"description\":\"Develop a C# class named 'BatchFileToPowerShellConverter' that can parse batch files and convert them into PowerShell scripts.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Test Conversion Accuracy\",\"description\":\"Verify that the tool accurately converts various batch file commands to their PowerShell equivalents.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T02:15:33", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 195. Plan generated by qwen2.5-coder:7b."}}
