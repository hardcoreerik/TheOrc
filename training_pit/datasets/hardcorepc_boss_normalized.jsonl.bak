 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Write unit tests for all public methods in the current project to ensure code quality."}, {"role": "assistant", "content": "{\"plan\":\"Identify public methods, create unit tests, verify coverage\",\"tasks\":[{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Identify all public methods\",\"description\":\"List all public methods across all classes in the project.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create unit test class for each method\",\"description\":\"For each identified method, create a corresponding unit test class in a separate file. Name the class according to the method it tests (e.g., UserServiceTests.cs if testing methods from UserService.cs).\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify test coverage\",\"description\":\"Run the unit tests and ensure that each public method is tested at least once. Document any untested methods.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T01:55:16", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 158. Plan generated by qwen2.5-coder:7b."}}
