 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: 20. Document the PowerShell script for system performance monitoring."}, {"role": "assistant", "content": "{\"plan\":\"Review scripts, document parameters/outputs, verify functionality, identify KPIs\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Review existing PowerShell scripts\",\"description\":\"Examine any existing PowerShell scripts used for system performance monitoring to understand their current functionality and limitations.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Document script parameters and outputs\",\"description\":\"Create a documentation file (e.g., PerformanceMonitoringScript.md) that outlines all parameters, return values, and any other relevant information for the PowerShell script.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify script functionality\",\"description\":\"Test the PowerShell script to ensure it accurately monitors system performance metrics without errors or unexpected behavior.\"},{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify key performance indicators (KPIs)\",\"description\":\"Determine which KPIs are most relevant for monitoring and document them in the documentation file, explaining their significance to system health and performance.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "