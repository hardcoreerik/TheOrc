 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a C#/WPF desktop application to manage inventory for a small retail store."}, {"role": "assistant", "content": "{\"plan\":\"Define requirements, create main window, design form, test functionality\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Define Application Requirements\",\"description\":\"Gather and document the functional and non-functional requirements for the inventory management system.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create Main Window\",\"description\":\"Develop the main window (MainWindow.xaml) with controls for displaying inventory items, adding new items, editing existing ones, and deleting items.\"},{\"role\":\"UIDEVELOPER\",\"priority\":2,\"title\":\"Design Inventory Item Entry Form\",\"description\":\"Create a form (InventoryItemEntryForm.xaml) for entering details of new or edited inventory items including name, quantity, price, etc.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Test Application Functionality\",\"description\":\"Verify that all features are working as expected, including adding, editing, deleting, and displaying inventory items.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T04:36:35", "notes": "Normalized from hardcorepc_raw_overnight.js