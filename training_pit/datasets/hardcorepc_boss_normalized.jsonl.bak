 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Refactor the testing framework to improve coverage and reliability."}, {"role": "assistant", "content": "{\"plan\":\"Identify missing tests, refactor existing ones, implement new utilities, and verify improvements iteratively\",\"tasks\":[{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Identify missing test cases\",\"description\":\"Review existing tests and identify areas with low or no coverage, ensuring all functionality is tested.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Refactor existing tests\",\"description\":\"Simplify and optimize existing tests to improve reliability and readability without reducing coverage.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Implement new test utilities\",\"description\":\"Create helper classes or methods in a file named Utilities/TestingUtilities.cs to simplify common testing tasks.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify test framework improvements\",\"description\":\"Run the entire test suite and verify that coverage has increased and all tests are passing reliably.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T03:01:23", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 295. Plan generated by qwen2.5-coder:7b."}}
