 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Integrate an external device for real-time monitoring with the C#/WPF application."}, {"role": "assistant", "content": "{\"plan\":\"Identify suitable external device API, create communication service, design real-time monitoring UI, and verify integration\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify Suitable External Device API\",\"description\":\"Research and identify a suitable API or SDK provided by the external device manufacturer for real-time monitoring.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create Device Communication Service\",\"description\":\"Implement a service (e.g., Services/DeviceCommunicationService.cs) to handle communication with the external device using the identified API.\"},{\"role\":\"UIDEVELOPER\",\"priority\":2,\"title\":\"Design Real-Time Monitoring UI\",\"description\":\"Design and implement the user interface elements in MainWindow.xaml to display real-time data from the external device.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Device Integration\",\"description\":\"Test the integration of the external device with the application to ensure it receives and displays real-time data correctly.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T00