 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop an IoT device application in C# that reads temperature data from sensors every 5 minutes and stores it locally."}, {"role": "assistant", "content": "{\"plan\":\"Develop a C# IoT app using researched libraries, implement services for temperature data reading and local storage, and test the data reading functionality\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research IoT sensor libraries for C#\",\"description\":\"Identify suitable libraries and frameworks for interfacing with IoT sensors in C#, focusing on temperature data.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create TemperatureSensorService.cs\",\"description\":\"Develop a class named TemperatureSensorService that will handle the communication with the temperature sensors and reading of data every 5 minutes.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Implement DataStorageService.cs\",\"description\":\"Create a service named DataStorageService responsible for storing the temperature data locally, such as in a text file or database.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify sensor data reading functionality\",\"description\":\"Test the TemperatureSensorService to ensure it correctly reads temperature data every 5 minutes from the sensors.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_bos