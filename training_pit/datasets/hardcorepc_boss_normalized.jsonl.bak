 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Refactor a PowerShell module to use parameterized queries for database operations."}, {"role": "assistant", "content": "{\"plan\":\"Review scripts, refactor SQL with parameters, validate changes\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Review existing PowerShell scripts\",\"description\":\"Identify all database operations within the current PowerShell module and understand their parameters.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Refactor SQL queries to use parameterized queries\",\"description\":\"Modify each SQL query in the module to use parameterized queries to prevent SQL injection. Create a new file Parameters.ps1 for storing query parameters if necessary.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Validate refactoring results\",\"description\":\"Execute all existing scripts and ensure that they still function correctly with the new parameterized queries. Check for any errors or unexpected behavior.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T05:59:31", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 639. Plan generated by qwen2.5-coder:7b."}}
