 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a PowerShell script to monitor system performance and alert on issues"}, {"role": "assistant", "content": "{\"plan\":\"Develop a PowerShell script by researching system monitoring tools, coding the script to track performance metrics, and testing it for accurate alerts on issues\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research System Performance Monitoring Tools\",\"description\":\"Gather information on existing PowerShell modules or scripts for monitoring system performance.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Develop Performance Monitoring Script\",\"description\":\"Create a PowerShell script named 'PerformanceMonitor.ps1' that collects CPU, memory, and disk usage data.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Test Performance Monitoring Script\",\"description\":\"Run the 'PerformanceMonitor.ps1' script on various system configurations to ensure it accurately captures performance data.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T06:12:45", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 689. Plan generated by qwen2.5-coder:7b."}}
