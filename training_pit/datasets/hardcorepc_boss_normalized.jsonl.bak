 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Integrate an existing database with the WPF application for storing user preferences"}, {"role": "assistant", "content": "{\"plan\":\"Identify compatible database, set up EF context, define data models, verify connection\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify Database Compatibility\",\"description\":\"Research and document which existing databases (e.g., SQL Server, SQLite) are compatible with WPF applications.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Set Up Entity Framework Context\",\"description\":\"Create a new Entity Framework context class (e.g., UserPreferencesContext.cs) to interact with the chosen database.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Define Data Models\",\"description\":\"Design and implement data models in C# (e.g., UserPreference.cs) that represent user preferences.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Database Connection\",\"description\":\"Test the connection between the WPF application and the database to ensure proper setup.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T06:13:21", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 691. Plan generated by qwen2.5-coder:7b."}}
