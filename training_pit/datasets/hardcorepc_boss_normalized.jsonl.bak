 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop an automated script to update all dependencies in the project's NuGet packages."}, {"role": "assistant", "content": "{\"plan\":\"Identify NuGet, create script, test update\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify NuGet Package Management Tool\",\"description\":\"Determine which NuGet package management tool is being used in the project (e.g., NuGet CLI, Paket).\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create Dependency Update Script\",\"description\":\"Write a PowerShell script named 'UpdateDependencies.ps1' that updates all NuGet packages using the identified tool.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Test Dependency Update Script\",\"description\":\"Verify that the 'UpdateDependencies.ps1' script successfully updates all NuGet packages in a local development environment without breaking any functionality.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T01:16:22", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 92. Plan generated by qwen2.5-coder:7b."}}
