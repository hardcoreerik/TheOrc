 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a PowerShell script to monitor disk space usage."}, {"role": "assistant", "content": "{\"plan\":\"Create and test a PowerShell script named DiskSpaceMonitor.ps1 to monitor disk space usage\",\"tasks\":[{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create DiskSpaceMonitor.ps1\",\"description\":\"Write a PowerShell script named DiskSpaceMonitor.ps1 that monitors disk space usage on the system.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Test Script Functionality\",\"description\":\"Verify that the DiskSpaceMonitor.ps1 script correctly reports disk space usage and handles different drive letters.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T00:19:50", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 834. Plan generated by qwen2.5-coder:7b."}}
