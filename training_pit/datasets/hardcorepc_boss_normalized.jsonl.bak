 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a data visualization tool for displaying trends in CSV data."}, {"role": "assistant", "content": "{\"plan\":\"Identify libraries, create service, design component, validate display\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify Data Visualization Libraries\",\"description\":\"Research and select appropriate data visualization libraries compatible with JavaScript/React that can handle CSV data and create interactive charts.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create Data Service\",\"description\":\"Develop a service (e.g., Services/DataService.cs) to read and parse the CSV file, converting it into a format suitable for visualization.\"},{\"role\":\"UIDEVELOPER\",\"priority\":2,\"title\":\"Design Visualization Component\",\"description\":\"Create a React component (e.g., components/LineChart.js) that uses the selected library to display trends from the CSV data interactively.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Validate Data Display\",\"description\":\"Test the visualization component to ensure it correctly displays trends, handles different types of data, and provides accurate tooltips and legends.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T02:03:14", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 169. Plan generated by qwen2.5-coder:7b."}}
