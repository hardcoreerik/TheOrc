 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create a PowerShell script to automate the deployment of the new software on multiple devices."}, {"role": "assistant", "content": "{\"plan\":\"Research deployment tools, create a PowerShell script for automation, and test it on multiple devices\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research Deployment Tools\",\"description\":\"Identify and research suitable PowerShell deployment tools for automating the installation on multiple devices.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create Deployment Script\",\"description\":\"Develop a PowerShell script named 'DeploySoftware.ps1' that includes functions to automate the installation process.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Test Deployment Script\",\"description\":\"Verify that the 'DeploySoftware.ps1' script correctly installs the software on a single device without errors.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T05:26:21", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 578. Plan generated by qwen2.5-coder:7b."}}
