 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create a PowerShell script that automates the deployment process for new application releases."}, {"role": "assistant", "content": "{\"plan\":\"Research deployment tools, develop PowerShell script, test functionality\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research existing deployment tools and scripts\",\"description\":\"Gather information on common deployment tools like Ansible, Chef, or custom PowerShell scripts to identify potential solutions.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Develop the PowerShell script\",\"description\":\"Create a PowerShell script named DeployApp.ps1 that includes functions for building, packaging, and deploying the application.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify script functionality\",\"description\":\"Test the DeployApp.ps1 script on different environments to ensure it correctly builds, packages, and deploys the application without errors.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T06:42:47", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 731. Plan generated by qwen2.5-coder:7b."}}
