 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create a PowerShell script that automates the backup of crucial company files."}, {"role": "assistant", "content": "{\"plan\":\"Develop a PowerShell script to automate file backups by identifying critical directories, creating timestamped folders for each backup, and copying files using Robocopy with error handling\",\"tasks\":[{\"role\":\"CODER\",\"priority\":2,\"title\":\"Write Backup Script\",\"description\":\"Create a PowerShell script named 'BackupCompanyFiles.ps1' to automate the backup of crucial company files.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Backup Functionality\",\"description\":\"Manually run the 'BackupCompanyFiles.ps1' script and verify that it correctly backs up all designated files to the specified location.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T00:23:14", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 21. Plan generated by qwen2.5-coder:7b."}}
