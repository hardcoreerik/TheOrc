 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Automate the generation of reports from processed data using C#/WPF."}, {"role": "assistant", "content": "{\"plan\":\"Identify templates, create ReportService, design UIs, test generation\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify required report templates and formats\",\"description\":\"Gather details on the types of reports needed, their formats (e.g., PDF, Excel), and any specific data requirements.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create a ReportService.cs class\",\"description\":\"Implement a service class that will handle the logic for generating reports based on processed data.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Develop MainWindow.xaml and ReportView.xaml\",\"description\":\"Design the WPF application interface, including windows for displaying reports in various formats (PDF viewer, Excel viewer).\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify report generation functionality\",\"description\":\"Test that reports are generated correctly and match the expected format and data.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T00:23:23", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 22. Plan generated by qwen2.5-coder:7b."}}
