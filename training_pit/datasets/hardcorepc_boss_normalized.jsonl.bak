 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: 16. Refactor a C# WPF application's UI to improve responsiveness and user experience."}, {"role": "assistant", "content": "{\"plan\":\"Refactor C# WPF app by optimizing layout, implementing async data binding, enhancing interaction, and verifying responsiveness\",\"tasks\":[{\"role\":\"UIDEVELOPER\",\"priority\":2,\"title\":\"Optimize WPF Window Layout\",\"description\":\"Refactor the MainWindow.xaml file to use more efficient layout controls (e.g., Grid instead of StackPanel) and remove unnecessary bindings.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Implement Asynchronous Data Binding\",\"description\":\"Modify data binding in ViewModel.cs files to fetch data asynchronously using Task or async/await to prevent the UI from freezing.\"},{\"role\":\"UIDEVELOPER\",\"priority\":2,\"title\":\"Enhance Interaction Responsiveness\",\"description\":\"Refactor event handlers in MainWindow.xaml.cs to reduce processing time and use threading where necessary.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify UI responsiveness after refactoring\",\"description\":\"Test the application under various conditions (e.g., multiple data loads, large datasets) to ensure the UI remains responsive.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generate