 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create a PowerShell script to automate daily system backups."}, {"role": "assistant", "content": "{\"plan\":\"Develop a PowerShell script using built-in cmdlets for daily system backups, incorporating error handling and logging\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research PowerShell Backup Tools and Techniques\",\"description\":\"Review existing PowerShell scripts, modules, and tools for automating system backups.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Develop Backup Script\",\"description\":\"Create a PowerShell script named 'DailyBackup.ps1' that copies specified directories to a backup location.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Backup Script Functionality\",\"description\":\"Test the 'DailyBackup.ps1' script on a test system to ensure it backs up files correctly and without errors.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T06:32:01", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 718. Plan generated by qwen2.5-coder:7b."}}
