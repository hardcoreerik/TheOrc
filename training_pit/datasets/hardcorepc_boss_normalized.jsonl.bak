 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create comprehensive testing plans for new features in the WPF app."}, {"role": "assistant", "content": "{\"plan\":\"Develop a structured testing framework including unit, integration, end-to-end, and performance tests to comprehensively validate new features in the WPF app\",\"tasks\":[{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Unit Tests for New Features\",\"description\":\"Verify that all individual components and functions of the new features work correctly in isolation.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Integration Tests for New Features\",\"description\":\"Ensure that the new features integrate smoothly with existing parts of the application without breaking anything.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"End-to-End Tests for New Features\",\"description\":\"Test the entire flow from user interaction to system response to confirm that the new features behave as expected in real-world scenarios.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Performance Tests for New Features\",\"description\":\"Evaluate the performance of the new features under various load conditions to ensure they meet the application's performance requirements.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T