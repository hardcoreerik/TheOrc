 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Optimize an existing algorithm to reduce runtime by 50%."}, {"role": "assistant", "content": "{\"plan\":\"Analyze current algorithm, refactor for efficiency, validate performance improvement\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Analyze Current Algorithm\",\"description\":\"Review the current algorithm's code and identify bottlenecks, time complexities, and areas for improvement.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Refactor Algorithm\",\"description\":\"Implement optimization techniques such as loop unrolling, caching results, or using more efficient data structures. Update the file: Algorithms/OptimizedAlgorithm.cs\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Validate Performance Improvement\",\"description\":\"Run performance tests before and after refactoring to ensure that the runtime has been reduced by 50%. Compare results with baseline data.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T05:51:27", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 629. Plan generated by qwen2.5-coder:7b."}}
