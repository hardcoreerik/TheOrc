 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a PowerShell module to manage user permissions on a file server."}, {"role": "assistant", "content": "{\"plan\":\"Develop a PowerShell module by researching existing file server management commands, creating UserService.cs and PermissionService.cs for managing user permissions, and verifying functionality with tests\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research existing file server management commands\",\"description\":\"Investigate and document any existing PowerShell cmdlets or scripts that can be used for managing user permissions on a file server.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create UserService.cs\",\"description\":\"Develop a C# class named UserService within the Services folder to handle user-related operations, such as adding and removing users from groups.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create PermissionService.cs\",\"description\":\"Develop a C# class named PermissionService within the Services folder to manage user permissions on files and folders.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify user permission management functionality\",\"description\":\"Test the UserService and PermissionService classes to ensure that they correctly add, remove, and modify user permissions on file server resources.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma