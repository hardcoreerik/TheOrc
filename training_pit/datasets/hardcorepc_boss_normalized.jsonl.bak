 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create a simple API endpoint for user authentication using JWT tokens."}, {"role": "assistant", "content": "{\"plan\":\"Implement JWT-based authentication in UserAuthenticationService, expose it via UserController, and test the endpoint for user authentication\",\"tasks\":[{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create UserAuthenticationService.cs\",\"description\":\"Implement a service to handle user authentication and generate JWT tokens.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create UserController.cs\",\"description\":\"Develop an API controller with an endpoint for user login that returns a JWT token upon successful authentication.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify User Authentication Endpoint\",\"description\":\"Test the user authentication endpoint to ensure it correctly generates and returns JWT tokens for valid credentials.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T01:10:53", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 85. Plan generated by qwen2.5-coder:7b."}}
