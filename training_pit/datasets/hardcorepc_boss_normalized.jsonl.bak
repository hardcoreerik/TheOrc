 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create a PowerShell script to automate the backup of configuration files daily at midnight."}, {"role": "assistant", "content": "{\"plan\":\"Write a PowerShell script to automate daily configuration file backups at midnight, then schedule it using Task Scheduler\",\"tasks\":[{\"role\":\"CODER\",\"priority\":2,\"title\":\"Write Backup Script\",\"description\":\"Create a PowerShell script named 'BackupConfigFiles.ps1' that copies all configuration files to a backup directory.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Backup Script\",\"description\":\"Manually run the 'BackupConfigFiles.ps1' script and verify that it correctly backs up the configuration files to the designated directory.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Schedule Script Execution\",\"description\":\"Modify the Task Scheduler on the target machine to execute the 'BackupConfigFiles.ps1' script daily at midnight.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-12T23:17:14", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 666. Plan generated by qwen2.5-coder:7b."}}
