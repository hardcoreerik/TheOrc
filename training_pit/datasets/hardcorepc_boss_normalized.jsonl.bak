 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Write detailed testing instructions for a mobile app backend."}, {"role": "assistant", "content": "{\"plan\":\"Develop comprehensive testing instructions for the mobile app backend, including unit test coverage, integration tests, performance assessments, and security scans\",\"tasks\":[{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Unit Test Coverage\",\"description\":\"Ensure that all critical functions in the backend service have at least 80% unit test coverage. Review code changes to maintain or improve this metric.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Integration Test Suite\",\"description\":\"Develop and execute an integration test suite to validate that various components of the backend system interact correctly under normal conditions.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Performance Testing\",\"description\":\"Conduct load testing and stress testing on the backend service to ensure it performs optimally under expected usage conditions. Document any bottlenecks or areas for improvement.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Security Scanning\",\"description\":\"Run security scans on the codebase using static application security testing (SAST) tools to identify and remediate potential vulnerabilities.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.