 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Automate the generation of reports from processed data using C#/WPF."}, {"role": "assistant", "content": "{\"plan\":\"Identify reports, create service, design viewer, verify generation\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify Required Reports\",\"description\":\"Gather a list of all reports that need to be automated and determine their formats, sources, and frequency.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create Report Generation Service\",\"description\":\"Develop a C# service class (e.g., Services/ReportGenerationService.cs) that handles the logic for generating each report based on the data processed.\"},{\"role\":\"UIDEVELOPER\",\"priority\":2,\"title\":\"Design Report Viewer Window\",\"description\":\"Create a WPF window (e.g., Views/ReportViewerWindow.xaml) that allows users to view and interact with the generated reports.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Report Generation\",\"description\":\"Ensure that each report is generated correctly, displayed accurately in the viewer window, and handles edge cases appropriately.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T00:36:02", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 38. Plan generated by qwen2.5-coder:7b."}}
