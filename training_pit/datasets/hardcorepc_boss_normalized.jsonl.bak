 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create automated tests for the file upload feature in the WPF application."}, {"role": "assistant", "content": "{\"plan\":\"Automate file upload tests by simulating button clicks, selecting files, monitoring upload progress, and checking error responses\",\"tasks\":[{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify File Upload Button Functionality\",\"description\":\"Test that clicking the 'File Upload' button opens a file dialog and allows selection of a file.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify File Selection Behavior\",\"description\":\"Test that only files with allowed extensions (e.g., .jpg, .png) can be selected and uploaded.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify File Upload Completion\",\"description\":\"Test that after a file is selected and uploaded, the application displays a success message and updates the UI to reflect the uploaded file.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Error Handling During File Upload\",\"description\":\"Test that error messages are displayed if an upload fails due to issues like network problems or invalid file types.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T04:50:20", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 510. Plan generated by qwen2.5-coder:7b."}}
