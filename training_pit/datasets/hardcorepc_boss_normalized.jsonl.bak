 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a PowerShell script to audit user permissions on servers."}, {"role": "assistant", "content": "{\"plan\":\"Develop a PowerShell script named UserPermissionAudit.ps1 to audit user permissions on servers by leveraging Get-Acl cmdlet and exporting results to CSV for easy review\",\"tasks\":[{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create UserPermissionAudit.ps1 Script\",\"description\":\"Develop a PowerShell script named UserPermissionAudit.ps1 that retrieves and outputs user permissions for specified servers.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Script Functionality\",\"description\":\"Test the UserPermissionAudit.ps1 script on multiple servers to ensure it accurately audits user permissions.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T00:18:05", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 828. Plan generated by qwen2.5-coder:7b."}}
