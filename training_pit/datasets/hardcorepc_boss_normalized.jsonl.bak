 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a PowerShell script to automate daily backup of critical system files."}, {"role": "assistant", "content": "{\"plan\":\"Review backup tools, create PowerShell script for automated daily backups, and test its functionality\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Review Backup Tools and Techniques\",\"description\":\"Explore existing backup tools, techniques, and best practices for automating backups in PowerShell.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create Backup Script\",\"description\":\"Develop a PowerShell script named 'DailyBackup.ps1' that copies critical system files to a designated backup location.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Backup Script\",\"description\":\"Test the backup script to ensure it correctly identifies and backs up critical system files without errors.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-12T22:46:14", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 2. Plan generated by qwen2.5-coder:7b."}}
