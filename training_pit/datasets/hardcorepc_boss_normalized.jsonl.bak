 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a PowerShell script to automate backup procedures."}, {"role": "assistant", "content": "{\"plan\":\"Research backup solutions, create a PowerShell script for automation, and test the script\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research existing backup solutions\",\"description\":\"Explore PowerShell modules and scripts for existing backup procedures to understand best practices and avoid reinventing the wheel.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create Backup Script\",\"description\":\"Develop a PowerShell script named `Backup-Files.ps1` that will automate the backup of specified directories. The script should include functionality for compression, encryption, and scheduling.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Test Backup Script\",\"description\":\"Execute the backup script in a controlled environment to ensure it correctly backs up the designated files without errors.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T04:24:53", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 467. Plan generated by qwen2.5-coder:7b."}}
