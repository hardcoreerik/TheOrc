ver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T03:46:24", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 372. Plan generated by qwen2.5-coder:7b."}}
