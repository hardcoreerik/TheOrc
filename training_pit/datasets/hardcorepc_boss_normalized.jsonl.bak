 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Create a PowerShell script to automate routine maintenance tasks."}, {"role": "assistant", "content": "{\"plan\":\"Identify tasks, create backup script, test functionality, then develop update script\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify Maintenance Tasks\",\"description\":\"List all the routine maintenance tasks that need to be automated, such as backup, system updates, and log management.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create PowerShell Script for Backup\",\"description\":\"Write a PowerShell script named `Backup-System.ps1` that performs regular backups of critical data files.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Backup Functionality\",\"description\":\"Test the `Backup-System.ps1` script to ensure it correctly backs up files and logs without errors.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create PowerShell Script for System Updates\",\"description\":\"Write a PowerShell script named `Update-System.ps1` that automates the process of checking and installing system updates.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T04:17:12", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 439. Plan generated by qwen2.5-coder:7b."}