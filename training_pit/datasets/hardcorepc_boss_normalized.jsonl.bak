 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a PowerShell script to automate server configuration backups."}, {"role": "assistant", "content": "{\"plan\":\"Identify backup requirements, create a PowerShell script for automated server configuration backups, and test the script's functionality\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify Backup Requirements\",\"description\":\"Gather information on the types of configurations that need to be backed up, frequency, and storage location.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create Backup Script\",\"description\":\"Write a PowerShell script named `Backup-ServerConfig.ps1` that captures the necessary configuration files and stores them in the specified backup location.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Script Functionality\",\"description\":\"Test the `Backup-ServerConfig.ps1` script to ensure it correctly backs up all required configurations without errors.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T06:43:01", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 732. Plan generated by qwen2.5-coder:7b."}}
