 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop an IoT solution that controls lighting based on environmental conditions."}, {"role": "assistant", "content": "{\"plan\":\"Identify sensors, implement interfaces, determine logic, develop control system\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Identify Required Sensors\",\"description\":\"Research and select appropriate sensors for monitoring environmental conditions such as light levels, temperature, and humidity.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Implement Sensor Interface\",\"description\":\"Create a C# class (Sensors/SensorInterface.cs) that defines methods for reading data from the selected sensors.\"},{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Determine Lighting Control Logic\",\"description\":\"Research control algorithms and strategies to determine optimal lighting based on environmental conditions.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Develop Lighting Control System\",\"description\":\"Create a C# class (Services/LightingService.cs) that uses the SensorInterface to monitor conditions and controls lighting devices accordingly.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T00:34:44", "notes": "Normalized from hardcorepc_raw_overnight.jsonl examp