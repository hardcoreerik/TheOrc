 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Design a data validation script in PowerShell to check CSV file integrity."}, {"role": "assistant", "content": "{\"plan\":\"Design and test a PowerShell script for validating CSV file integrity by checking headers, data types, and consistency\",\"tasks\":[{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create PowerShell Script\",\"description\":\"Develop a PowerShell script named Validate-CSV.ps1 that reads a CSV file and checks for the presence of mandatory columns, validates data types, and ensures there are no duplicate entries.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Data Validation Logic\",\"description\":\"Test the Validate-CSV.ps1 script with various CSV files to ensure it correctly identifies missing columns, type errors, and duplicates.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T00:30:36", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 34. Plan generated by qwen2.5-coder:7b."}}
