 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Develop a PowerShell script to automate server configuration."}, {"role": "assistant", "content": "{\"plan\":\"Research PowerShell cmdlets, create a script file, and test basic functionality\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research PowerShell cmdlets for server configuration\",\"description\":\"Gather information on PowerShell cmdlets that can be used to automate various aspects of server configuration, such as user management, network settings, and software installations.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Create a PowerShell script file\",\"description\":\"Write a PowerShell script file named 'ServerConfig.ps1' that will hold the automation logic.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify basic functionality of the script\",\"description\":\"Test the script to ensure it can perform basic server configuration tasks, such as creating a new user and setting network settings.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original_model": "qwen2.5-coder:7b", "original_generated": "2026-06-13T05:08:41", "notes": "Normalized from hardcorepc_raw_overnight.jsonl example 544. Plan generated by qwen2.5-coder:7b."}}
