 no preamble, no trailing text.\nString values MUST NOT contain literal newlines — use \\n inside strings if needed.\n{\n  \"plan\": \"one-sentence overall approach\",\n  \"tasks\": [\n    {\n      \"role\": \"RESEARCHER\",\n      \"priority\": 1,\n      \"title\": \"Short descriptive title\",\n      \"description\": \"Detailed, self-contained instructions for this minion. Use \\n for line breaks inside this string.\"\n    }\n  ]\n}"}, {"role": "user", "content": "Goal: Refactor a PowerShell module to use parameterized queries for database operations."}, {"role": "assistant", "content": "{\"plan\":\"Refactor PowerShell modules by implementing parameterized queries for database operations through research, code modification, and testing\",\"tasks\":[{\"role\":\"RESEARCHER\",\"priority\":1,\"title\":\"Research on Parameterized Queries in PowerShell\",\"description\":\"Investigate how to implement parameterized queries in PowerShell for safe and efficient database operations.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Refactor UserService.ps1\",\"description\":\"Refactor the UserService.ps1 file to use parameterized queries instead of string interpolation or concatenation for SQL commands.\"},{\"role\":\"TESTER\",\"priority\":2,\"title\":\"Verify Parameterized Queries in User Operations\",\"description\":\"Test user-related operations (e.g., GetUser, AddUser) to ensure that parameterized queries are working as expected and preventing SQL injection attacks.\"},{\"role\":\"CODER\",\"priority\":2,\"title\":\"Refactor ProductRepository.ps1\",\"description\":\"Refactor the ProductRepository.ps1 file similarly to UserService.ps1, using parameterized queries for all database operations involving products.\"}]}"}], "metadata": {"category": "boss_planning", "task_type": "feature_plan", "source": "hardcorepc_normalized", "quality": "silver", "contains_sensitive_data": false, "base_model_target": "theorc-boss:gemma4", "created_by": "normalize_hardcorepc_boss.py", "original