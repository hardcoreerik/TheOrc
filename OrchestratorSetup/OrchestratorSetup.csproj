<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <RootNamespace>OrchestratorSetup</RootNamespace>
    <AssemblyName>OrchestratorSetup</AssemblyName>
    <ApplicationIcon>..\Assets\icon.ico</ApplicationIcon>
    <NoWarn>$(NoWarn);NU1510</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="System.IO"/>
    <Using Include="System.Collections.Generic"/>
    <Using Include="System.Collections.ObjectModel"/>
    <Using Include="System.Linq"/>
    <Using Include="System.Threading"/>
    <Using Include="System.Threading.Tasks"/>
    <Using Include="System.ComponentModel"/>
    <Using Include="System.Runtime.CompilerServices"/>
  </ItemGroup>

  <ItemGroup>
    <!-- System.Text.Json is inbox in .NET 10 but kept explicit for IDE Intellisense -->
    <PackageReference Include="System.Text.Json"  Version="10.0.8" NoWarn="NU1510" />
    <!-- WMI managed API — required for Win32_VideoController and ComputerSystem queries -->
    <PackageReference Include="System.Management"  Version="9.0.0" />
  </ItemGroup>

  <!-- Embed the model manifest and profile templates INSIDE the exe assembly
       so the standalone single-file installer works without a Resources/ folder
       next to it. Read via Assembly.GetManifestResourceStream() at runtime. -->
  <ItemGroup>
    <EmbeddedResource Include="..\Setup\model-manifest.json"
                      Link="Resources\model-manifest.json"/>
    <EmbeddedResource Include="..\Setup\Profiles\*.agent.md"
                      Link="Resources\Profiles\%(Filename)%(Extension)"/>
  </ItemGroup>

</Project>
