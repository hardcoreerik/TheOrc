<Window x:Class="OrchestratorSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OrchestratorSetup.Converters"
        Title="The Orc — Setup"
        Width="940" Height="700"
        MinWidth="820" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BgDeep}"
        AutomationProperties.AutomationId="SetupWindow">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <!-- ══ Layout: sidebar left, content right ══════════════════════════════ -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="#111111"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo / product name -->
                <StackPanel DockPanel.Dock="Top" Margin="24,32,24,32">
                    <TextBlock Text="🐉" FontSize="42" HorizontalAlignment="Left"/>
                    <TextBlock Text="The Orc" Style="{StaticResource TextPageTitle}"
                               FontSize="20" Margin="0,6,0,2"/>
                    <TextBlock Text="Setup Wizard" Style="{StaticResource TextSubtitle}"
                               FontSize="11"/>
                </StackPanel>

                <!-- Step list -->
                <ItemsControl DockPanel.Dock="Top"
                              x:Name="StepList"
                              Margin="0,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="StepRow" Padding="24,10">
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="StepDot"
                                            Width="18" Height="18"
                                            CornerRadius="9"
                                            Background="{StaticResource TextMuted}"
                                            Margin="0,0,10,0">
                                        <TextBlock x:Name="StepNum"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                    <TextBlock x:Name="StepName"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Version footer -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="v1.0.0"
                           Style="{StaticResource TextSubtitle}"
                           FontSize="10"
                           Margin="24,0,24,20"
                           VerticalAlignment="Bottom"/>
            </DockPanel>
        </Border>

        <!-- ── Main content area ────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page host — swapped by MainWindow.xaml.cs -->
            <ContentControl Grid.Row="0"
                            x:Name="PageHost"
                            Margin="0"
                            AutomationProperties.AutomationId="PageHost"/>

            <!-- ── Footer: progress bar + nav buttons ────────────────────── -->
            <Border Grid.Row="1"
                    Background="#1A1A1A"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="24,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Progress -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,32,0">
                        <ProgressBar x:Name="WizardProgress"
                                     Style="{StaticResource ThemedProgressBar}"
                                     Value="0" Maximum="100"
                                     AutomationProperties.AutomationId="Setup.Progress"/>
                        <TextBlock x:Name="ProgressLabel"
                                   Text="Step 1 of 9"
                                   Style="{StaticResource TextSubtitle}"
                                   FontSize="10" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Back / Next / Install / Finish -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnBack"
                                Content="← Back"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0"
                                Click="BtnBack_Click"
                                AutomationProperties.AutomationId="Setup.Back"/>
                        <Button x:Name="BtnNext"
                                Content="Next →"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnNext_Click"
                                AutomationProperties.AutomationId="Setup.Next"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
