<Window x:Class="OrchestratorSetup.UninstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Orc — Uninstall"
        Width="500" Height="380"
        MinWidth="440" MinHeight="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BgDeep}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/InstallerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="32,28,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Icon + title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Image Source="pack://application:,,,/Assets/icon.png"
                   Width="48" Height="48" Margin="0,0,16,0"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   VerticalAlignment="Center"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Remove TheOrc?"
                           Style="{StaticResource TextPageTitle}" FontSize="20" Margin="0"/>
                <TextBlock Text="This will uninstall TheOrc from your computer."
                           Style="{StaticResource TextSubtitle}" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Install path display -->
        <Border Grid.Row="2"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1" CornerRadius="4" Padding="12,8">
            <StackPanel>
                <TextBlock Text="Install location:"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                <TextBlock x:Name="TbInstallPath"
                           Text="(not found)"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="12" FontFamily="Consolas"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Options -->
        <StackPanel Grid.Row="4" Orientation="Vertical">
            <CheckBox x:Name="ChkRemoveUserData"
                      Content="Remove user data (settings, workspace history)"
                      Foreground="{StaticResource TextSecondary}"
                      FontSize="12" FontFamily="Segoe UI"
                      IsChecked="False" Margin="0,0,0,6"/>
        </StackPanel>

        <!-- Progress / status -->
        <Border x:Name="BdrProgress" Grid.Row="5" Visibility="Collapsed"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1" CornerRadius="4"
                Margin="0,12,0,0" Padding="12,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                <TextBlock x:Name="TbProgress"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11" FontFamily="Consolas"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <DockPanel Grid.Row="6" Margin="0,16,0,0">
            <Button x:Name="BtnCancel"
                    DockPanel.Dock="Right"
                    Content="Cancel"
                    Width="90" Height="32"
                    Margin="0,0,0,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnCancel_Click"/>
            <Button x:Name="BtnRemove"
                    DockPanel.Dock="Right"
                    Content="Remove TheOrc"
                    Width="130" Height="32"
                    Margin="0,0,8,0"
                    Background="#5C1A1A" Foreground="#F48771"
                    BorderBrush="#8A2A2A" BorderThickness="1"
                    Click="BtnRemove_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="12,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7A2020"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#B03A3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#2A1414"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#3A2020"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DockPanel>
    </Grid>
</Window>
