<Window x:Class="OrchestratorSetup.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Orc — Setup"
        Width="940" Height="700"
        MinWidth="820" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="{StaticResource BgDeep}"
        AutomationProperties.AutomationId="SetupWindow">

    <Grid>
        <!-- ══ Layout: sidebar left, content right ══════════════════════════════ -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="#111111"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo / product name -->
                <StackPanel DockPanel.Dock="Top" Margin="24,28,24,28">
                    <Image Source="avares://OrchestratorSetup/Assets/icon.png"
                           Width="64" Height="64"
                           HorizontalAlignment="Left"
                           RenderOptions.BitmapInterpolationMode="HighQuality"
                           Margin="0,0,0,10"/>
                    <TextBlock Text="TheOrc"
                               Classes="PageTitle"
                               FontSize="18" Margin="0,0,0,2"/>
                    <TextBlock Text="Setup Wizard"
                               Classes="Subtitle"
                               FontSize="11"/>
                </StackPanel>

                <!-- Step list -->
                <ItemsControl DockPanel.Dock="Top"
                              x:Name="StepList"
                              Margin="0,0,0,0"/>

                <!-- Version footer -->
                <TextBlock DockPanel.Dock="Bottom"
                           x:Name="TxtVersion"
                           Text="v1.9.4"
                           Classes="Subtitle"
                           FontSize="10"
                           Margin="24,0,24,20"
                           VerticalAlignment="Bottom"/>
            </DockPanel>
        </Border>

        <!-- ── Main content area ────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page host — swapped by MainWindow.axaml.cs -->
            <ContentControl Grid.Row="0"
                            x:Name="PageHost"
                            Margin="0"
                            AutomationProperties.AutomationId="PageHost"/>

            <!-- ── Footer: progress bar + nav buttons ────────────────────── -->
            <Border Grid.Row="1"
                    Background="#1A1A1A"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="24,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Progress -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,32,0">
                        <ProgressBar x:Name="WizardProgress"
                                     Classes="Themed"
                                     Value="0" Maximum="100"
                                     AutomationProperties.AutomationId="Setup.Progress"/>
                        <TextBlock x:Name="ProgressLabel"
                                   Text="Step 1 of 8"
                                   Classes="Subtitle"
                                   FontSize="10" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Back / Next / Install / Finish -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnBack"
                                Content="← Back"
                                Classes="Secondary"
                                Margin="0,0,8,0"
                                Click="BtnBack_Click"
                                AutomationProperties.AutomationId="Setup.Back"/>
                        <Button x:Name="BtnNext"
                                Content="Next →"
                                Classes="Primary"
                                Click="BtnNext_Click"
                                AutomationProperties.AutomationId="Setup.Next"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
