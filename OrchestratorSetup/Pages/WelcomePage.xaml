<UserControl x:Class="OrchestratorSetup.Pages.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.Welcome">

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="48,0">

            <!-- Hero -->
            <TextBlock Text="🐉" FontSize="64" Margin="0,0,0,16"/>

            <TextBlock Text="Welcome to The Orc"
                       Style="{StaticResource TextHero}"
                       Margin="0,0,0,12"/>

            <TextBlock Style="{StaticResource TextSubtitle}" FontSize="14"
                       Margin="0,0,0,32">
                The Orc is an AI coding assistant that runs <Run FontWeight="SemiBold"
                Foreground="{StaticResource Accent}">entirely on your machine</Run> —
                no cloud, no subscriptions, no telemetry.
                <LineBreak/><LineBreak/>
                This wizard will detect your GPU, let you choose a coding profile,
                download the best model for your hardware, and have you up and running
                in a few minutes.
            </TextBlock>

            <Separator Style="{StaticResource HRule}"/>

            <!-- What will be installed -->
            <TextBlock Text="WHAT GETS INSTALLED"
                       Style="{StaticResource TextLabel}"
                       Margin="0,12,0,10"/>

            <ItemsControl>
                <ItemsControl.Items>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="✅" Margin="0,0,10,0"/>
                        <TextBlock Text="OrchestratorIDE — the AI coding workspace"
                                   Style="{StaticResource TextBody}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="✅" Margin="0,0,10,0"/>
                        <TextBlock Text="llama.cpp runtime — local inference engine"
                                   Style="{StaticResource TextBody}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="✅" Margin="0,0,10,0"/>
                        <TextBlock Text="A GGUF coding model matched to your GPU"
                                   Style="{StaticResource TextBody}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="✅" Margin="0,0,10,0"/>
                        <TextBlock Text="A tailored .agent.md for your coding discipline"
                                   Style="{StaticResource TextBody}"/>
                    </StackPanel>
                </ItemsControl.Items>
            </ItemsControl>

            <TextBlock Margin="0,24,0,0"
                       Style="{StaticResource TextSubtitle}"
                       FontSize="11">
                Click <Run FontWeight="SemiBold">Next</Run> to begin.
                Installation typically takes 5–15 minutes depending on your
                internet speed and model size.
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
