<UserControl x:Class="OrchestratorSetup.Pages.ModelPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OrchestratorSetup.Converters"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.Model">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="40,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Swarm Bundle card -->
            <RowDefinition Height="*"/>      <!-- All models expander -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Model Selection" Style="{StaticResource TextPageTitle}"/>
            <TextBlock Style="{StaticResource TextSubtitle}">
                Select the AI models to install.  The Swarm Bundle below gives TheOrc a
                dedicated <Run Foreground="{StaticResource Success}">Worker</Run> for coding
                and a fast <Run Foreground="{StaticResource Warning}">Boss</Run> for planning.
                Both are recommended for the best multi-agent experience.
            </TextBlock>
        </StackPanel>

        <!-- ── Swarm Bundle card ────────────────────────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}"
                BorderBrush="{StaticResource BorderAccent}"
                Margin="0,0,0,12"
                AutomationProperties.AutomationId="Model.BundleCard">
            <StackPanel>

                <!-- Bundle badge row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Border Background="{StaticResource Accent}" CornerRadius="3"
                            Padding="6,2" Margin="0,0,8,0">
                        <TextBlock Text="SWARM BUNDLE" Foreground="White"
                                   FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                    </Border>
                    <TextBlock x:Name="TxtBundleHardwareSummary"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ── Worker row ────────────────────────────────────────── -->
                <Border x:Name="RowWorker"
                        Background="#0D1A0D" CornerRadius="4"
                        Padding="10,8" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" x:Name="ChkWorker"
                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                  Checked="BundleCheckBox_Changed"
                                  Unchecked="BundleCheckBox_Changed"
                                  AutomationProperties.AutomationId="Model.ChkWorker"/>

                        <Border Grid.Column="1" CornerRadius="3" Padding="6,2"
                                Background="#1A3A1A" VerticalAlignment="Center"
                                Margin="0,0,10,0">
                            <TextBlock Text="WORKER · CODER" FontSize="9" FontWeight="Bold"
                                       Foreground="#4ACA4A" FontFamily="Segoe UI"/>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal">
                                <!-- Partner badge (NVIDIA / GOOGLE) — shown by code-behind -->
                                <Border x:Name="BdrWorkerPartner"
                                        CornerRadius="3" Padding="5,1" Margin="0,0,7,0"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="TxtWorkerPartner"
                                               FontSize="9" FontWeight="Bold"
                                               FontFamily="Segoe UI"/>
                                </Border>
                                <TextBlock x:Name="TxtWorkerName"
                                           FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                            <WrapPanel Margin="0,3,0,0">
                                <TextBlock x:Name="TxtWorkerVram" FontSize="11"
                                           Foreground="{StaticResource Accent}"
                                           FontFamily="Segoe UI" Margin="0,0,10,0"/>
                                <TextBlock x:Name="TxtWorkerSize" FontSize="11"
                                           Foreground="{StaticResource Success}"
                                           FontFamily="Segoe UI" Margin="0,0,10,0"/>
                                <TextBlock x:Name="TxtWorkerStars" FontSize="13"
                                           Foreground="{StaticResource Warning}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Boss row ──────────────────────────────────────────── -->
                <Border x:Name="RowBoss"
                        Background="#1A140A" CornerRadius="4"
                        Padding="10,8" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" x:Name="ChkBoss"
                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                  Checked="BundleCheckBox_Changed"
                                  Unchecked="BundleCheckBox_Changed"
                                  AutomationProperties.AutomationId="Model.ChkBoss"/>

                        <Border Grid.Column="1" CornerRadius="3" Padding="6,2"
                                Background="#3A2800" VerticalAlignment="Center"
                                Margin="0,0,10,0">
                            <TextBlock Text="BOSS · ORCHESTRATOR" FontSize="9" FontWeight="Bold"
                                       Foreground="#FFB300" FontFamily="Segoe UI"/>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="TxtBossName"
                                       FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <WrapPanel Margin="0,3,0,0">
                                <TextBlock x:Name="TxtBossVram" FontSize="11"
                                           Foreground="{StaticResource Accent}"
                                           FontFamily="Segoe UI" Margin="0,0,10,0"/>
                                <TextBlock x:Name="TxtBossSize" FontSize="11"
                                           Foreground="{StaticResource Success}"
                                           FontFamily="Segoe UI" Margin="0,0,10,0"/>
                                <TextBlock x:Name="TxtBossStars" FontSize="13"
                                           Foreground="{StaticResource Warning}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Researcher row (optional, not pre-checked) ────────── -->
                <Border x:Name="RowResearcher"
                        Background="#0A1420" CornerRadius="4"
                        Padding="10,8" Margin="0,0,0,0"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" x:Name="ChkResearcher"
                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                  Checked="BundleCheckBox_Changed"
                                  Unchecked="BundleCheckBox_Changed"
                                  AutomationProperties.AutomationId="Model.ChkResearcher"/>

                        <Border Grid.Column="1" CornerRadius="3" Padding="6,2"
                                Background="#0E1F2E" VerticalAlignment="Center"
                                Margin="0,0,10,0">
                            <TextBlock Text="RESEARCHER" FontSize="9" FontWeight="Bold"
                                       Foreground="#4A9FD9" FontFamily="Segoe UI"/>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="TxtResearcherName"
                                       FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <WrapPanel Margin="0,3,0,0">
                                <TextBlock x:Name="TxtResearcherVram" FontSize="11"
                                           Foreground="{StaticResource Accent}"
                                           FontFamily="Segoe UI" Margin="0,0,10,0"/>
                                <TextBlock x:Name="TxtResearcherSize" FontSize="11"
                                           Foreground="{StaticResource Success}"
                                           FontFamily="Segoe UI" Margin="0,0,10,0"/>
                                <TextBlock x:Name="TxtResearcherStars" FontSize="13"
                                           Foreground="{StaticResource Warning}"/>
                            </WrapPanel>
                        </StackPanel>

                        <TextBlock Grid.Column="3" Text="Optional"
                                   FontSize="10" FontStyle="Italic"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Border>

            </StackPanel>
        </Border>

        <!-- ── All models expander ──────────────────────────────────────────── -->
        <Expander Grid.Row="2"
                  x:Name="ExpanderAllModels"
                  Header="Browse all available models"
                  Foreground="{StaticResource TextSecondary}"
                  FontFamily="Segoe UI" FontSize="12"
                  Margin="0,0,0,0">
            <ScrollViewer MaxHeight="240"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,8,0,0">
                <!-- Attach a class-level CheckBox.Click handler via the ItemsControl -->
                <ItemsControl x:Name="ModelList"
                              CheckBox.Click="ModelListCheckBox_Click">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}"
                                    Margin="0,0,0,5"
                                    Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Checkbox — IsChecked bound two-way; Click bubbles to ItemsControl -->
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Tag="{Binding Id}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"/>

                                    <!-- Role badge (optional) -->
                                    <Border Grid.Column="1"
                                            Visibility="{Binding HasRoleLabel, Converter={StaticResource BoolToVis}}"
                                            CornerRadius="3" Padding="5,1" Margin="0,0,8,0"
                                            Background="#1A2A1A" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding RoleLabel}"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="{StaticResource Success}"
                                                   FontFamily="Segoe UI"/>
                                    </Border>

                                    <StackPanel Grid.Column="2">
                                        <!-- Name row with optional partner badge -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <Border Visibility="{Binding HasPartnerBadge, Converter={StaticResource BoolToVis}}"
                                                    Background="{Binding PartnerBadgeBg}"
                                                    CornerRadius="3" Padding="5,1" Margin="0,0,7,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PartnerBadge}"
                                                           Foreground="{Binding PartnerBadgeFg}"
                                                           FontSize="9" FontWeight="Bold"
                                                           FontFamily="Segoe UI"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="Segoe UI" FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource TextSubtitle}"
                                                   FontSize="11"/>

                                        <WrapPanel Margin="0,4,0,0">
                                            <TextBlock Text="{Binding VramDisplay}"
                                                       FontSize="11" FontFamily="Segoe UI"
                                                       Foreground="{StaticResource Accent}"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding SizeDisplay}"
                                                       FontSize="11" FontFamily="Segoe UI"
                                                       Foreground="{StaticResource Success}"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Visibility="{Binding OllamaOnly, Converter={StaticResource BoolToVis}}"
                                                       Text="Ollama pull"
                                                       FontSize="11" FontFamily="Segoe UI"
                                                       Foreground="#4A9FD9"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding StarsDisplay}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource Warning}"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Expander>

        <!-- ── Footer: selection summary ───────────────────────────────────── -->
        <Border Grid.Row="3" Margin="0,10,0,0"
                Background="#0A0A0A" CornerRadius="4" Padding="12,7">
            <DockPanel>
                <TextBlock x:Name="TxtFooterCount"
                           DockPanel.Dock="Left"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="{StaticResource TextSecondary}"/>
                <TextBlock x:Name="TxtFooterSize"
                           DockPanel.Dock="Right"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{StaticResource Accent}"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
