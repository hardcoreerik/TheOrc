<!-- Renamed from DownloadPage.xaml per INSTALLER_REVAMP_SPEC.md §5.6 (no structural change). -->
<UserControl x:Class="OrchestratorSetup.Pages.InstallPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.Install">

    <Grid Margin="40,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with orc mascot -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="TxtPageTitle"
                           Text="Downloading &amp; Installing…"
                           Classes="PageTitle"/>
                <TextBlock x:Name="TxtPageSubtitle"
                           Classes="Subtitle" TextWrapping="Wrap">
                    Please wait while TheOrc downloads and installs all components.
                    Large models may take several minutes.
                </TextBlock>
                <!-- MainWindow hides Back/Next entirely on this page (it drives itself);
                     without this, a failed or cancelled install left no way back at all.
                     Shown only then; stacks below the subtitle, no overlap risk. -->
                <Button x:Name="BtnBackToSetup"
                        Content="← Back to Setup"
                        Classes="Secondary"
                        HorizontalAlignment="Left"
                        Margin="0,10,0,0"
                        IsVisible="False"
                        Click="BtnBackToSetup_Click"
                        AutomationProperties.AutomationId="Install.BackToSetup"/>
            </StackPanel>
            <Image Grid.Column="1"
                   Source="avares://OrchestratorSetup/Assets/badge1.png"
                   Width="88" Height="88"
                   Stretch="Uniform"
                   VerticalAlignment="Top"
                   RenderOptions.BitmapInterpolationMode="HighQuality"
                   Margin="16,0,0,0"/>
        </Grid>

        <!-- Overall progress -->
        <Border Grid.Row="1" Classes="Card" Margin="0,0,0,14">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="OVERALL PROGRESS"
                               Classes="Label"/>
                    <TextBlock x:Name="TxtOverallPct"
                               HorizontalAlignment="Right"
                               Classes="Label"
                               Foreground="{StaticResource Accent}"/>
                </Grid>
                <ProgressBar x:Name="PbOverall"
                             Classes="Themed"
                             Height="10"
                             Value="0" Maximum="100"
                             AutomationProperties.AutomationId="Install.Overall"/>
                <TextBlock x:Name="TxtOverallStatus"
                           Classes="Subtitle"
                           FontSize="11"
                           Margin="0,8,0,0"
                           Text="Preparing…"/>
            </StackPanel>
        </Border>

        <!-- Per-item download list -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="DownloadItems"/>
        </ScrollViewer>

        <!-- Log / error area -->
        <Border Grid.Row="3"
                Classes="Card"
                Padding="12,8"
                Margin="0,12,0,0"
                MaxHeight="100">
            <ScrollViewer x:Name="LogScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="TxtLog"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
