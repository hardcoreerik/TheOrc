<UserControl x:Class="OrchestratorSetup.Pages.HardwareDetectPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.Hardware">

    <Grid Margin="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Hardware Detection" Style="{StaticResource TextPageTitle}"/>
            <TextBlock Style="{StaticResource TextSubtitle}">
                The Orc detected your hardware and selected the best llama.cpp runtime
                variant. You can override these choices if needed.
            </TextBlock>
        </StackPanel>

        <!-- Detection status -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- GPU -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="GPU"
                           Style="{StaticResource TextLabel}" Width="120" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           x:Name="TxtGpuName"
                           Style="{StaticResource TextBody}"
                           Margin="0,0,0,10"/>

                <!-- VRAM -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="VRAM"
                           Style="{StaticResource TextLabel}" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           x:Name="TxtVram"
                           Style="{StaticResource TextBody}"
                           Margin="0,0,0,10"/>

                <!-- CUDA -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="CUDA"
                           Style="{StaticResource TextLabel}" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           x:Name="TxtCuda"
                           Style="{StaticResource TextBody}"
                           Margin="0,0,0,10"/>

                <!-- Runtime variant -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Runtime Variant"
                           Style="{StaticResource TextLabel}"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TxtVariant"
                               Style="{StaticResource TextBody}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="(auto-selected)"
                               Margin="8,0,0,0"
                               Style="{StaticResource TextSubtitle}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Runtime variant override -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="OVERRIDE RUNTIME VARIANT"
                           Style="{StaticResource TextLabel}"
                           Margin="0,0,0,10"/>
                <ComboBox x:Name="CmbVariant"
                          SelectionChanged="CmbVariant_SelectionChanged"
                          Background="#1A1A1A"
                          Foreground="{StaticResource TextPrimary}"
                          BorderBrush="{StaticResource BorderSubtle}"
                          FontFamily="Segoe UI"
                          FontSize="12"
                          AutomationProperties.AutomationId="Hardware.VariantOverride">
                    <ComboBoxItem Tag="cuda12"  Content="CUDA 12.x — NVIDIA RTX 20-series and newer"/>
                    <ComboBoxItem Tag="cuda11"  Content="CUDA 11.x — older NVIDIA GPUs"/>
                    <ComboBoxItem Tag="vulkan"  Content="Vulkan — AMD or Intel Arc GPUs"/>
                    <ComboBoxItem Tag="avx2"    Content="AVX2 CPU — no GPU, modern CPU"/>
                    <ComboBoxItem Tag="cpu"     Content="CPU baseline — maximum compatibility"/>
                </ComboBox>
                <TextBlock Margin="0,8,0,0" Style="{StaticResource TextSubtitle}" FontSize="11">
                    If The Orc crashes on first launch, try selecting a lower variant
                    (Vulkan → AVX2 → CPU baseline).
                </TextBlock>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
