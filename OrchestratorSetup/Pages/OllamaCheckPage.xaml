<UserControl x:Class="OrchestratorSetup.Pages.OllamaCheckPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.OllamaCheck">

    <Grid Margin="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Ollama Detection" Style="{StaticResource TextPageTitle}"/>
            <TextBlock Style="{StaticResource TextSubtitle}">
                The Orc can use llama.cpp (bundled) or an existing Ollama service.
                We checked for Ollama on this machine.
            </TextBlock>
        </StackPanel>

        <!-- Detection result card -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock x:Name="TxtOllamaIcon" Text="⬜" FontSize="20"
                               Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtOllamaStatus"
                               Style="{StaticResource TextBody}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="TxtOllamaDetail"
                           Style="{StaticResource TextSubtitle}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Choice cards -->
        <StackPanel Grid.Row="2">

            <!-- Option A: llama.cpp -->
            <Border x:Name="CardLlamaCpp"
                    Margin="0,0,0,12"
                    Style="{StaticResource CardBorder}"
                    BorderBrush="{StaticResource BorderAccent}"
                    Cursor="Hand"
                    MouseLeftButtonUp="CardLlamaCpp_Click"
                    AutomationProperties.AutomationId="Ollama.UseLlamaCpp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="RadioLlamaCpp"
                             Width="16" Height="16"
                             Stroke="{StaticResource Accent}"
                             StrokeThickness="2"
                             Fill="{StaticResource Accent}"
                             Margin="0,0,12,0" VerticalAlignment="Top"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Use llama.cpp (bundled with The Orc)"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Style="{StaticResource TextSubtitle}" FontSize="12">
                            Download and manage llama-server.exe alongside The Orc.
                            The Orc starts and stops the server automatically.
                            <Run FontWeight="SemiBold" Foreground="{StaticResource Accent}">Recommended.</Run>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Option B: existing Ollama -->
            <Border x:Name="CardOllama"
                    Style="{StaticResource CardBorder}"
                    Cursor="Hand"
                    MouseLeftButtonUp="CardOllama_Click"
                    AutomationProperties.AutomationId="Ollama.UseExisting">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="RadioOllama"
                             Width="16" Height="16"
                             Stroke="{StaticResource TextMuted}"
                             StrokeThickness="2"
                             Fill="Transparent"
                             Margin="0,0,12,0" VerticalAlignment="Top"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TxtOllamaOptionName"
                                   Text="Use existing Ollama service"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtOllamaOptionDetail"
                                   Style="{StaticResource TextSubtitle}" FontSize="12">
                            Skip the llama.cpp download. The Orc will connect to Ollama
                            at http://localhost:11434. You manage Ollama separately.
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
