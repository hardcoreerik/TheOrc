<UserControl x:Class="OrchestratorSetup.Pages.LicensePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.License">

    <Grid Margin="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="License Agreement" Style="{StaticResource TextPageTitle}"/>
            <TextBlock Style="{StaticResource TextSubtitle}">
                Please read the following license agreement. You must accept the terms
                before installing The Orc.
            </TextBlock>
        </StackPanel>

        <!-- License text scroll area -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="16">
                <TextBlock xml:space="preserve"
                           Style="{StaticResource TextBody}"
                           FontFamily="Consolas"
                           FontSize="11"
                           LineHeight="18">
MIT License

