only against systems you own or have explicit written permission to test.
Misuse is entirely the user's responsibility.
                </TextBlock>
            </ScrollViewer>
        </Border>

        <!-- Agreement checkbox -->
        <CheckBox Grid.Row="2"
                  x:Name="ChkAgree"
                  Margin="0,16,0,0"
                  Style="{StaticResource ThemedCheckBox}"
                  Content="I have read and accept the license agreement"
                  AutomationProperties.AutomationId="License.Agree"
                  Checked="ChkAgree_Changed"
                  Unchecked="ChkAgree_Changed"/>
    </Grid>
</UserControl>
