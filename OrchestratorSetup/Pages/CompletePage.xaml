<UserControl x:Class="OrchestratorSetup.Pages.CompletePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.Complete">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="480" Margin="48,0">

            <!-- Success icon -->
            <TextBlock Text="✅" FontSize="64"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <TextBlock Text="The Orc is Ready!"
                       Style="{StaticResource TextHero}"
                       FontSize="30"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Style="{StaticResource TextSubtitle}"
                       FontSize="13"
                       Margin="0,0,0,32">
                Everything is installed and configured.
                Your AI coding assistant is ready to use — offline, private, yours.
            </TextBlock>

            <Separator Style="{StaticResource HRule}"/>

            <!-- Summary -->
            <Grid Margin="0,16,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile"
                           Style="{StaticResource TextLabel}" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           x:Name="TxtSummaryProfile"
                           Style="{StaticResource TextBody}"
                           VerticalAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Model"
                           Style="{StaticResource TextLabel}" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           x:Name="TxtSummaryModel"
                           Style="{StaticResource TextBody}"
                           VerticalAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Installed to"
                           Style="{StaticResource TextLabel}" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           x:Name="TxtSummaryPath"
                           Style="{StaticResource TextBody}"
                           FontFamily="Consolas" FontSize="11"
                           TextWrapping="Wrap"/>
            </Grid>

            <!-- Options -->
            <StackPanel Margin="0,0,0,28">
                <CheckBox x:Name="ChkLaunch"
                          IsChecked="True"
                          Style="{StaticResource ThemedCheckBox}"
                          Content="Launch The Orc now"
                          AutomationProperties.AutomationId="Complete.Launch"
                          Checked="ChkLaunch_Changed"
                          Unchecked="ChkLaunch_Changed"/>
                <CheckBox x:Name="ChkDesktopShortcut"
                          IsChecked="True"
                          Style="{StaticResource ThemedCheckBox}"
                          Content="Create desktop shortcut"
                          AutomationProperties.AutomationId="Complete.Desktop"
                          Checked="ChkDesktop_Changed"
                          Unchecked="ChkDesktop_Changed"/>
                <CheckBox x:Name="ChkStartMenu"
                          IsChecked="True"
                          Style="{StaticResource ThemedCheckBox}"
                          Content="Create Start Menu shortcut"
                          AutomationProperties.AutomationId="Complete.StartMenu"
                          Checked="ChkStartMenu_Changed"
                          Unchecked="ChkStartMenu_Changed"/>
            </StackPanel>

            <!-- Finish button -->
            <Button x:Name="BtnFinish"
                    Content="Finish →"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Center"
                    Padding="32,10"
                    FontSize="14"
                    Click="BtnFinish_Click"
                    AutomationProperties.AutomationId="Complete.Finish"/>

            <TextBlock Margin="0,16,0,0"
                       HorizontalAlignment="Center"
                       Style="{StaticResource TextSubtitle}"
                       FontSize="11">
                Tip: edit <Run FontFamily="Consolas">.agent.md</Run> in your workspace to customise agent behaviour.
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
