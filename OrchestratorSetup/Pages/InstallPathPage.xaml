<UserControl x:Class="OrchestratorSetup.Pages.InstallPathPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.InstallPath">

    <Grid Margin="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Installation Paths" Style="{StaticResource TextPageTitle}"/>
            <TextBlock Style="{StaticResource TextSubtitle}">
                Choose where to install the app and where to store model files.
                Models can be large (4–20 GB) — pick a drive with plenty of space.
            </TextBlock>
        </StackPanel>

        <!-- App path -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="APP INSTALLATION FOLDER"
                           Style="{StaticResource TextLabel}"
                           Margin="0,0,0,8"/>
                <TextBlock Style="{StaticResource TextSubtitle}" FontSize="11" Margin="0,0,0,10">
                    OrchestratorIDE.exe, the llama.cpp runtime, and all support files.
                    Typically a few hundred MB.
                </TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             x:Name="TxtAppPath"
                             Style="{StaticResource FlatTextBox}"
                             AutomationProperties.AutomationId="Path.AppInstall"
                             TextChanged="TxtAppPath_TextChanged"/>
                    <Button Grid.Column="2"
                            Content="Browse…"
                            Style="{StaticResource BrowseButton}"
                            Click="BtnBrowseApp_Click"
                            AutomationProperties.AutomationId="Path.BrowseApp"/>
                </Grid>
                <TextBlock x:Name="TxtAppDriveSpace"
                           Style="{StaticResource TextSubtitle}"
                           FontSize="11"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Model path -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="MODEL STORAGE FOLDER"
                           Style="{StaticResource TextLabel}"
                           Margin="0,0,0,8"/>
                <TextBlock Style="{StaticResource TextSubtitle}" FontSize="11" Margin="0,0,0,10">
                    GGUF model files (.gguf). Models range from 2 GB to 20 GB.
                    Store on the drive with the most free space — can be different from the app.
                </TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             x:Name="TxtModelPath"
                             Style="{StaticResource FlatTextBox}"
                             AutomationProperties.AutomationId="Path.ModelStorage"
                             TextChanged="TxtModelPath_TextChanged"/>
                    <Button Grid.Column="2"
                            Content="Browse…"
                            Style="{StaticResource BrowseButton}"
                            Click="BtnBrowseModel_Click"
                            AutomationProperties.AutomationId="Path.BrowseModel"/>
                </Grid>
                <TextBlock x:Name="TxtModelDriveSpace"
                           Style="{StaticResource TextSubtitle}"
                           FontSize="11"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Validation message -->
        <TextBlock Grid.Row="3"
                   x:Name="TxtValidation"
                   Foreground="{StaticResource Error}"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>
