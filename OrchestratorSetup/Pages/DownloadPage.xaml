<UserControl x:Class="OrchestratorSetup.Pages.DownloadPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.Download">

    <Grid Margin="40,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with orc mascot -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="TxtPageTitle"
                           Text="Downloading &amp; Installing…"
                           Style="{StaticResource TextPageTitle}"/>
                <TextBlock x:Name="TxtPageSubtitle"
                           Style="{StaticResource TextSubtitle}">
                    Please wait while TheOrc downloads and installs all components.
                    Large models may take several minutes.
                </TextBlock>
            </StackPanel>
            <Image Grid.Column="1"
                   Source="pack://application:,,,/Assets/badge1.png"
                   Width="88" Height="88"
                   Stretch="Uniform"
                   VerticalAlignment="Top"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Margin="16,0,0,0"/>
        </Grid>

        <!-- Overall progress -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,14">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="OVERALL PROGRESS"
                               Style="{StaticResource TextLabel}"/>
                    <TextBlock x:Name="TxtOverallPct"
                               HorizontalAlignment="Right"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource Accent}"/>
                </Grid>
                <ProgressBar x:Name="PbOverall"
                             Style="{StaticResource ThemedProgressBar}"
                             Height="10"
                             Value="0" Maximum="100"
                             AutomationProperties.AutomationId="Download.Overall"/>
                <TextBlock x:Name="TxtOverallStatus"
                           Style="{StaticResource TextSubtitle}"
                           FontSize="11"
                           Margin="0,8,0,0"
                           Text="Preparing…"/>
            </StackPanel>
        </Border>

        <!-- Per-item download list -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="DownloadItems"/>
        </ScrollViewer>

        <!-- Log / error area -->
        <Border Grid.Row="3"
                Style="{StaticResource CardBorder}"
                Padding="12,8"
                Margin="0,12,0,0"
                MaxHeight="100">
            <ScrollViewer x:Name="LogScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="TxtLog"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
