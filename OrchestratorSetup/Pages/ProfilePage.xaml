<UserControl x:Class="OrchestratorSetup.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPanel}"
             AutomationProperties.AutomationId="Page.Profile">

    <Grid Margin="40,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Coding Profile" Style="{StaticResource TextPageTitle}"/>
            <TextBlock Style="{StaticResource TextSubtitle}">
                Your selection tailors the AI agent's rules and model recommendation.
                You can switch profiles later by editing <Run FontFamily="Consolas">.agent.md</Run>.
            </TextBlock>
        </StackPanel>

        <!-- Profile grid — 2 columns × 4 rows -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <UniformGrid x:Name="ProfileGrid"
                         Columns="2"
                         Margin="0,0,0,8"/>
        </ScrollViewer>

        <!-- Selected label -->
        <TextBlock Grid.Row="2"
                   x:Name="TxtSelected"
                   Style="{StaticResource TextSubtitle}"
                   FontSize="11"
                   Margin="0,8,0,0"/>
    </Grid>
</UserControl>
